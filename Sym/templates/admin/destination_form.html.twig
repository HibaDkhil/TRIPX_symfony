{% extends 'admin/admin_base.html.twig' %}
{% block title %}{{ target_destination ? 'Edit' : 'Add' }} Destination — TripX Admin{% endblock %}

{% block breadcrumbs %}
  <a href="{{ path('admin_dashboard') }}" class="crumb">Dashboard</a>
  <span class="sep">›</span>
  <a href="{{ path('admin_destinations') }}" class="crumb">Destinations</a>
  <span class="sep">›</span>
  <span class="crumb active">{{ target_destination ? 'Edit ' ~ target_destination.name : 'Add Destination' }}</span>
{% endblock %}

{% block content %}
<div class="reveal">
  <div style="margin-bottom:32px;">
    <h1 class="display-sm" style="margin-bottom:4px">{{ target_destination ? 'Edit' : 'Add' }} Destination</h1>
    <p class="text-muted" style="font-size:14px">Fill the details for the destination.</p>
  </div>

  <div class="card reveal" style="max-width: 800px;">
    <div class="card-body">
      {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
        
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
          <div class="form-group" style="margin-bottom: 20px;">
            {{ form_label(form.name, 'Name *', {'label_attr': {'style': 'display:block; margin-bottom:8px; font-weight:600;'}}) }}
            {{ form_widget(form.name, {'attr': {'class': 'form-control', 'style': 'width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);'}}) }}
            <div style="color: red; font-size: 13px; margin-top: 4px;">{{ form_errors(form.name) }}</div>
          </div>
          <div class="form-group" style="margin-bottom: 20px;">
            {{ form_label(form.country, 'Country *', {'label_attr': {'style': 'display:block; margin-bottom:8px; font-weight:600;'}}) }}
            {{ form_widget(form.country, {'attr': {'class': 'form-control', 'style': 'width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);'}}) }}
            <div style="color: red; font-size: 13px; margin-top: 4px;">{{ form_errors(form.country) }}</div>
          </div>
          <div class="form-group" style="margin-bottom: 20px;">
            {{ form_label(form.city, 'City', {'label_attr': {'style': 'display:block; margin-bottom:8px; font-weight:600;'}}) }}
            {{ form_widget(form.city, {'attr': {'class': 'form-control', 'style': 'width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);'}}) }}
            <div style="color: red; font-size: 13px; margin-top: 4px;">{{ form_errors(form.city) }}</div>
          </div>
          <div class="form-group" style="margin-bottom: 20px;">
            {{ form_label(form.type, 'Type *', {'label_attr': {'style': 'display:block; margin-bottom:8px; font-weight:600;'}}) }}
            {{ form_widget(form.type, {'attr': {'class': 'form-control', 'style': 'width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);'}}) }}
            <div style="color: red; font-size: 13px; margin-top: 4px;">{{ form_errors(form.type) }}</div>
          </div>
          <div class="form-group" style="margin-bottom: 20px;">
            {{ form_label(form.bestSeason, 'Best Season *', {'label_attr': {'style': 'display:block; margin-bottom:8px; font-weight:600;'}}) }}
            {{ form_widget(form.bestSeason, {'attr': {'class': 'form-control', 'style': 'width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);'}}) }}
            <div style="color: red; font-size: 13px; margin-top: 4px;">{{ form_errors(form.bestSeason) }}</div>
          </div>
          <div class="form-group" style="margin-bottom: 20px;">
            {{ form_label(form.estimatedBudget, 'Estimated Budget', {'label_attr': {'style': 'display:block; margin-bottom:8px; font-weight:600;'}}) }}
            {{ form_widget(form.estimatedBudget, {'attr': {'class': 'form-control', 'style': 'width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);'}}) }}
            <div style="color: red; font-size: 13px; margin-top: 4px;">{{ form_errors(form.estimatedBudget) }}</div>
          </div>
          <div class="form-group" style="margin-bottom: 20px;">
            {{ form_label(form.imageUrl, 'Image URL', {'label_attr': {'style': 'display:block; margin-bottom:8px; font-weight:600;'}}) }}
            {{ form_widget(form.imageUrl, {'attr': {'class': 'form-control', 'style': 'width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);'}}) }}
            <div style="color: red; font-size: 13px; margin-top: 4px;">{{ form_errors(form.imageUrl) }}</div>
          </div>
          <div class="form-group" style="margin-bottom: 20px;">
            {{ form_label(form.latitude, 'Latitude', {'label_attr': {'style': 'display:block; margin-bottom:8px; font-weight:600;'}}) }}
            {{ form_widget(form.latitude, {'attr': {'class': 'form-control', 'style': 'width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);'}}) }}
            <div style="color: red; font-size: 13px; margin-top: 4px;">{{ form_errors(form.latitude) }}</div>
          </div>
          <div class="form-group" style="margin-bottom: 20px;">
            {{ form_label(form.longitude, 'Longitude', {'label_attr': {'style': 'display:block; margin-bottom:8px; font-weight:600;'}}) }}
            {{ form_widget(form.longitude, {'attr': {'class': 'form-control', 'style': 'width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);'}}) }}
            <div style="color: red; font-size: 13px; margin-top: 4px;">{{ form_errors(form.longitude) }}</div>
          </div>
        </div>
        
        <div class="form-group" style="margin-bottom: 20px;">
          {{ form_label(form.description, 'Description', {'label_attr': {'style': 'display:block; margin-bottom:8px; font-weight:600;'}}) }}
          {{ form_widget(form.description, {'attr': {'rows': '4', 'class': 'form-control', 'style': 'width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);'}}) }}
          <div style="color: red; font-size: 13px; margin-top: 4px;">{{ form_errors(form.description) }}</div>
        </div>

        <div style="display:flex; gap:12px; margin-top:32px;">
          <button type="submit" class="btn btn-primary" style="flex:1;">Save Destination</button>
          <a href="{{ path('admin_destinations') }}" class="btn btn-secondary" style="flex:1; text-align:center;">Cancel</a>
        </div>
      {{ form_end(form) }}
    </div>
  </div>
</div>
{% endblock %}
