{% extends 'admin/admin_base.html.twig' %}
{% block title %}Blog Management — TripX Admin{% endblock %}

{% block breadcrumbs %}
  <span class="crumb active">Blog</span>
{% endblock %}

{% block content %}
<style>
/* ── Admin Blog Styles ── */
.ab-stats        { display:grid; grid-template-columns:repeat(auto-fill,minmax(160px,1fr)); gap:16px; margin-bottom:28px; }
.ab-stat         { background:var(--bg-card); border:1px solid var(--border-color); border-radius:14px; padding:20px 18px; position:relative; overflow:hidden; transition:all .2s; }
.ab-stat:hover   { transform:translateY(-2px); box-shadow:0 8px 28px rgba(0,0,0,.25); }
.ab-stat::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; }
.ab-stat.c1::before { background:linear-gradient(90deg,#2563eb,#0ea5e9); }
.ab-stat.c2::before { background:linear-gradient(90deg,#f59e0b,#ef4444); }
.ab-stat.c3::before { background:linear-gradient(90deg,#10b981,#3b82f6); }
.ab-stat.c4::before { background:#a78bfa; }
.ab-stat.c5::before { background:#38bdf8; }
.ab-stat .num    { font-size:32px; font-weight:900; color:var(--accent-primary); line-height:1; }
.ab-stat .lbl    { font-size:12px; color:var(--text-muted); margin-top:4px; font-weight:600; text-transform:uppercase; letter-spacing:.06em; }

.ab-tabs         { display:flex; gap:0; border-bottom:2px solid var(--border-color); margin-bottom:24px; }
.ab-tab          { padding:12px 24px; font-size:14px; font-weight:700; cursor:pointer; border:none; background:none; color:var(--text-muted); position:relative; transition:color .2s; }
.ab-tab:hover    { color:var(--text-primary); }
.ab-tab.active   { color:var(--accent-primary); }
.ab-tab.active::after { content:''; position:absolute; bottom:-2px; left:0; right:0; height:2px; background:var(--accent-primary); }
.tab-cnt         { display:inline-block; margin-left:6px; padding:1px 8px; border-radius:50px; font-size:11px; font-weight:700; background:rgba(255,255,255,.08); }
.ab-tab.active .tab-cnt { background:var(--accent-primary); color:#fff; }
.tab-panel       { display:none; }
.tab-panel.active{ display:block; }

/* Table */
.ab-table        { width:100%; border-collapse:collapse; background:var(--bg-card); border-radius:14px; overflow:hidden; border:1px solid var(--border-color); }
.ab-table th     { background:var(--bg-surface); padding:12px 14px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--text-muted); text-align:left; border-bottom:1px solid var(--border-color); }
.ab-table td     { padding:13px 14px; font-size:13px; border-bottom:1px solid var(--border-color); vertical-align:middle; }
.ab-table tr:last-child td { border-bottom:none; }
.ab-table tr:hover td { background:rgba(255,255,255,.03); }

/* Badges */
.badge           { display:inline-block; padding:3px 10px; border-radius:50px; font-size:11px; font-weight:700; }
.badge-pending   { background:rgba(245,158,11,.15); color:#fcd34d; border:1px solid rgba(245,158,11,.3); }
.badge-approved  { background:rgba(16,185,129,.15); color:#6ee7b7; border:1px solid rgba(16,185,129,.3); }
.type-dot        { display:inline-block; padding:3px 10px; border-radius:50px; font-size:11px; font-weight:700; }
.type-inquiry    { background:rgba(59,130,246,.15); color:#93c5fd; }
.type-story      { background:rgba(16,185,129,.15); color:#6ee7b7; }
.type-review     { background:rgba(245,158,11,.15); color:#fcd34d; }
.type-advice     { background:rgba(168,85,247,.15); color:#c4b5fd; }
.type-other      { background:rgba(255,255,255,.06); color:#9ca3af; }

/* Action buttons */
.ab-actions      { display:flex; gap:6px; flex-wrap:wrap; }
.btn-approve     { padding:5px 12px; background:rgba(16,185,129,.15); color:#6ee7b7; border:1px solid rgba(16,185,129,.3); border-radius:50px; font-size:12px; font-weight:700; cursor:pointer; transition:all .2s; }
.btn-approve:hover { background:rgba(16,185,129,.3); }
.btn-reject      { padding:5px 12px; background:rgba(245,158,11,.15); color:#fcd34d; border:1px solid rgba(245,158,11,.3); border-radius:50px; font-size:12px; font-weight:700; cursor:pointer; transition:all .2s; }
.btn-reject:hover{ background:rgba(245,158,11,.3); }
.btn-del         { padding:5px 12px; background:rgba(239,68,68,.15); color:#fca5a5; border:1px solid rgba(239,68,68,.3); border-radius:50px; font-size:12px; font-weight:700; cursor:pointer; transition:all .2s; }
.btn-del:hover   { background:rgba(239,68,68,.3); }
.btn-edit        { padding:5px 12px; background:rgba(37,99,235,.15); color:#c4b5fd; border:1px solid rgba(37,99,235,.3); border-radius:50px; font-size:12px; font-weight:700; cursor:pointer; transition:all .2s; }
.btn-edit:hover  { background:rgba(37,99,235,.3); }
.btn-view        { padding:5px 12px; background:rgba(59,130,246,.15); color:#93c5fd; border:1px solid rgba(59,130,246,.3); border-radius:50px; font-size:12px; font-weight:700; text-decoration:none; transition:all .2s; }
.btn-view:hover  { background:rgba(59,130,246,.3); }

.post-title-cell { max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; font-weight:700; color:var(--text-primary); }
.story-thumb     { width:44px; height:34px; object-fit:cover; border-radius:6px; }
.empty-state-admin { text-align:center; padding:48px; color:var(--text-muted); }

/* Search + Filter bar */
.ab-toolbar      { display:flex; gap:12px; margin-bottom:18px; flex-wrap:wrap; align-items:center; }
.ab-search-wrap  { flex:1; min-width:200px; display:flex; align-items:center; gap:8px; background:var(--bg-card); border:1px solid var(--border-color); border-radius:50px; padding:9px 16px; }
.ab-search-wrap input { flex:1; border:none; background:none; outline:none; font-size:13px; color:var(--text-primary); }
.ab-filter-select { padding:9px 14px; background:var(--bg-card); border:1px solid var(--border-color); border-radius:50px; color:var(--text-primary); font-size:13px; cursor:pointer; outline:none; }

/* Edit Modal */
.ab-modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.7); z-index:1000; align-items:center; justify-content:center; }
.ab-modal-overlay.open { display:flex; }
.ab-modal        { background:var(--bg-card); border:1px solid var(--border-color); border-radius:20px; padding:28px 30px; width:100%; max-width:560px; animation:modalIn .25s cubic-bezier(0.22,1,0.36,1); }
@keyframes modalIn { from{opacity:0;transform:scale(.95) translateY(10px)} to{opacity:1;transform:none} }
.ab-modal h3     { font-size:18px; font-weight:800; color:var(--text-primary); margin:0 0 20px; }
.ab-modal label  { display:block; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--text-muted); margin-bottom:6px; margin-top:16px; }
.ab-modal label:first-of-type { margin-top:0; }
.ab-modal input, .ab-modal textarea, .ab-modal select {
  width:100%; padding:11px 14px; background:var(--bg-surface); border:1px solid var(--border-color);
  border-radius:10px; color:var(--text-primary); font-size:14px; outline:none; box-sizing:border-box;
  font-family:inherit; transition:border-color .2s;
}
.ab-modal input:focus, .ab-modal textarea:focus, .ab-modal select:focus {
  border-color:var(--accent-primary);
  box-shadow:0 0 0 3px rgba(99,102,241,.15);
}
.ab-modal textarea { min-height:130px; resize:vertical; }
.ab-modal-actions { display:flex; gap:10px; margin-top:20px; justify-content:flex-end; }
.ab-modal-save   { padding:10px 24px; background:var(--accent-primary,#6366f1); color:#fff; border:none; border-radius:50px; font-weight:700; cursor:pointer; transition:all .2s; }
.ab-modal-save:hover { opacity:.85; }
.ab-modal-cancel { padding:10px 20px; background:rgba(255,255,255,.06); border:1px solid var(--border-color); color:var(--text-muted); border-radius:50px; cursor:pointer; font-weight:700; transition:all .2s; }
.ab-modal-err    { font-size:12px; color:#fca5a5; margin-top:8px; }
.ab-modal-close  { float:right; background:none; border:none; color:var(--text-muted); font-size:20px; cursor:pointer; line-height:1; }

/* Confirmation modal */
.ab-confirm-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:1001; align-items:center; justify-content:center; }
.ab-confirm-overlay.open { display:flex; }
.ab-confirm      { background:var(--bg-card); border:1px solid var(--border-color); border-radius:16px; padding:24px 28px; max-width:380px; width:100%; text-align:center; animation:modalIn .2s ease; }
.ab-confirm h4   { font-size:17px; font-weight:800; margin:0 0 10px; color:var(--text-primary); }
.ab-confirm p    { font-size:13px; color:var(--text-muted); margin:0 0 20px; }
.ab-confirm-btns { display:flex; gap:10px; justify-content:center; }
.ab-confirm-yes  { padding:9px 24px; background:#ef4444; color:#fff; border:none; border-radius:50px; font-weight:700; cursor:pointer; }
.ab-confirm-no   { padding:9px 20px; background:rgba(255,255,255,.06); border:1px solid var(--border-color); color:var(--text-muted); border-radius:50px; cursor:pointer; font-weight:700; }

/* Flash */
.ab-flash        { padding:12px 18px; border-radius:12px; margin-bottom:18px; font-size:13px; font-weight:600; }
.ab-flash.success{ background:rgba(16,185,129,.1); border:1px solid rgba(16,185,129,.3); color:#6ee7b7; }
.ab-flash.info   { background:rgba(59,130,246,.1); border:1px solid rgba(59,130,246,.3); color:#93c5fd; }
.ab-flash.error  { background:rgba(239,68,68,.1); border:1px solid rgba(239,68,68,.3); color:#fca5a5; }
</style>

{# Flash messages #}
{% for msg in app.flashes('success') %}<div class="ab-flash success">✅ {{ msg }}</div>{% endfor %}
{% for msg in app.flashes('info') %}<div class="ab-flash info">ℹ️ {{ msg }}</div>{% endfor %}
{% for msg in app.flashes('error') %}<div class="ab-flash error">❌ {{ msg }}</div>{% endfor %}
<div id="ajax-flash" style="display:none;" class="ab-flash"></div>

{# Stats #}
<div class="ab-stats">
  <div class="ab-stat c1">
    <div class="num">{{ stats.total }}</div>
    <div class="lbl">Total Posts</div>
  </div>
  <div class="ab-stat c2">
    <div class="num">{{ stats.pending }}</div>
    <div class="lbl">Pending</div>
  </div>
  <div class="ab-stat c3">
    <div class="num">{{ stats.approved }}</div>
    <div class="lbl">Approved</div>
  </div>
  <div class="ab-stat c4">
    <div class="num">{{ stats.stories }}</div>
    <div class="lbl">Travel Stories</div>
  </div>
  <div class="ab-stat c5">
    <div class="num">{{ stats.comments }}</div>
    <div class="lbl">Comments</div>
  </div>
</div>

{# Tabs #}
<div class="ab-tabs">
  <button class="ab-tab active" onclick="switchTab('posts', this)">
    📝 Posts <span class="tab-cnt">{{ posts|length }}</span>
  </button>
  <button class="ab-tab" onclick="switchTab('stories', this)">
    🧳 Stories <span class="tab-cnt">{{ stories|length }}</span>
  </button>
  <button class="ab-tab" onclick="switchTab('comments', this)">
    💬 Comments <span class="tab-cnt">{{ stats.comments }}</span>
  </button>
</div>

{# ── POSTS TAB ── #}
<div class="tab-panel active" id="tab-posts">
  <div class="ab-toolbar">
    <div class="ab-search-wrap">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <input type="text" id="posts-search" placeholder="Search posts…" oninput="triggerPostFilter()">
    </div>
    <select class="ab-filter-select" id="posts-type-filter" onchange="triggerPostFilter()">
      <option value="">All Types</option>
      <option value="inquiry">Inquiry</option>
      <option value="story">Story</option>
      <option value="review">Review</option>
      <option value="advice">Advice</option>
      <option value="other">Other</option>
    </select>
    <select class="ab-filter-select" id="posts-status-filter" onchange="triggerPostFilter()">
      <option value="">All Statuses</option>
      <option value="pending">Pending</option>
      <option value="approved">Approved</option>
    </select>
  </div>
  {% if posts is empty %}
    <div class="empty-state-admin"><p style="font-size:42px">📭</p><p>No posts yet.</p></div>
  {% else %}
    <table class="ab-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Title</th>
          <th>Author</th>
          <th>Type</th>
          <th>Status</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="posts-tbody">
        {% for post in posts %}
          <tr id="post-row-{{ post.id }}"
              data-title="{{ post.title|lower }}"
              data-type="{{ post.type }}"
              data-status="{{ post.isConfirmed ? 'approved' : 'pending' }}">
            <td style="color:var(--text-muted);font-size:12px;">{{ post.id }}</td>
            <td class="post-title-cell" title="{{ post.title }}">{{ post.title }}</td>
            <td>{{ authorMap[post.userId] ?? 'User #' ~ post.userId }}</td>
            <td><span class="type-dot type-{{ post.type }}">{{ post.type }}</span></td>
            <td id="status-cell-{{ post.id }}">
              {% if post.isConfirmed %}
                <span class="badge badge-approved">✅ Approved</span>
              {% else %}
                <span class="badge badge-pending">⏳ Pending</span>
              {% endif %}
            </td>
            <td style="font-size:12px;color:var(--text-muted);">
              {% if post.createdAt %}{{ post.createdAt|date('d M Y') }}{% endif %}
            </td>
            <td>
              <div class="ab-actions">
                <a href="{{ path('admin_post_show', {id: post.id}) }}" class="btn-view">View</a>
                <button class="btn-edit" onclick="openEditModal({{ post.id }}, {{ post.title|json_encode }}, {{ post.body|json_encode }}, '{{ post.type }}', '{{ csrf_token('admin_blog_edit_' ~ post.id)|e('js') }}')">
                  Edit
                </button>
                {% if not post.isConfirmed %}
                  <button class="btn-approve" onclick="approvePost({{ post.id }}, {{ csrf_token('admin_blog_' ~ post.id)|json_encode }})">
                    Approve
                  </button>
                {% else %}
                  <button class="btn-reject" onclick="rejectPost({{ post.id }}, {{ csrf_token('admin_blog_' ~ post.id)|json_encode }})">
                    Reject
                  </button>
                {% endif %}
                <button class="btn-del" onclick="confirmDelete('post', {{ post.id }}, {{ csrf_token('admin_blog_delete_' ~ post.id)|json_encode }})">
                  Delete
                </button>
              </div>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}
</div>

{# ── STORIES TAB ── #}
<div class="tab-panel" id="tab-stories">
  <div class="ab-toolbar">
    <div class="ab-search-wrap">
      <input type="text" id="stories-search" placeholder="Search stories…" oninput="filterTable('stories-tbody', this.value)">
    </div>
  </div>
  {% if stories is empty %}
    <div class="empty-state-admin"><p style="font-size:42px">🧳</p><p>No travel stories yet.</p></div>
  {% else %}
    <table class="ab-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Cover</th>
          <th>Title</th>
          <th>Author</th>
          <th>Destination</th>
          <th>Rating</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="stories-tbody">
        {% for story in stories %}
          <tr id="story-row-{{ story.id }}" data-title="{{ story.title|lower }}">
            <td style="color:var(--text-muted);font-size:12px;">{{ story.id }}</td>
            <td>
              {% if story.coverImageUrl %}
                <img src="{{ story.coverImageUrl }}" class="story-thumb" onerror="this.style.display='none'">
              {% else %}—{% endif %}
            </td>
            <td class="post-title-cell" title="{{ story.title }}">{{ story.title }}</td>
            <td>{{ authorMap[story.userId] ?? 'User #' ~ story.userId }}</td>
            <td>{{ story.destination ?? '—' }}</td>
            <td>
              {% if story.overallRating %}
                <span style="color:#fcd34d;">{% for i in 1..story.overallRating %}⭐{% endfor %}</span>
              {% else %}—{% endif %}
            </td>
            <td style="font-size:12px;color:var(--text-muted);">{% if story.createdAt %}{{ story.createdAt|date('d M Y') }}{% endif %}</td>
            <td>
              <div class="ab-actions">
                <a href="{{ path('admin_story_show', {id: story.id}) }}" class="btn-view">View</a>
                <button class="btn-del" onclick="confirmDelete('story', {{ story.id }}, {{ csrf_token('admin_story_delete_' ~ story.id)|json_encode }})">
                  Delete
                </button>
              </div>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}
</div>

{# ── COMMENTS TAB ── #}
<div class="tab-panel" id="tab-comments">
  <div class="ab-toolbar">
    <div class="ab-search-wrap">
      <input type="text" id="comments-search" placeholder="Search comments…" oninput="filterTable('comments-tbody', this.value)">
    </div>
  </div>
  {% if comments is empty %}
    <div class="empty-state-admin"><p style="font-size:42px">💬</p><p>No comments yet.</p></div>
  {% else %}
    <table class="ab-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Comment</th>
          <th>Author</th>
          <th>Post ID</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="comments-tbody">
        {% for comment in comments %}
          <tr id="comment-row-{{ comment.id }}" data-title="{{ comment.body|lower }}">
            <td style="color:var(--text-muted);font-size:12px;">{{ comment.id }}</td>
            <td style="max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
              {{ comment.body }}
            </td>
            <td>{{ authorMap[comment.userId] ?? 'User #' ~ comment.userId }}</td>
            <td>
              {% if comment.post %}
                <a href="{{ path('admin_post_show', {id: comment.post.id}) }}" class="btn-view" style="font-size:11px;">
                  #{{ comment.post.id }}
                </a>
              {% else %}—{% endif %}
            </td>
            <td style="font-size:12px;color:var(--text-muted);">
              {% if comment.createdAt %}{{ comment.createdAt|date('d M Y · H:i') }}{% endif %}
            </td>
            <td>
              <div class="ab-actions">
                <button class="btn-del" onclick="confirmDelete('comment', {{ comment.id }}, {{ csrf_token('admin_comment_delete_' ~ comment.id)|json_encode }})">
                  Delete
                </button>
              </div>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}
</div>

{# ── Edit Modal ── #}
<div class="ab-modal-overlay" id="edit-modal">
  <div class="ab-modal">
    <button class="ab-modal-close" onclick="closeEditModal()">×</button>
    <h3>✏️ Edit Post</h3>
    <label>Title</label>
    <input type="text" id="modal-title" placeholder="Post title…" autocomplete="off">
    <label>Content</label>
    <textarea id="modal-body" placeholder="Post content…"></textarea>
    <label>Type</label>
    <select id="modal-type">
      <option value="inquiry">Inquiry</option>
      <option value="story">Story</option>
      <option value="review">Review</option>
      <option value="advice">Advice</option>
      <option value="other">Other</option>
    </select>
    <div class="ab-modal-err" id="modal-err"></div>
    <div class="ab-modal-actions">
      <button class="ab-modal-cancel" onclick="closeEditModal()">Cancel</button>
      <button class="ab-modal-save" onclick="savePost()">💾 Save Changes</button>
    </div>
  </div>
</div>

{# ── Confirm Modal ── #}
<div class="ab-confirm-overlay" id="confirm-modal">
  <div class="ab-confirm">
    <h4 id="confirm-title">Are you sure?</h4>
    <p id="confirm-msg">This action cannot be undone.</p>
    <div class="ab-confirm-btns">
      <button class="ab-confirm-no" onclick="closeConfirm()">Cancel</button>
      <button class="ab-confirm-yes" id="confirm-yes-btn">Confirm</button>
    </div>
  </div>
</div>

<script>
/* ── Tab switch ── */
function switchTab(tab, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.ab-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');
  btn.classList.add('active');
}

/* ── Filter table rows ── */
function triggerPostFilter() {
  filterTable('posts-tbody', document.getElementById('posts-search').value, document.getElementById('posts-type-filter').value, document.getElementById('posts-status-filter').value);
}

function filterTable(tbodyId, q, typeVal, statusVal) {
  const tbody  = document.getElementById(tbodyId);
  if (!tbody) return;
  const search = (q || '').toLowerCase().trim();
  tbody.querySelectorAll('tr').forEach(row => {
    const title  = (row.dataset.title || '').toLowerCase();
    const type   = (row.dataset.type  || '').toLowerCase();
    const status = (row.dataset.status|| '').toLowerCase();
    const matchQ      = !search   || title.includes(search);
    const matchType   = !typeVal  || type   === typeVal;
    const matchStatus = !statusVal|| status === statusVal;
    row.style.display = matchQ && matchType && matchStatus ? '' : 'none';
  });
}

/* ── Flash ── */
function showAdminFlash(msg, type) {
  const f = document.getElementById('ajax-flash');
  f.textContent  = msg;
  f.className    = 'ab-flash ' + type;
  f.style.display = 'block';
  clearTimeout(f._t);
  f._t = setTimeout(() => { f.style.display = 'none'; }, 4000);
}

/* ── Approve / Reject ── */
async function approvePost(id, token) {
  const fd = new URLSearchParams({ _token: token });
  try {
    const res  = await fetch(`/admin/blog/${id}/approve`, { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    const data = await res.json();
    if (data.success) {
      document.getElementById(`status-cell-${id}`).innerHTML = '<span class="badge badge-approved">✅ Approved</span>';
      const row = document.getElementById(`post-row-${id}`);
      if (row) row.dataset.status = 'approved';
      // Swap button Approve → Reject
      const approveBtn = document.querySelector(`[onclick*="approvePost(${id},"]`);
      if (approveBtn) {
        const newToken = '{% verbatim %}{{ csrf_token("admin_blog_" ~ id) }}{% endverbatim %}';
        approveBtn.outerHTML = `<button class="btn-reject" onclick="rejectPost(${id}, '${token}')">Reject</button>`;
      }
      showAdminFlash('✅ Post approved!', 'success');
    }
  } catch(e) { showAdminFlash('❌ Error approving post.', 'error'); }
}

async function rejectPost(id, token) {
  const fd = new URLSearchParams({ _token: token });
  try {
    const res  = await fetch(`/admin/blog/${id}/reject`, { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    const data = await res.json();
    if (data.success) {
      document.getElementById(`status-cell-${id}`).innerHTML = '<span class="badge badge-pending">⏳ Pending</span>';
      const row = document.getElementById(`post-row-${id}`);
      if (row) row.dataset.status = 'pending';
      showAdminFlash('ℹ️ Post rejected.', 'info');
    }
  } catch(e) { showAdminFlash('❌ Error rejecting post.', 'error'); }
}

/* ── Edit Modal ── */
let _editId    = null;
let _editToken = null;

function openEditModal(id, title, body, type, token) {
  _editId    = id;
  _editToken = token;
  document.getElementById('modal-title').value = title;
  document.getElementById('modal-body').value  = body;
  document.getElementById('modal-type').value  = type;
  document.getElementById('modal-err').textContent = '';
  document.getElementById('edit-modal').classList.add('open');
}

function closeEditModal() {
  document.getElementById('edit-modal').classList.remove('open');
}

// Generate correct CSRF token per post on open
document.querySelectorAll('[onclick*="openEditModal"]').forEach(btn => {
  const id = btn.getAttribute('onclick').match(/openEditModal\((\d+)/)?.[1];
  if (id) {
    // CSRF tokens are baked in per-row from Twig; the JS will grab the right one via hidden fields approach
  }
});

async function savePost() {
  const title = document.getElementById('modal-title').value.trim();
  const body  = document.getElementById('modal-body').value.trim();
  const type  = document.getElementById('modal-type').value;
  const errEl = document.getElementById('modal-err');

  errEl.textContent = '';
  if (title.length < 3) { errEl.textContent = 'Title must be at least 3 characters.'; return; }
  if (body.length < 10) { errEl.textContent = 'Body must be at least 10 characters.'; return; }

  // Use the directly provided token
  const token = _editToken;

  const fd = new URLSearchParams({ title, body, type, _token: token });
  try {
    const res  = await fetch(`/admin/blog/${_editId}/edit`, { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    const data = await res.json();
    if (data.error) { errEl.textContent = data.error; return; }
    if (data.success) {
      const row = document.getElementById('post-row-' + _editId);
      const cell = row?.querySelector('.post-title-cell');
      if (cell) cell.textContent = data.title;
      if (row) {
        row.dataset.title = data.title.toLowerCase();
        row.dataset.type = data.type;
        const typeEl = row.querySelector('.type-dot');
        if (typeEl) {
          typeEl.className = 'type-dot type-' + data.type;
          typeEl.textContent = data.type;
        }
      }
      showAdminFlash('✅ Post updated!', 'success');
      closeEditModal();
    }
  } catch(e) { errEl.textContent = 'Failed to save.'; }
}

/* ── Confirm Delete ── */
let _confirmCallback = null;

function confirmDelete(targetType, id, token) {
  const labels = { post: 'post', story: 'travel story', comment: 'comment' };
  document.getElementById('confirm-title').textContent = 'Delete this ' + labels[targetType] + '?';
  document.getElementById('confirm-msg').textContent   = 'This action cannot be undone.';
  document.getElementById('confirm-modal').classList.add('open');

  _confirmCallback = async () => {
    const routes = {
      post:    `/admin/blog/${id}/delete`,
      story:   `/admin/blog/story/${id}/delete`,
      comment: `/admin/blog/comment/${id}/delete`,
    };
    const fd = new URLSearchParams({ _token: token });
    try {
      const res  = await fetch(routes[targetType], { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } });
      const data = await res.json();
      if (data.success) {
        const row = document.getElementById(`${targetType}-row-${id}`);
        if (row) {
          row.style.transition = 'opacity .3s, transform .3s';
          row.style.opacity    = '0';
          row.style.transform  = 'translateX(20px)';
          setTimeout(() => row.remove(), 350);
        }
        showAdminFlash('✅ Deleted successfully.', 'success');
      } else {
        showAdminFlash('❌ Delete failed.', 'error');
      }
    } catch(e) { showAdminFlash('❌ Delete failed.', 'error'); }
    closeConfirm();
  };

  document.getElementById('confirm-yes-btn').onclick = () => _confirmCallback && _confirmCallback();
}

function closeConfirm() {
  document.getElementById('confirm-modal').classList.remove('open');
  _confirmCallback = null;
}

/* Close modals on overlay click */
document.getElementById('edit-modal').addEventListener('click', e => { if (e.target === e.currentTarget) closeEditModal(); });
document.getElementById('confirm-modal').addEventListener('click', e => { if (e.target === e.currentTarget) closeConfirm(); });
</script>
