{% extends 'admin/admin_base.html.twig' %}

{% block title %}Post #{{ post.id }} — TripX Admin{% endblock %}

{% block breadcrumbs %}
  <a href="{{ path('admin_blog') }}" class="crumb">Blog</a>
  <span class="sep">›</span>
  <span class="crumb active">Post #{{ post.id }}</span>
{% endblock %}

{% block content %}
<style>
  .as-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    overflow: hidden;
    animation: fadeUp .4s ease both;
  }
  .as-header {
    padding: 24px 30px;
    border-bottom: 1px solid var(--border-color);
    background: var(--bg-surface);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .as-header-title h1 {
    font-size: 20px;
    font-weight: 800;
    margin: 0;
    color: var(--text-primary);
  }
  .as-body {
    padding: 30px;
  }
  .as-meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
    padding: 20px;
    background: rgba(255,255,255,0.02);
    border-radius: 12px;
    border: 1px solid var(--border-color);
  }
  .as-meta-item label {
    display: block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--text-muted);
    font-weight: 700;
    margin-bottom: 4px;
  }
  .as-meta-item span {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
  }
  .as-content-box {
    margin-bottom: 30px;
    line-height: 1.6;
    color: var(--text-primary);
    font-size: 15px;
    white-space: pre-wrap;
  }
  .as-img-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 12px;
    margin-bottom: 30px;
  }
  .as-img-grid img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid var(--border-color);
  }
  .as-section-title {
    font-size: 14px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--text-muted);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Comments */
  .as-comment {
    display: flex;
    gap: 14px;
    padding: 16px;
    border-bottom: 1px solid var(--border-color);
  }
  .as-comment:last-child { border-bottom: none; }
  .as-comment-avatar {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--accent-primary);
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-weight: 700; font-size: 14px; flex-shrink: 0;
  }
  .as-comment-body { flex: 1; }
  .as-comment-name { font-weight: 700; font-size: 13px; color: var(--text-primary); margin-bottom: 2px; }
  .as-comment-text { font-size: 13px; color: var(--text-muted); line-height: 1.5; }
  .as-comment-meta { font-size: 11px; color: var(--text-muted); margin-top: 6px; }

  .badge { display: inline-block; padding: 4px 10px; border-radius: 50px; font-size: 11px; font-weight: 700; }
  .badge-pending { background: rgba(245,158,11,0.15); color: #fcd34d; border: 1px solid rgba(245,158,11,0.3); }
  .badge-approved { background: rgba(16,185,129,0.15); color: #6ee7b7; border: 1px solid rgba(16,185,129,0.3); }

  .btn-action {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    transition: all .2s;
    border: 1px solid transparent;
  }
  .btn-del { background: rgba(239,68,68,0.1); color: #fca5a5; border-color: rgba(239,68,68,0.2); }
  .btn-del:hover { background: rgba(239,68,68,0.2); }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
</style>

<div class="as-card">
  <div class="as-header">
    <div class="as-header-title">
      <h1>Preview Post #{{ post.id }}</h1>
    </div>
    <div style="display:flex; gap:10px;">
      {% if not post.isConfirmed %}
        <form method="post" action="{{ path('admin_blog_approve', {id: post.id}) }}" class="inline-form">
          <input type="hidden" name="_token" value="{{ csrf_token('admin_blog_' ~ post.id) }}">
          <button type="submit" class="btn-action" style="background:var(--accent-primary); color:#fff;">✅ Approve Post</button>
        </form>
      {% endif %}
      <form method="post" action="{{ path('admin_blog_delete', {id: post.id}) }}" 
            onsubmit="return confirm('Delete this post permanently?')" class="inline-form">
        <input type="hidden" name="_token" value="{{ csrf_token('admin_blog_delete_' ~ post.id) }}">
        <button type="submit" class="btn-action btn-del">🗑 Delete Post</button>
      </form>
    </div>
  </div>

  <div class="as-body">
    <div class="as-meta-grid">
      <div class="as-meta-item">
        <label>Status</label>
        {% if post.isConfirmed %}
          <span class="badge badge-approved">Approved</span>
        {% else %}
          <span class="badge badge-pending">Pending Approval</span>
        {% endif %}
      </div>
      <div class="as-meta-item">
        <label>Author</label>
        <span>{{ authorMap[post.userId] ?? 'User #' ~ post.userId }}</span>
      </div>
      <div class="as-meta-item">
        <label>Type</label>
        <span style="text-transform:capitalize">{{ post.type }}</span>
      </div>
      <div class="as-meta-item">
        <label>Created At</label>
        <span>{{ post.createdAt ? post.createdAt|date('d M Y · H:i') : 'N/A' }}</span>
      </div>
    </div>

    <div class="as-section-title">📄 Content</div>
    <h2 style="font-size:24px; font-weight:900; margin:0 0 16px; color:var(--text-primary);">{{ post.title }}</h2>
    <div class="as-content-box">{{ post.body }}</div>

    {% if post.imageUrl %}
      <div class="as-section-title">🖼️ Media Gallery</div>
      <div class="as-img-grid">
        {% for img in post.imageUrl|split(',') %}
          {% if img|trim %}
            <img src="{{ img|trim }}" alt="Post image" onerror="this.src='https://placehold.co/600x400?text=Image+Not+Found'">
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    <div class="as-section-title">💬 Comments ({{ post.comments|length }})</div>
    <div style="background:rgba(0,0,0,0.02); border:1px solid var(--border-color); border-radius:12px; overflow:hidden;">
      {% if post.comments is empty %}
        <div style="padding:30px; text-align:center; color:var(--text-muted); font-size:14px;">No comments on this post.</div>
      {% else %}
        {% for comment in post.comments %}
          <div class="as-comment">
            <div class="as-comment-avatar">{{ (authorMap[comment.userId] ?? 'U')|first|upper }}</div>
            <div class="as-comment-body">
              <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                <div class="as-comment-name">{{ authorMap[comment.userId] ?? 'User #' ~ comment.userId }}</div>
                <form method="post" action="{{ path('admin_comment_delete', {id: comment.id}) }}" 
                      onsubmit="return confirm('Delete this comment?')">
                  <input type="hidden" name="_token" value="{{ csrf_token('admin_comment_delete_' ~ comment.id) }}">
                  <button type="submit" style="background:none; border:none; color:#ef4444; cursor:pointer; font-size:16px;" title="Delete Comment">🗑</button>
                </form>
              </div>
              <div class="as-comment-text">{{ comment.body }}</div>
              <div class="as-comment-meta">
                {{ comment.createdAt ? comment.createdAt|date('d M Y · H:i') : '' }}
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}
