{% extends 'admin/admin_base.html.twig' %}
{% block title %}Manage Users — TripX Admin{% endblock %}

{% block page_styles %}
  .user-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
  }
  .user-table th {
    background: rgba(0,166,237,0.05);
    text-align: left;
    padding: 16px 20px;
    font-family: var(--font-display);
    font-size: 14px;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    border-bottom: 2px solid var(--border-color);
  }
  .user-table td {
    padding: 16px 20px;
    border-bottom: 1px solid var(--border-color);
    vertical-align: middle;
  }
  .user-table tr:last-child td { border-bottom: none; }
  .user-table tr:hover { background: rgba(255,255,255,0.02); }
  
  .user-meta { display: flex; align-items: center; gap: 12px; }
  .user-avatar { 
    width: 40px; height: 40px; 
    border-radius: 50%; 
    background: var(--accent-primary); 
    display: flex; align-items: center; justify-content: center; 
    color: #fff; font-weight: 700;
  }
  .search-wrap {
    margin-bottom: 24px;
    display: flex;
    gap: 16px;
  }
  .search-input {
    flex: 1;
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    padding: 12px 20px;
    border-radius: 8px;
    color: var(--text-main);
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 30px;
  }
  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    padding: 20px;
    border-radius: var(--border-radius-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .chart-container-small {
    width: 100%;
    height: 180px;
    position: relative;
  }
{% endblock %}

{% block breadcrumbs %}
  <span class="crumb active">Users</span>
{% endblock %}

{% block content %}
  <div class="reveal">
    <h1 class="display-md" style="margin-bottom:6px;">Platform <span class="text-coral">Users</span></h1>
    <p class="text-muted" style="margin-bottom:36px;">Manage accounts, permissions, and security status.</p>
  </div>

  <div class="stats-grid reveal stagger">
    <div class="stat-card">
      <div style="font-family:var(--font-mono); font-size:11px; color:var(--text-muted); margin-bottom:10px;">GENDER DISTRIBUTION</div>
      <div class="chart-container-small">
        <canvas id="userGenderChart"></canvas>
      </div>
    </div>
    <div class="stat-card">
      <div style="font-family:var(--font-mono); font-size:11px; color:var(--text-muted); margin-bottom:10px;">USER GROWTH</div>
      <div class="chart-container-small">
        <canvas id="userGrowthChart"></canvas>
      </div>
      <div style="margin-top:10px; font-size:24px; font-weight:700;">{{ stats.totalUsers }}</div>
      <div style="font-size:12px; color:#10b981;">+12% vs last month</div>
    </div>
    <div class="stat-card">
      <div style="font-family:var(--font-mono); font-size:11px; color:var(--text-muted); margin-bottom:10px;">AVERAGE ENGAGEMENT</div>
      <div style="font-size:48px; margin: 20px 0;">⏱️</div>
      <div style="font-size:24px; font-weight:700;">{{ stats.averageMinutes }} <span style="font-size:14px;font-weight:normal;color:var(--text-muted);">min</span></div>
      <div style="font-size:12px; color:var(--text-muted);">Avg Session Duration per User</div>
    </div>
  </div>

  <div class="search-wrap reveal">
    <form method="get" action="{{ path('admin_users') }}" style="display:flex; width:100%; gap:12px;">
      <input type="text" name="q" id="liveSearch" onkeyup="searchUsers()" value="{{ currentQuery }}" class="search-input" placeholder="Search by name or email..." style="margin-bottom:0;">
      <button type="submit" class="btn btn-primary">Search</button>
      {% if currentQuery %}
        <a href="{{ path('admin_users') }}" class="btn btn-secondary">Clear</a>
      {% endif %}
    </form>
  </div>

  <div id="users-pjax-container">
    <div style="animation: fadeIn 0.5s ease forwards; opacity: 1;">
    <table class="user-table">
      <thead>
        <tr>
          <th>
            <a href="{{ path('admin_users', {s: 'userId', order: currentOrder == 'ASC' ? 'DESC' : 'ASC', q: currentQuery}) }}" style="color:inherit; text-decoration:none;">
              ID {{ currentSort == 'userId' ? (currentOrder == 'ASC' ? '↑' : '↓') : '' }}
            </a>
          </th>
          <th>
            <a href="{{ path('admin_users', {s: 'firstName', order: currentOrder == 'ASC' ? 'DESC' : 'ASC', q: currentQuery}) }}" style="color:inherit; text-decoration:none;">
              User {{ currentSort == 'firstName' ? (currentOrder == 'ASC' ? '↑' : '↓') : '' }}
            </a>
          </th>
          <th>
            <a href="{{ path('admin_users', {s: 'email', order: currentOrder == 'ASC' ? 'DESC' : 'ASC', q: currentQuery}) }}" style="color:inherit; text-decoration:none;">
              Email {{ currentSort == 'email' ? (currentOrder == 'ASC' ? '↑' : '↓') : '' }}
            </a>
          </th>
          <th>
            <a href="{{ path('admin_users', {s: 'role', order: currentOrder == 'ASC' ? 'DESC' : 'ASC', q: currentQuery}) }}" style="color:inherit; text-decoration:none;">
              Role {{ currentSort == 'role' ? (currentOrder == 'ASC' ? '↑' : '↓') : '' }}
            </a>
          </th>
          <th>
            <a href="{{ path('admin_users', {s: 'status', order: currentOrder == 'ASC' ? 'DESC' : 'ASC', q: currentQuery}) }}" style="color:inherit; text-decoration:none;">
              Status {{ currentSort == 'status' ? (currentOrder == 'ASC' ? '↑' : '↓') : '' }}
            </a>
          </th>
          <th>
            <a href="{{ path('admin_users', {s: 'birthYear', order: currentOrder == 'ASC' ? 'DESC' : 'ASC', q: currentQuery}) }}" style="color:inherit; text-decoration:none;">
              Birth Year {{ currentSort == 'birthYear' ? (currentOrder == 'ASC' ? '↑' : '↓') : '' }}
            </a>
            /
            <a href="{{ path('admin_users', {s: 'gender', order: currentOrder == 'ASC' ? 'DESC' : 'ASC', q: currentQuery}) }}" style="color:inherit; text-decoration:none;">
              Gender {{ currentSort == 'gender' ? (currentOrder == 'ASC' ? '↑' : '↓') : '' }}
            </a>
          </th>
          <th style="text-align:right">Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for u in users %}
        <tr>
          <td style="font-family:var(--font-mono);font-size:12px;">#{{ u.userId }}</td>
          <td>
            <div class="user-meta">
              <div class="user-avatar" style="background: {{ u.gender == 'Female' ? '#ff4d6d' : '#00a6ed' }}">
                {{ u.firstName|first|upper }}{{ u.lastName|first|upper }}
              </div>
              <div>
                <div style="font-weight:600">{{ u.firstName }} {{ u.lastName }}</div>
              </div>
            </div>
          </td>
          <td style="font-size:12px; color:var(--text-muted)">{{ u.email }}</td>
          <td><span class="badge {{ u.role == 'admin' ? 'badge-coral' : 'badge-teal' }}">{{ u.role|upper }}</span></td>
          <td>
             <span style="display:inline-block; width:8px; height:8px; border-radius:50%; background:{{ u.status == 'active' ? '#10b981' : (u.status == 'banned' ? '#ef4444' : '#f59e0b') }}; margin-right:6px;"></span>
             <span style="color:{{ u.status == 'banned' ? '#ef4444' : 'inherit' }}">{{ u.status|replace({'_': ' '})|capitalize }}</span>
          </td>
          <td style="font-size:13px;">{{ u.birthYear|default('N/A') }} / {{ u.gender|default('N/A') }}</td>
          <td style="text-align:right">
            <div style="display:flex; justify-content:flex-end; gap:8px;">
               <a href="{{ path('admin_user_detail', {id: u.userId}) }}" class="btn btn-secondary btn-sm" style="background: rgba(0,166,237,0.1); color: #00a6ed">View</a>
               <a href="{{ path('admin_user_edit', {id: u.userId}) }}" class="btn btn-secondary btn-sm">Edit</a>
               {% if u.status != 'banned' %}
                 <a href="{{ path('admin_user_ban', {id: u.userId}) }}" class="btn btn-secondary btn-sm" style="color:#ef4444" onclick="event.preventDefault(); openConfirmModal('Ban this user?', this.href)">Ban</a>
               {% else %}
                 <a href="{{ path('admin_user_unban', {id: u.userId}) }}" class="btn btn-secondary btn-sm" style="color:#10b981" onclick="event.preventDefault(); openConfirmModal('Unban this user?', this.href)">Unban</a>
               {% endif %}
               <a href="{{ path('admin_user_delete', {id: u.userId}) }}" class="btn btn-primary btn-sm" onclick="event.preventDefault(); openConfirmModal('Delete permanently?', this.href)">Delete</a>
            </div>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  {% if users.pageCount|default(0) > 1 %}
  <div class="pagination" style="display:flex; justify-content:center; gap: 8px; margin-top:24px;">
      {% if users.currentPageNumber > 1 %}
          <a href="{{ path('admin_users', {page: users.currentPageNumber - 1, q: currentQuery, s: currentSort, order: currentOrder}) }}" class="btn btn-secondary pjax-link">←</a>
      {% endif %}
      
      <div style="display:flex; align-items:center; gap:8px; padding:0 12px; color: var(--text-muted);">
          Page {{ users.currentPageNumber }} of {{ users.pageCount }}
      </div>

      {% if users.currentPageNumber < users.pageCount %}
          <a href="{{ path('admin_users', {page: users.currentPageNumber + 1, q: currentQuery, s: currentSort, order: currentOrder}) }}" class="btn btn-secondary pjax-link">→</a>
      {% endif %}
  </div>
  {% endif %}
  </div> <!-- end filter pjax container -->
{% endblock %}

{% block javascripts %}
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    function searchUsers() {
      const q = document.getElementById('liveSearch').value;
      fetch(`{{ path('admin_users_search') }}?q=${encodeURIComponent(q)}`)
        .then(res => res.json())
        .then(data => {
          const tbody = document.querySelector('.user-table tbody');
          if (data.length === 0) {
             tbody.innerHTML = '<tr><td colspan="7" style="text-align:center; padding: 20px;">No results found</td></tr>';
             return;
          }
          tbody.innerHTML = '';
          data.forEach(u => {
             const avatarBg = u.gender === 'Female' ? '#ff4d6d' : '#00a6ed';
             const initials = ((u.firstName || '').charAt(0) + (u.lastName || '').charAt(0)).toUpperCase();
             const badgeClass = u.role === 'admin' ? 'badge-coral' : 'badge-teal';
             const statusColor = u.status === 'active' ? '#10b981' : (u.status === 'banned' ? '#ef4444' : '#f59e0b');
             const statusBg = u.status === 'banned' ? '#ef4444' : 'inherit';
             const statusText = u.status.replace('_', ' ');
             const statusCapitalized = statusText.charAt(0).toUpperCase() + statusText.slice(1);
             const tr = document.createElement('tr');
             
             tr.innerHTML = `
               <td style="font-family:var(--font-mono);font-size:12px;">#${u.userId}</td>
               <td>
                 <div class="user-meta">
                   <div class="user-avatar" style="background: ${avatarBg}">${initials}</div>
                   <div><div style="font-weight:600">${u.firstName} ${u.lastName}</div></div>
                 </div>
               </td>
               <td style="font-size:12px; color:var(--text-muted)">${u.email}</td>
               <td><span class="badge ${badgeClass}">${u.role.toUpperCase()}</span></td>
               <td>
                 <span style="display:inline-block; width:8px; height:8px; border-radius:50%; background:${statusColor}; margin-right:6px;"></span>
                 <span style="color:${statusBg}">${statusCapitalized}</span>
               </td>
               <td style="font-size:13px;">${u.birthYear || 'N/A'} / ${u.gender || 'N/A'}</td>
               <td style="text-align:right">
                 <div style="display:flex; justify-content:flex-end; gap:8px;">
                   <a href="/admin/users/detail/${u.userId}" class="btn btn-secondary btn-sm" style="background: rgba(0,166,237,0.1); color: #00a6ed">View</a>
                   <a href="/admin/users/edit/${u.userId}" class="btn btn-secondary btn-sm">Edit</a>
                   ${u.status !== 'banned' ? `<a href="/admin/users/ban/${u.userId}" class="btn btn-secondary btn-sm" style="color:#ef4444" onclick="event.preventDefault(); openConfirmModal('Ban this user?', this.href)">Ban</a>` : `<a href="/admin/users/unban/${u.userId}" class="btn btn-secondary btn-sm" style="color:#10b981" onclick="event.preventDefault(); openConfirmModal('Unban this user?', this.href)">Unban</a>`}
                   <a href="/admin/users/delete/${u.userId}" class="btn btn-primary btn-sm" onclick="event.preventDefault(); openConfirmModal('Delete permanently?', this.href)">Delete</a>
                 </div>
               </td>
             `;
             tbody.appendChild(tr);
          });
        });
    }

    document.addEventListener('DOMContentLoaded', function() {
      // Gender Distribution Chart
      const ctxGender = document.getElementById('userGenderChart').getContext('2d');
      new Chart(ctxGender, {
        type: 'doughnut',
        data: {
          labels: ['Male', 'Female'],
          datasets: [{
            data: [{{ stats.males }}, {{ stats.females }}],
            backgroundColor: ['#00a6ed', '#ff4d6d'],
            borderWidth: 0,
            cutout: '70%'
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { position: 'bottom', labels: { color: '#8898aa', boxWidth: 12 } } }
        }
      });

      // Dynamic Real Growth Chart
      const ctxGrowth = document.getElementById('userGrowthChart').getContext('2d');
      new Chart(ctxGrowth, {
        type: 'line',
        data: {
          labels: {{ stats.growthLabels|json_encode|raw }},
          datasets: [{
            label: 'New Users',
            data: {{ stats.growthData|json_encode|raw }},
            borderColor: '#00a6ed',
            tension: 0.4,
            fill: true,
            backgroundColor: 'rgba(0,166,237,0.1)'
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { grid: { display: false } },
            y: { grid: { color: 'rgba(255,255,255,0.05)' }, beginAtZero: true }
          }
        }
      });
      
      // AJAX PJAX Logic for Pagination & Sorting without Page Reload
      document.body.addEventListener('click', function(e) {
          const tableLink = e.target.closest('#users-pjax-container th a');
          const pageLink = e.target.closest('#users-pjax-container .pagination a');
          
          if (tableLink || pageLink) {
              e.preventDefault();
              let href = (tableLink || pageLink).getAttribute('href');
              
              const container = document.getElementById('users-pjax-container');
              container.style.opacity = '0.5';
              container.style.pointerEvents = 'none';
              
              fetch(href)
                  .then(response => response.text())
                  .then(html => {
                      const parser = new DOMParser();
                      const doc = parser.parseFromString(html, 'text/html');
                      const newContent = doc.getElementById('users-pjax-container').innerHTML;
                      
                      container.innerHTML = newContent;
                      container.style.opacity = '1';
                      container.style.pointerEvents = 'auto';
                      
                      window.history.pushState({ path: href }, '', href);
                  })
                  .catch(err => {
                      // Fallback to reload
                      window.location.href = href;
                  });
          }
      });
    });
  </script>
{% endblock %}
