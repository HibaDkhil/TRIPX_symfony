async function exportCSV(type = 'standard') {
  showToast('Generating ' + type + ' report...', 'info');

  const q      = document.getElementById('search-box').value;
  const status = document.getElementById('filter-status').value;
  const acc    = document.getElementById('filter-acc').value;
  const from   = document.getElementById('filter-from').value;
  const to     = document.getElementById('filter-to').value;

  const url = `${SEARCH_URL}?q=${encodeURIComponent(q)}&status=${encodeURIComponent(status)}&accommodation=${encodeURIComponent(acc)}&dateFrom=${encodeURIComponent(from)}&dateTo=${encodeURIComponent(to)}`;

  try {
    const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    const data = await res.json();
    const bookings = data.bookings;

    let csvContent = '';

    if (type === 'standard') {
      csvContent = generateStandardCSV(bookings);
    } else if (type === 'advanced') {
      csvContent = generateAdvancedCSV(bookings);
    } else if (type === 'accommodation') {
      csvContent = generateAccommodationCSV(bookings);
    } else if (type === 'monthly') {
      csvContent = generateMonthlyCSV(bookings);
    }

    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement('a');
    const url_file = URL.createObjectURL(blob);
    link.href = url_file;
    link.setAttribute('download', `bookings_${type}_${new Date().toISOString().slice(0,19).replace(/:/g, '-')}.csv`);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    URL.revokeObjectURL(url_file);

    showToast(`${type.charAt(0).toUpperCase() + type.slice(1)} report exported!`, 'success');
  } catch(e) {
    showToast('Export failed: ' + e.message, 'error');
  }
}

function generateStandardCSV(bookings) {
  const headers = ['ID', 'Created', 'Accommodation', 'Room', 'Check-in', 'Check-out', 'Nights', 'Guests', 'Total', 'Status', 'Phone', 'Special Requests'];
  const rows = [headers];

  bookings.forEach(b => {
    const nights = b.checkIn && b.checkOut ? Math.round((new Date(b.checkOut) - new Date(b.checkIn)) / 86400000) : 0;
    rows.push([
      b.id,
      b.createdAt || '',
      `"${(b.accName || '').replace(/"/g, '""')}"`,
      `"${(b.roomName || '').replace(/"/g, '""')}"`,
      b.checkIn || '',
      b.checkOut || '',
      nights,
      b.numberOfGuests || 1,
      b.totalPrice || 0,
      b.status || '',
      b.phoneNumber || '',
      `"${(b.specialRequests || '').replace(/"/g, '""')}"`
    ]);
  });

  return rows.map(row => row.join(',')).join('\n');
}

function generateAdvancedCSV(bookings) {
  const lines = [];

  lines.push('================================================================================');
  lines.push('TRIPX ADVANCED BOOKINGS REPORT');
  lines.push('================================================================================');
  lines.push(`Generated:,${new Date().toLocaleString()}`);
  lines.push(`Total Bookings:,${bookings.length}`);

  const totalRevenue = bookings.reduce((sum, b) => sum + (b.status === 'CONFIRMED' ? parseFloat(b.totalPrice || 0) : 0), 0);
  lines.push(`Total Revenue:,€${totalRevenue.toFixed(2)}`);
  lines.push(`Average Booking:,€${(totalRevenue / Math.max(1, bookings.length)).toFixed(2)}`);
  lines.push('================================================================================');
  lines.push('');

  lines.push('📊 KPI DASHBOARD');
  lines.push('================================================================================');
  lines.push('KPI,Value,Target,Status');

  const confirmedCount = bookings.filter(b => b.status === 'CONFIRMED').length;
  const pendingCount   = bookings.filter(b => b.status === 'PENDING').length;
  const cancelledCount = bookings.filter(b => b.status === 'CANCELLED').length;
  const rejectedCount  = bookings.filter(b => b.status === 'REJECTED').length;

  lines.push(`Total Revenue,€${totalRevenue.toFixed(2)},€${(totalRevenue * 1.1).toFixed(2)},${totalRevenue > 50000 ? '✅ Exceeded' : '🟡 On Track'}`);
  lines.push(`Avg Booking Value,€${(totalRevenue / Math.max(1, bookings.length)).toFixed(2)},€180.00,${(totalRevenue / Math.max(1, bookings.length)) > 180 ? '✅ Good' : '⚠️ Below'}`);
  lines.push(`Confirmed Rate,${((confirmedCount / Math.max(1, bookings.length)) * 100).toFixed(1)}%,70%,${((confirmedCount / Math.max(1, bookings.length)) * 100) > 70 ? '✅ Excellent' : '⚠️ Low'}`);
  lines.push(`Cancellation Rate,${((cancelledCount / Math.max(1, bookings.length)) * 100).toFixed(1)}%,<8%,${((cancelledCount / Math.max(1, bookings.length)) * 100) < 8 ? '✅ Good' : '⚠️ High'}`);
  lines.push('================================================================================');
  lines.push('');

  lines.push('📈 STATUS BREAKDOWN');
  lines.push('================================================================================');
  lines.push('Status,Count,Percentage,Visual');

  const statuses = [
    { name: 'CONFIRMED', count: confirmedCount, color: '🟢' },
    { name: 'PENDING',   count: pendingCount,   color: '🟡' },
    { name: 'CANCELLED', count: cancelledCount, color: '🔴' },
    { name: 'REJECTED',  count: rejectedCount,  color: '⚫' }
  ];

  statuses.forEach(s => {
    const pct = (s.count / Math.max(1, bookings.length)) * 100;
    const bar = '█'.repeat(Math.floor(pct / 2)) + '░'.repeat(50 - Math.floor(pct / 2));
    lines.push(`${s.name},${s.count},${pct.toFixed(1)}%,${s.color} ${bar}`);
  });
  lines.push('================================================================================');
  lines.push('');

  lines.push('🏨 ACCOMMODATION PERFORMANCE RANKING');
  lines.push('================================================================================');
  lines.push('Rank,Accommodation,Bookings,Revenue,Avg Price');

  const accMap = new Map();
  bookings.forEach(b => {
    const name = b.accName || 'Unknown';
    if (!accMap.has(name)) accMap.set(name, { bookings: 0, revenue: 0 });
    const stats = accMap.get(name);
    stats.bookings++;
    if (b.status === 'CONFIRMED') stats.revenue += parseFloat(b.totalPrice || 0);
  });

  const sortedAcc = Array.from(accMap.entries()).sort((a, b) => b[1].revenue - a[1].revenue);
  let rank = 1;
  for (const [name, stats] of sortedAcc) {
    const avgPrice = stats.bookings > 0 ? stats.revenue / stats.bookings : 0;
    lines.push(`${rank},"${name.replace(/"/g, '""')}",${stats.bookings},€${stats.revenue.toFixed(2)},€${avgPrice.toFixed(2)}`);
    rank++;
  }
  lines.push('================================================================================');
  lines.push('');

  lines.push('🛏️ ROOM TYPE PERFORMANCE');
  lines.push('================================================================================');
  lines.push('Room Type,Bookings,Revenue,Avg Price');

  const roomMap = new Map();
  bookings.forEach(b => {
    const type = b.roomType || 'Standard';
    if (!roomMap.has(type)) roomMap.set(type, { bookings: 0, revenue: 0 });
    const stats = roomMap.get(type);
    stats.bookings++;
    if (b.status === 'CONFIRMED') stats.revenue += parseFloat(b.totalPrice || 0);
  });

  for (const [type, stats] of roomMap.entries()) {
    const avgPrice = stats.bookings > 0 ? stats.revenue / stats.bookings : 0;
    lines.push(`"${type.replace(/"/g, '""')}",${stats.bookings},€${stats.revenue.toFixed(2)},€${avgPrice.toFixed(2)}`);
  }
  lines.push('================================================================================');
  lines.push('');

  lines.push('📅 MONTHLY REVENUE TRENDS');
  lines.push('================================================================================');
  lines.push('Month,Bookings,Revenue,Avg Price');

  const monthlyMap = new Map();
  bookings.forEach(b => {
    if (b.createdAt) {
      const month = b.createdAt.substring(0, 7);
      if (!monthlyMap.has(month)) monthlyMap.set(month, { bookings: 0, revenue: 0 });
      const stats = monthlyMap.get(month);
      stats.bookings++;
      if (b.status === 'CONFIRMED') stats.revenue += parseFloat(b.totalPrice || 0);
    }
  });

  const sortedMonths = Array.from(monthlyMap.keys()).sort();
  for (const month of sortedMonths) {
    const stats = monthlyMap.get(month);
    const avgPrice = stats.bookings > 0 ? stats.revenue / stats.bookings : 0;
    lines.push(`${month},${stats.bookings},€${stats.revenue.toFixed(2)},€${avgPrice.toFixed(2)}`);
  }
  lines.push('================================================================================');
  lines.push('');

  lines.push('🤖 AI-POWERED INSIGHTS');
  lines.push('================================================================================');

  const weekdays = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
  const dayCount = [0,0,0,0,0,0,0];
  let totalNights = 0;
  let totalGuests = 0;

  bookings.forEach(b => {
    if (b.checkIn) {
      const day = new Date(b.checkIn).getDay();
      dayCount[day]++;
    }
    if (b.checkIn && b.checkOut) {
      const nights = Math.round((new Date(b.checkOut) - new Date(b.checkIn)) / 86400000);
      totalNights += nights;
    }
    totalGuests += b.numberOfGuests || 1;
  });

  const bestDayIndex = dayCount.indexOf(Math.max(...dayCount));
  const bestDay  = weekdays[bestDayIndex];
  const avgStay  = bookings.length > 0 ? (totalNights / bookings.length).toFixed(1) : 0;
  const avgGuests = bookings.length > 0 ? (totalGuests / bookings.length).toFixed(1) : 0;

  lines.push(`Best Performing Day,${bestDay},Consider weekend pricing strategy`);
  lines.push(`Average Stay Duration,${avgStay} nights,Promote extended stay discounts`);
  lines.push(`Average Guests per Booking,${avgGuests},Family packages could boost revenue`);
  lines.push(`Total Confirmed Bookings,${confirmedCount},${confirmedCount > 100 ? 'Strong performance' : 'Need more marketing'}`);
  lines.push('================================================================================');
  lines.push('');

  lines.push('📋 DETAILED BOOKINGS DATA');
  lines.push('================================================================================');
  lines.push('ID,Created,Accommodation,Room,Check-in,Check-out,Nights,Guests,Total,Status,Phone');

  bookings.forEach(b => {
    const nights = b.checkIn && b.checkOut ? Math.round((new Date(b.checkOut) - new Date(b.checkIn)) / 86400000) : 0;
    lines.push(`${b.id},${b.createdAt || ''},"${(b.accName || '').replace(/"/g, '""')}","${(b.roomName || '').replace(/"/g, '""')}",${b.checkIn || ''},${b.checkOut || ''},${nights},${b.numberOfGuests || 1},${b.totalPrice || 0},${b.status || ''},${b.phoneNumber || ''}`);
  });

  lines.push('================================================================================');
  lines.push('');
  lines.push(`Report generated on ${new Date().toLocaleString()} by TripX Admin System`);

  return lines.join('\n');
}

function generateAccommodationCSV(bookings) {
  const lines = [];

  lines.push('🏨 ACCOMMODATION PERFORMANCE REPORT');
  lines.push('================================================================================');
  lines.push(`Generated:,${new Date().toLocaleString()}`);
  lines.push('================================================================================');
  lines.push('');
  lines.push('Accommodation,Total Bookings,Confirmed Bookings,Total Revenue,Avg Price,Top Room Type');

  const accMap = new Map();
  bookings.forEach(b => {
    const name = b.accName || 'Unknown';
    if (!accMap.has(name)) accMap.set(name, { total: 0, confirmed: 0, revenue: 0, rooms: new Map() });
    const stats = accMap.get(name);
    stats.total++;
    if (b.status === 'CONFIRMED') {
      stats.confirmed++;
      stats.revenue += parseFloat(b.totalPrice || 0);
    }
    const roomType = b.roomType || 'Standard';
    stats.rooms.set(roomType, (stats.rooms.get(roomType) || 0) + 1);
  });

  for (const [name, stats] of accMap.entries()) {
    const avgPrice = stats.confirmed > 0 ? stats.revenue / stats.confirmed : 0;
    let topRoom = '';
    let maxCount = 0;
    for (const [room, count] of stats.rooms) {
      if (count > maxCount) { maxCount = count; topRoom = room; }
    }
    lines.push(`"${name.replace(/"/g, '""')}",${stats.total},${stats.confirmed},€${stats.revenue.toFixed(2)},€${avgPrice.toFixed(2)},"${topRoom}"`);
  }

  return lines.join('\n');
}

function generateMonthlyCSV(bookings) {
  const lines = [];

  lines.push('📅 MONTHLY BOOKINGS SUMMARY');
  lines.push('================================================================================');
  lines.push(`Generated:,${new Date().toLocaleString()}`);
  lines.push('================================================================================');
  lines.push('');
  lines.push('Year-Month,Total Bookings,Confirmed,Revenue,Avg Price');

  const monthlyMap = new Map();
  bookings.forEach(b => {
    if (b.createdAt) {
      const month = b.createdAt.substring(0, 7);
      if (!monthlyMap.has(month)) monthlyMap.set(month, { total: 0, confirmed: 0, revenue: 0 });
      const stats = monthlyMap.get(month);
      stats.total++;
      if (b.status === 'CONFIRMED') {
        stats.confirmed++;
        stats.revenue += parseFloat(b.totalPrice || 0);
      }
    }
  });

  const sortedMonths = Array.from(monthlyMap.keys()).sort();
  for (const month of sortedMonths) {
    const stats = monthlyMap.get(month);
    const avgPrice = stats.confirmed > 0 ? stats.revenue / stats.confirmed : 0;
    lines.push(`${month},${stats.total},${stats.confirmed},€${stats.revenue.toFixed(2)},€${avgPrice.toFixed(2)}`);
  }

  return lines.join('\n');
}

function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function capitalize(s) { return s ? s.charAt(0).toUpperCase() + s.slice(1).toLowerCase() : ''; }
function fmtDate(d) { return new Date(d).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }); }
function escHtml(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function showToast(msg, type = 'success') {
  const t = document.getElementById('toast');
  t.textContent = (type==='success'?'✅ ':type==='error'?'❌ ':'ℹ️ ') + msg;
  t.className = `toast ${type} show`;
  setTimeout(() => t.classList.remove('show'), 3500);
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') { closeBModal(); closeReasonModal(); }
});

// ── ML Insights ───────────────────────────────────────────
async function loadMlInsights() {
  setMlStatus('loading');
  try {
    const res  = await fetch(ML_URL, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    const json = await res.json();
    if (!json.success) { setMlStatus('error', json.error); return; }
    renderMlInsights(json.data);
  } catch (e) { setMlStatus('error', e.message); }
}

function renderMlInsights(d) {
  const reg = d.regression;
  const el  = d.elasticity;
  const trained = reg.modelTrained;
  document.getElementById('ml-status-badge').innerHTML = trained
    ? '<span style="width:7px;height:7px;border-radius:50%;background:#10b981;display:inline-block;"></span> Model active'
    : '⚠ Insufficient data';
  document.getElementById('ml-status-badge').style.cssText +=
    trained ? ';background:rgba(16,185,129,.12);color:#10b981;border-color:rgba(16,185,129,.3);'
            : ';background:rgba(245,158,11,.12);color:#f59e0b;border-color:rgba(245,158,11,.3);';

  const occ = d.forecastOccupancyPct;
  document.getElementById('ml-occ-val').textContent = occ.toFixed(1) + '%';
  document.getElementById('ml-occ-bar').style.width = occ + '%';

  const adj = d.suggestedPriceAdjustmentPct;
  document.getElementById('ml-adj-val').textContent = (adj >= 0 ? '+' : '') + adj.toFixed(1) + '%';
  document.getElementById('ml-adj-val').style.color = adj > 1 ? '#10b981' : adj < -1 ? '#ef4444' : '#6b7280';
  const adjDir = adj > 1 ? 'Increase prices' : adj < -1 ? 'Decrease prices' : 'Hold prices';
  const adjCol = adj > 1 ? 'rgba(16,185,129,.12);color:#10b981;border-color:rgba(16,185,129,.3)'
               : adj < -1 ? 'rgba(239,68,68,.12);color:#ef4444;border-color:rgba(239,68,68,.3)'
               : 'rgba(107,114,128,.12);color:#6b7280;border-color:rgba(107,114,128,.3)';
  document.getElementById('ml-adj-tag').innerHTML = `<span style="display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;border:1px solid;background:${adjCol}">${adjDir}</span>`;
  if (reg.modelTrained) document.getElementById('ml-adj-sub').textContent = `Current avg €${reg.currentAvgNightly} → predicted €${reg.predictedAvgNightly}`;

  const conf = d.modelConfidencePct;
  document.getElementById('ml-conf-val').textContent = conf.toFixed(1) + '%';
  document.getElementById('ml-conf-bar').style.width = conf + '%';
  document.getElementById('ml-conf-bar').style.background = conf >= 70 ? '#10b981' : conf >= 45 ? '#f59e0b' : '#ef4444';
  document.getElementById('ml-conf-val').style.color      = conf >= 70 ? '#10b981' : conf >= 45 ? '#f59e0b' : '#ef4444';
  document.getElementById('ml-conf-sub').textContent = reg.modelTrained ? `${reg.sampleSize} confirmed booking samples` : 'Need more confirmed bookings';

  document.getElementById('ml-reg-badge').textContent = reg.modelTrained ? `R² ${reg.r2}` : 'Not trained';
  if (reg.modelTrained) document.getElementById('ml-reg-badge').style.cssText += ';background:rgba(16,185,129,.12);color:#10b981;';
  document.getElementById('ml-reg-body').innerHTML = reg.modelTrained ? `
    ${mlMetric('R² Score', `<span style="color:#10b981;font-weight:700;">${reg.r2}</span>`)}
    ${mlMetric('RMSE', `€${reg.rmse} / night`)}
    ${mlMetric('Training samples', reg.sampleSize + ' bookings')}
    ${mlMetric('Ridge λ', '0.12')}
    ${mlMetric('Current avg nightly', `€${reg.currentAvgNightly}`)}
    ${mlMetric('Predicted avg nightly', `<span style="color:#7F77DD;font-weight:700;">€${reg.predictedAvgNightly}</span>`)}
    <div class="ml-narrative">${escHtml(reg.narrative)}</div>`
  : `<div style="padding:16px;font-size:13px;color:var(--text-muted);">${escHtml(reg.narrative)}</div>`;

  document.getElementById('ml-el-badge').textContent = el.modelTrained ? `β = ${el.beta}` : 'Not trained';
  if (el.modelTrained) {
    const barColor = (pct) => pct >= 70 ? '#10b981' : pct >= 40 ? '#f59e0b' : '#ef4444';
    const barsHtml = el.buckets.map(b => `
      <div class="el-row">
        <span class="el-label">${escHtml(b.label)}</span>
        <div class="el-bar-wrap"><div class="el-bar" style="width:${b.occupancyPct}%;background:${barColor(b.occupancyPct)};"></div></div>
        <span class="el-pct" style="color:${barColor(b.occupancyPct)};">${b.occupancyPct}%</span>
      </div>`).join('');
    document.getElementById('ml-el-body').innerHTML = `
      ${mlMetric('Elasticity coefficient β', `<span style="color:#f59e0b;font-weight:700;">${el.beta}</span>`)}
      ${mlMetric('Interpretation', el.interpretation)}
      ${mlMetric('+5% price → occupancy', `<span style="color:${el.deltaOccAt5pct < 0 ? '#ef4444' : '#10b981'};font-weight:700;">${el.deltaOccAt5pct >= 0 ? '+' : ''}${el.deltaOccAt5pct}%</span>`)}
      ${mlMetric('+10% price → occupancy', `<span style="color:${el.deltaOccAt10pct < 0 ? '#ef4444' : '#10b981'};font-weight:700;">${el.deltaOccAt10pct >= 0 ? '+' : ''}${el.deltaOccAt10pct}%</span>`)}
      ${mlMetric('−5% price → occupancy', `<span style="color:#10b981;font-weight:700;">${el.deltaOccAtMinus5 >= 0 ? '+' : ''}${el.deltaOccAtMinus5}%</span>`)}
      <div style="margin-top:10px;font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px;">Price → relative demand curve</div>
      ${barsHtml}
      <div class="ml-narrative">${escHtml(el.narrative)}</div>`;
  } else {
    document.getElementById('ml-el-body').innerHTML = `<div style="padding:16px;font-size:13px;color:var(--text-muted);">${escHtml(el.narrative)}</div>`;
  }
  setMlStatus('done');
}

function mlMetric(label, valHtml) {
  return `<div class="ml-metric"><span class="ml-metric-lbl">${label}</span><span class="ml-metric-val">${valHtml}</span></div>`;
}

function setMlStatus(state, msg) {
  const btn = document.getElementById('ml-refresh-btn');
  if (state === 'loading') { btn.textContent = '⏳ Loading…'; btn.disabled = true; }
  else if (state === 'error') {
    btn.textContent = '↻ Refresh'; btn.disabled = false;
    document.getElementById('ml-status-badge').textContent = '❌ Error';
    document.getElementById('ml-status-badge').style.cssText += ';background:rgba(239,68,68,.12);color:#ef4444;border-color:rgba(239,68,68,.3);';
    showToast('ML Insights error: ' + (msg || 'unknown'), 'error');
  } else { btn.textContent = '↻ Refresh'; btn.disabled = false; }
}
async function exportReport(type) {
    const q      = document.getElementById('search-box').value;
    const status = document.getElementById('filter-status').value;
    const acc    = document.getElementById('filter-acc').value;
    const from   = document.getElementById('filter-from').value;
    const to     = document.getElementById('filter-to').value;
    
    let url = '';
    if (type === 'dashboard') {
        url = `/admin/accommodations/bookings/export/dashboard?q=${encodeURIComponent(q)}&status=${encodeURIComponent(status)}&accommodation=${encodeURIComponent(acc)}&dateFrom=${encodeURIComponent(from)}&dateTo=${encodeURIComponent(to)}`;
        window.open(url, '_blank');
    } else if (type === 'excel') {
        url = `/admin/accommodations/bookings/export/excel?q=${encodeURIComponent(q)}&status=${encodeURIComponent(status)}&accommodation=${encodeURIComponent(acc)}&dateFrom=${encodeURIComponent(from)}&dateTo=${encodeURIComponent(to)}`;
        window.location.href = url;
    }
    
    document.getElementById('export-menu').style.display = 'none';
    exportMenuOpen = false;
}

// ── Boot ──────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  loadGCalBanner();
  loadMlInsights();
});
</script>
