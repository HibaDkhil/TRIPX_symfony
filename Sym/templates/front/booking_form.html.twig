<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Book your trip to {{ destination.name }} — TripX">
  <title>Book {{ destination.name }} — TripX</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400..900&family=Montserrat:wght@100..900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets.php?f=css/main.css">
  <link rel="stylesheet" href="/assets.php?f=css/animations.css">
  <style>
    .page-top { padding-top: calc(var(--nav-height) + 60px); padding-bottom: 40px; }
    .booking-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: var(--border-radius-lg);
      padding: 40px;
      max-width: 700px;
      margin: 0 auto;
      box-shadow: var(--shadow-md);
    }
    .booking-dest-header {
      display: flex; align-items: center; gap: 20px;
      margin-bottom: 32px; padding-bottom: 24px;
      border-bottom: 1px solid var(--border-color);
    }
    .booking-dest-thumb {
      width: 80px; height: 80px; border-radius: var(--border-radius-md);
      background: linear-gradient(135deg, #1a3a5c, #2d6a4f);
      display: flex; align-items: center; justify-content: center;
      font-size: 36px; flex-shrink: 0; overflow: hidden;
    }
    .booking-dest-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .form-group { margin-bottom: 20px; }
    .form-label { display: block; margin-bottom: 8px; font-weight: 600; font-size: 14px; }
    .form-input {
      width: 100%; padding: 12px 16px; border-radius: 10px;
      border: 1px solid var(--border-color);
      background: var(--bg-surface); color: var(--text-primary);
      font-size: 14px; transition: border-color 0.2s;
    }
    .form-input:focus { outline: none; border-color: var(--accent-primary); }
    .form-input.error { border-color: #ef4444; }
    .error-text { color: #ef4444; font-size: 12px; margin-top: 4px; display: none; }
    .price-preview {
      background: rgba(0,166,237,0.06);
      border: 1px solid rgba(0,166,237,0.2);
      border-radius: var(--border-radius-md);
      padding: 20px; text-align: center; margin-top: 24px;
    }
    @media (max-width: 600px) {
      .form-row { grid-template-columns: 1fr; }
      .booking-card { padding: 24px; }
    }
  </style>
</head>
<body>
    <div id="cursor-dot"></div><div id="cursor-halo"></div>

<nav class="nav">
  <div class="nav-inner">
    <a href="{{ path('index') }}" class="nav-logo">Trip<span>X</span></a>
    <div class="nav-links">
      <a href="{{ path('index') }}"          class="nav-link">Home</a>
      <a href="{{ path('destinations') }}"   class="nav-link">Destinations</a>
      <a href="{{ path('activities') }}"     class="nav-link">Activities</a>
      <a href="{{ path('accommodations') }}" class="nav-link">Accommodations</a>
      <a href="{{ path('transport') }}"      class="nav-link">Transport</a>
      <a href="{{ path('offers') }}"         class="nav-link">Offers</a>
      <a href="{{ path('blog') }}" class="nav-link">Blog</a><a href="{{ path('my_bookings') }}" class="nav-link">My Bookings</a>
    </div>
    <div class="nav-actions">
      <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
        <span class="toggle-icon icon-sun">☀️</span>
        <span class="toggle-icon icon-moon">🌙</span>
      </button>
      <a href="{{ path('users') }}" class="btn-nav-primary ripple-btn">My Profile</a><a href="{{ path('app_logout') }}" class="Btn-logout" style="margin-left: 8px;">
        <div class="sign"><svg viewBox="0 0 512 512"><path d="M377.9 105.9L500.7 228.7c7.2 7.2 11.3 17.1 11.3 27.3s-4.1 20.1-11.3 27.3L377.9 406.1c-6.4 6.4-15 9.9-24 9.9c-18.7 0-33.9-15.2-33.9-33.9l0-62.1-128 0c-17.7 0-32-14.3-32-32l0-64c0-17.7 14.3-32 32-32l128 0 0-62.1c0-18.7 15.2-33.9 33.9-33.9c9 0 17.6 3.6 24 9.9zM160 96L96 96c-17.7 0-32 14.3-32 32l0 256c0 17.7 14.3 32 32 32l64 0c17.7 0 32 14.3 32 32s-14.3 32-32 32l-64 0c-53 0-96-43-96-96L0 128C0 75 43 32 96 32l64 0c17.7 0 32 14.3 32 32s-14.3 32-32 32z" /></svg></div>
        <div class="text">Logout</div>
      </a>
    </div>
  </div>
</nav>

<div class="page-top">
  <div class="container">
    <div class="section-label reveal"><span>New Booking</span></div>
    <h1 class="display-md reveal" style="margin-bottom:8px">Book <span class="gradient-text">{{ destination.name }}</span></h1>
    <p class="serif-mood text-muted reveal reveal-delay-1">Fill in your travel details to confirm your reservation.</p>
  </div>
</div>

<section class="section-sm">
  <div class="container">

    {% for label, messages in app.flashes %}
      <div style="max-width:700px; margin:0 auto 20px;">
        {% for message in messages %}
          <div style="padding:12px 20px; border-radius:10px; margin-bottom:8px; font-size:14px;
            {% if label == 'error' %}background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.3); color:#ef4444;
            {% else %}background:rgba(16,185,129,0.1); border:1px solid rgba(16,185,129,0.3); color:#10b981;{% endif %}">
            {% if label == 'success' %}✅{% else %}❌{% endif %} {{ message }}
          </div>
        {% endfor %}
      </div>
    {% endfor %}

    <div class="booking-card reveal">
      <div class="booking-dest-header">
        <div class="booking-dest-thumb">
          {% if destination.imageUrl %}
            <img src="{{ destination.imageUrl }}" alt="{{ destination.name }}">
          {% else %}
            🌍
          {% endif %}
        </div>
        <div>
          <div style="font-family:var(--font-mono); font-size:10px; color:var(--text-muted); letter-spacing:0.12em; text-transform:uppercase; margin-bottom:4px;">{{ destination.country }}</div>
          <div style="font-family:var(--font-display); font-size:24px; text-transform:uppercase;">{{ destination.name }}</div>
          <div style="display:flex; gap:8px; margin-top:8px;">
            <span class="badge badge-teal">{{ destination.type|capitalize }}</span>
            <span class="badge badge-muted">From €{{ (destination.estimatedBudget ?? 100)|number_format(0) }}</span>
          </div>
        </div>
      </div>

      {{ form_start(form, {'attr': {'id': 'bookingForm', 'novalidate': 'novalidate'}}) }}
        <div class="form-row">
          <div class="form-group">
            {{ form_label(form.startAt, 'Start Date *', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.startAt, {'attr': {'class': 'form-input', 'id': 'startAt'}}) }}
            <div style="color: #ef4444; font-size: 13px; margin-top: 4px;">{{ form_errors(form.startAt) }}</div>
            <div class="error-text" id="startError">Start date is required and cannot be in the past.</div>
          </div>
          <div class="form-group">
            {{ form_label(form.endAt, 'End Date *', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.endAt, {'attr': {'class': 'form-input', 'id': 'endAt'}}) }}
            <div style="color: #ef4444; font-size: 13px; margin-top: 4px;">{{ form_errors(form.endAt) }}</div>
            <div class="error-text" id="endError">End date must be after the start date.</div>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            {{ form_label(form.numGuests, 'Number of Guests *', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.numGuests, {'attr': {'class': 'form-input', 'id': 'numGuests'}}) }}
            <div style="color: #ef4444; font-size: 13px; margin-top: 4px;">{{ form_errors(form.numGuests) }}</div>
            <div class="error-text" id="guestsError">Must be between 1 and 20.</div>
          </div>
          <div class="form-group">
            <label class="form-label" for="userBudget">Budget per person (€)</label>
            <input type="number" name="userBudget" id="userBudget" class="form-input" value="{{ (destination.estimatedBudget ?? 100)|round }}" min="1" step="1">
            <div class="error-text" id="budgetError">Budget must be greater than 0.</div>
          </div>
        </div>

        <div class="form-group">
          {{ form_label(form.notes, 'Special Requests / Notes', {'label_attr': {'class': 'form-label'}}) }}
          {{ form_widget(form.notes, {'attr': {'rows': '3', 'class': 'form-input', 'style': 'resize:vertical;', 'placeholder': 'Any special requirements, dietary needs, etc.'}}) }}
          <div style="color: #ef4444; font-size: 13px; margin-top: 4px;">{{ form_errors(form.notes) }}</div>
        </div>



        <div style="display:flex; gap:12px; margin-top:32px;">
          <button type="submit" class="btn btn-primary ripple-btn" style="flex:1; font-size:16px; padding:14px;">✈️ Confirm Booking</button>
          <a href="{{ path('destinations') }}" class="btn btn-secondary" style="flex:1; text-align:center; padding:14px;">Cancel</a>
        </div>
      {{ form_end(form) }}
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container">
    <div class="footer-bottom">
      <div class="footer-copy">© 2026 TripX. All rights reserved.</div>
      <a href="{{ path('destinations') }}" class="footer-copy" style="color:var(--accent-primary)">← Back to Destinations</a>
    </div>
  </div>
</footer>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const budgetInput = document.getElementById('userBudget');
  const startAt = document.getElementById('startAt');
  const endAt = document.getElementById('endAt');
  const numGuests = document.getElementById('numGuests');
  const form = document.getElementById('bookingForm');
  startAt.addEventListener('change', function() {
    endAt.min = this.value;
    if (endAt.value && endAt.value <= this.value) endAt.value = '';
  });

  // Client-side validation
  form.addEventListener('submit', function(e) {
    let valid = true;

    // Reset
    document.querySelectorAll('.form-input').forEach(i => i.classList.remove('error'));
    document.querySelectorAll('.error-text').forEach(t => t.style.display = 'none');

    if (!startAt.value) {
      startAt.classList.add('error');
      document.getElementById('startError').style.display = 'block';
      document.getElementById('startError').textContent = 'Start date is required.';
      valid = false;
    } else {
      const selected = new Date(startAt.value);
      const today = new Date();
      today.setHours(0,0,0,0);
      if (selected < today) {
        startAt.classList.add('error');
        document.getElementById('startError').style.display = 'block';
        document.getElementById('startError').textContent = 'Start date cannot be in the past.';
        valid = false;
      }
    }
    if (!endAt.value) {
      endAt.classList.add('error');
      document.getElementById('endError').style.display = 'block';
      document.getElementById('endError').textContent = 'End date is required.';
      valid = false;
    } else if (startAt.value && endAt.value <= startAt.value) {
      endAt.classList.add('error');
      document.getElementById('endError').style.display = 'block';
      document.getElementById('endError').textContent = 'End date must be after the start date.';
      valid = false;
    }
    const g = parseInt(numGuests.value);
    if (!g || g < 1 || g > 20) {
      numGuests.classList.add('error');
      document.getElementById('guestsError').style.display = 'block';
      valid = false;
    }
    const b = parseFloat(budgetInput.value);
    if (!b || b <= 0) {
      budgetInput.classList.add('error');
      document.getElementById('budgetError').style.display = 'block';
      valid = false;
    }

    if (!valid) e.preventDefault();
  });

});
</script>
<script src="/assets.php?f=js/main.js"></script>
</body>
</html>
