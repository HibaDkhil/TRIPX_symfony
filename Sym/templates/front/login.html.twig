{% extends 'front/base_auth.html.twig' %}
{% block title %}Login{% endblock %}

{% block extra_css %}
<style>
  /* ── Wavy input errors from Symfony ── */
  .form-control .form-error-message {
    display: block;
    color: #ef4444;
    font-size: 11px;
    margin-top: 4px;
    padding-left: 2px;
    animation: fadeInUp 0.3s ease;
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .form-control.has-error input,
  .form-control.has-error input:focus {
    border-bottom-color: #ef4444 !important;
  }

  /* ── Modal Styles ── */
  .modal-overlay {
    position: fixed; inset: 0;
    background: rgba(11, 18, 32, 0.85);
    backdrop-filter: blur(8px);
    display: flex; align-items: center; justify-content: center;
    z-index: 9999;
    opacity: 0; pointer-events: none;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .modal-overlay.show { opacity: 1; pointer-events: auto; }
  
  .modal-card {
    background: #162236;
    width: 90%; max-width: 440px;
    padding: 40px;
    border-radius: 24px;
    box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
    border: 1px solid rgba(255,255,255,0.05);
    transform: translateY(20px);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    color: #fff;
  }
  .modal-overlay.show .modal-card { transform: translateY(0); }

  .modal-card .form-title { color: #fff !important; }
  .modal-card .form-sub { color: #fff !important; font-weight: 500; opacity: 0.9; }
  
  .modal-card .form-control input {
    color: #fff !important;
    border-bottom: 2px solid rgba(255,255,255,0.1);
  }
  .modal-card .form-control input:focus {
    border-bottom-color: #00a6ed;
  }
  .modal-card .form-control label {
    color: rgba(255,255,255,0.6);
  }
  .modal-card .form-control input:focus ~ label,
  .modal-card .form-control input:not(:placeholder-shown) ~ label {
    color: #00a6ed;
  }

  .modal-close {
    position: absolute; top: 20px; right: 20px;
    background: rgba(255,255,255,0.05); border: none;
    color: #9ca3af; width: 32px; height: 32px; border-radius: 50%;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: all 0.2s;
  }
  .modal-close:hover { background: #ef4444; color: #fff; }

  .modal-step { display: none; }
  .modal-step.active { display: block; animation: fadeInModal 0.4s ease; }
  
  @keyframes fadeInModal {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }

  .pw-requirements { font-size: 11px; margin-top: 8px; color: #9ca3af; line-height: 1.4; }
  .pw-requirements span { display: block; }
  .pw-requirements .met { color: #0fd850; }

  /* ── Eye Toggle Fix ── */
  .field-icon.toggle-pw { cursor: pointer; z-index: 10; pointer-events: auto; }
  .field-icon.toggle-pw i { transition: color 0.2s; }
  .field-icon.toggle-pw:hover i { color: #00a6ed; }
</style>
{% endblock %}

{% block body %}
<div id="app">
  <div class="auth-card" id="authCard">

    {# ── Forms container (behind image) ── #}
    <div class="auth-forms">
    
        {# Display signup errors #}
{% for message in app.flashes('signup_error') %}
    <div class="alert alert-error" style="background: rgba(239,68,68,0.1); border: 1px solid #ef4444; border-radius: 8px; padding: 12px; margin-bottom: 16px; color: #ef4444; font-size: 14px;">
        <i class="fas fa-exclamation-circle"></i> {{ message }}
    </div>
{% endfor %}
      {# LOGIN PANEL #}
      <div class="form-panel panel-login" id="panelLogin">
        <div class="form-title">Welcome back <span class="sparkle">✦</span></div>
        <div class="form-sub">Sign in and pick up where you left off</div>

        <div class="social-row">
          <a href="{{ path('connect_google_start') }}" class="social-btn social-btn--circle">
            <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="G"/>
          </a>
          <a href="{{ path('connect_linkedin_start') }}" class="social-btn social-btn--circle">
            <i class="fab fa-linkedin" style="color:#0a66c2; font-size: 1.5rem;"></i>
          </a>
        </div>

        <div class="divider"><span>or continue with email</span></div>

        {% set error_flashes = app.flashes('error') %}
        {% set success_flashes = app.flashes('success') %}
        {# Flash messages #}
        {% for message in error_flashes %}
          <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> {{ message }}</div>
        {% endfor %}
        {% for message in success_flashes %}
          <div class="alert alert-success"><i class="fas fa-check-circle"></i> {{ message }}</div>
        {% endfor %}

        {# Symfony Authentication Error #}
        {% if error %}
          <div class="alert alert-error">
            <i class="fas fa-exclamation-circle"></i> {{ error.messageKey|trans(error.messageData, 'security') }}
          </div>
        {% endif %}

        <form method="POST" action="{{ path('app_login') }}" id="loginForm" novalidate>
          <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}"/>

          <div class="form-control {{ error ? 'has-error' : '' }}">
            <input type="email" id="login_email" name="_username"
                   value="{{ last_username }}"
                   autocomplete="email" 
                   placeholder=" " />
            <label for="login_email">
              <span style="transition-delay:0ms">E</span><span style="transition-delay:50ms">m</span><span style="transition-delay:100ms">a</span><span style="transition-delay:150ms">i</span><span style="transition-delay:200ms">l</span>
            </label>
            <span class="field-icon"><i class="far fa-envelope"></i></span>
            {% if error_type == 'EMAIL_NOT_FOUND' %}
              <span class="form-error-message">Email doesn't exist</span>
            {% elseif error and error_type != 'INVALID_PASSWORD' %}
              <span class="form-error-message">Invalid email or password</span>
            {% endif %}
          </div>

          <div class="form-control {{ error ? 'has-error' : '' }}">
            <input type="password" id="login_password" name="_password"
                   autocomplete="current-password" 
                   placeholder=" " />
            <label for="login_password">
              <span style="transition-delay:0ms">P</span><span style="transition-delay:50ms">a</span><span style="transition-delay:100ms">s</span><span style="transition-delay:150ms">s</span><span style="transition-delay:200ms">w</span><span style="transition-delay:250ms">o</span><span style="transition-delay:300ms">r</span><span style="transition-delay:350ms">d</span>
            </label>
            <span class="field-icon toggle-pw" data-target="login_password">
              <i class="far fa-eye"></i>
            </span>
            {% if error_type == 'INVALID_PASSWORD' %}
              <span class="form-error-message">Wrong password</span>
            {% elseif error and error_type != 'EMAIL_NOT_FOUND' %}
              <span class="form-error-message">Invalid email or password</span>
            {% endif %}
          </div>

          <div class="forgot">
            <a href="#" id="openForgot">Forgot password?</a>
          </div>

          <div class="btn-row">
            <button type="button" class="btn-secondary" id="goSignup">Create account</button>
            <button type="submit" class="btn-primary">Login</button>
          </div>
        </form>
      </div>

      {# SIGNUP PANEL #}
      <div class="form-panel panel-signup" id="panelSignup">
        <div class="form-title">Join TripX <span class="sparkle">✈</span></div>
        <div class="form-sub">Create your account — it only takes a minute</div>

        {{ form_start(form, {'action': path('app_register'), 'method': 'POST', 'attr': {'id': 'signupForm', 'novalidate': 'novalidate'}}) }}

        {# ── Name row ── #}
        <div class="name-row">
            <div class="form-control {{ form.firstName.vars.errors|length > 0 ? 'has-error' : '' }}">
                {{ form_widget(form.firstName, {'attr': {'placeholder': ' '}}) }}
                <label for="{{ form.firstName.vars.id }}">
                    <span style="transition-delay:0ms">F</span><span style="transition-delay:50ms">i</span><span style="transition-delay:100ms">r</span><span style="transition-delay:150ms">s</span><span style="transition-delay:200ms">t</span>
                </label>
                {% if form.firstName.vars.errors|length > 0 %}
                    <span class="form-error-message">{{ form.firstName.vars.errors[0].message }}</span>
                {% endif %}
            </div>
            <div class="form-control {{ form.lastName.vars.errors|length > 0 ? 'has-error' : '' }}">
                {{ form_widget(form.lastName, {'attr': {'placeholder': ' '}}) }}
                <label for="{{ form.lastName.vars.id }}">
                    <span style="transition-delay:0ms">L</span><span style="transition-delay:50ms">a</span><span style="transition-delay:100ms">s</span><span style="transition-delay:150ms">t</span>
                </label>
                {% if form.lastName.vars.errors|length > 0 %}
                    <span class="form-error-message">{{ form.lastName.vars.errors[0].message }}</span>
                {% endif %}
            </div>
        </div>

        {# ── Email ── #}
        <div class="form-control {{ form.email.vars.errors|length > 0 ? 'has-error' : '' }}">
            {{ form_widget(form.email, {'attr': {'placeholder': ' '}}) }}
            <label for="{{ form.email.vars.id }}">
                <span style="transition-delay:0ms">E</span><span style="transition-delay:50ms">m</span><span style="transition-delay:100ms">a</span><span style="transition-delay:150ms">i</span><span style="transition-delay:200ms">l</span>
            </label>
            <span class="field-icon"><i class="far fa-envelope"></i></span>
            {% if form.email.vars.errors|length > 0 %}
                <span class="form-error-message">{{ form.email.vars.errors[0].message }}</span>
            {% endif %}
        </div>

        {# ── Password ── #}
        <div class="form-control {{ form.plainPassword.first.vars.errors|length > 0 ? 'has-error' : '' }}">
            {{ form_widget(form.plainPassword.first, {'attr': {'placeholder': ' '}}) }}
            <label for="{{ form.plainPassword.first.vars.id }}">
                <span style="transition-delay:0ms">P</span><span style="transition-delay:50ms">a</span><span style="transition-delay:100ms">s</span><span style="transition-delay:150ms">s</span><span style="transition-delay:200ms">w</span><span style="transition-delay:250ms">o</span><span style="transition-delay:300ms">r</span><span style="transition-delay:350ms">d</span>
            </label>
            <span class="field-icon toggle-pw" data-target="{{ form.plainPassword.first.vars.id }}"><i class="far fa-eye"></i></span>
            {% if form.plainPassword.first.vars.errors|length > 0 %}
                <span class="form-error-message">{{ form.plainPassword.first.vars.errors[0].message }}</span>
            {% endif %}
        </div>

        {# ── Confirm Password ── #}
        <div class="form-control {{ form.plainPassword.second.vars.errors|length > 0 ? 'has-error' : '' }}">
            {{ form_widget(form.plainPassword.second, {'attr': {'placeholder': ' '}}) }}
            <label for="{{ form.plainPassword.second.vars.id }}">
                <span style="transition-delay:0ms">C</span><span style="transition-delay:50ms">o</span><span style="transition-delay:100ms">n</span><span style="transition-delay:150ms">f</span><span style="transition-delay:200ms">i</span><span style="transition-delay:250ms">r</span><span style="transition-delay:300ms">m</span>
            </label>
            <span class="field-icon toggle-pw" data-target="{{ form.plainPassword.second.vars.id }}"><i class="far fa-eye"></i></span>
            {% if form.plainPassword.second.vars.errors|length > 0 %}
                <span class="form-error-message">{{ form.plainPassword.second.vars.errors[0].message }}</span>
            {% endif %}
            {% if form.plainPassword.vars.errors|length > 0 %}
                <span class="form-error-message">{{ form.plainPassword.vars.errors[0].message }}</span>
            {% endif %}
        </div>

        {# ── Phone (optional) ── #}
        <div class="form-control {{ form.phoneNumber.vars.errors|length > 0 ? 'has-error' : '' }}">
            {{ form_widget(form.phoneNumber, {'attr': {'placeholder': ' '}}) }}
            <label for="{{ form.phoneNumber.vars.id }}">
                <span style="transition-delay:0ms">P</span><span style="transition-delay:50ms">h</span><span style="transition-delay:100ms">o</span><span style="transition-delay:150ms">n</span><span style="transition-delay:200ms">e</span>
                <span style="transition-delay:250ms; font-size:12px; opacity:.7"> (optional)</span>
            </label>
            {% if form.phoneNumber.vars.errors|length > 0 %}
                <span class="form-error-message">{{ form.phoneNumber.vars.errors[0].message }}</span>
            {% endif %}
        </div>

        <div class="btn-row" style="margin-top:20px">
            <button type="button" class="btn-secondary" id="goLogin">Back to login</button>
            <button type="button" class="btn-primary" id="doRegister">Create account</button>
        </div>

        {# Render save field as hidden so form_rest doesn't double-render a submit button #}
        {{ form_widget(form.save, {'attr': {'style': 'display:none !important', 'tabindex': '-1', 'aria-hidden': 'true'}}) }}

        {{ form_rest(form) }}
        {{ form_end(form) }}
      </div>

    </div>{# /auth-forms #}

    {# Image panel – slides right on signup #}
    <div class="auth-image" id="authImage">
      <img src="{{ asset('images/traveLogin.jpg') }}"
           alt="Adventure awaits" loading="eager"/>
      <div class="auth-image-overlay"></div>
      <div class="logo-badge">
        <svg viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="19" cy="19" r="19" fill="white" fill-opacity=".18"/>
          <text x="7" y="26" font-size="18" font-family="serif" fill="white">✈</text>
        </svg>
        <span>TripX</span>
      </div>
      <div class="auth-image-text">
        <div class="tagline">Your Next<br/>Adventure,</div>
        <div class="sub">Instantly</div>
      </div>
    </div>

  </div>{# /auth-card #}

  {# ── Forgot Password Modal ── #}
  <div class="modal-overlay" id="forgotModal">
    <div class="modal-card">
      <button class="modal-close" id="closeForgot"><i class="fas fa-times"></i></button>
      
      {# Step 1: Send Code #}
      <div class="modal-step active" id="stepEmail">
        <div class="form-title" style="font-size: 1.5rem;">Reset Password <span class="sparkle">✦</span></div>
        <div class="form-sub">Enter your email and we'll send a code</div>
        <div class="form-control" style="margin-top: 30px;">
          <input type="email" id="forgot_email" placeholder=" " />
          <label for="forgot_email">Email Address</label>
          <span class="field-icon"><i class="far fa-envelope"></i></span>
        </div>
        <button class="btn-primary" style="width: 100%; margin-top: 20px;" id="btnSendCode">Send Code</button>
      </div>

      {# Step 2: Verify Code #}
      <div class="modal-step" id="stepCode">
        <div class="form-title" style="font-size: 1.5rem;">Verify Code <span class="sparkle">✉</span></div>
        <div class="form-sub">Enter the 6-digit code sent to your email</div>
        <div class="form-control" style="margin-top: 30px;">
          <input type="text" id="forgot_code" placeholder=" " maxlength="6" style="text-align: center; letter-spacing: 8px; font-weight: 800; font-size: 24px;" />
          <label for="forgot_code">6-Digit Code</label>
        </div>
        <button class="btn-primary" style="width: 100%; margin-top: 20px;" id="btnVerifyCode">Verify Code</button>
      </div>

      {# Step 3: New Password #}
      <div class="modal-step" id="stepReset">
        <div class="form-title" style="font-size: 1.5rem;">New Password <span class="sparkle">🔒</span></div>
        <div class="form-sub">Create your new secure password</div>
        <div class="form-control" style="margin-top: 30px;">
          <input type="password" id="forgot_password" placeholder=" " />
          <label for="forgot_password">New Password</label>
          <span class="field-icon toggle-pw" data-target="forgot_password"><i class="far fa-eye"></i></span>
        </div>
        <div class="form-control">
          <input type="password" id="forgot_confirm" placeholder=" " />
          <label for="forgot_confirm">Confirm Password</label>
          <span class="field-icon toggle-pw" data-target="forgot_confirm"><i class="far fa-eye"></i></span>
        </div>
        <button class="btn-primary" style="width: 100%; margin-top: 20px;" id="btnResetFinal">Update Password</button>
      </div>
    </div>
  </div>
</div>{# /app #}
{% endblock %}

{% block extra_js %}
<script>
  window.TRIPX = {
    registerUrl: "{{ path('app_register') }}",
    onboardingUrl: "{{ path('app_onboarding') }}",
    lockUntil: {{ lock_until ? lock_until : 'null' }},
    errorType: "{{ error_type|default('') }}",
    endpoints: {
      sendCode: "{{ path('app_forgot_password_send_code') }}",
      verifyCode: "{{ path('app_forgot_password_verify') }}",
      resetPassword: "{{ path('app_forgot_password_reset') }}"
    }
  };
</script>
{% endblock %}
