              <div class="timeline-card-img" style="overflow:hidden">
                <img src="{{ trip.photo|default('https://images.unsplash.com/photo-1488646953014-85cb44e25828?q=80&w=200') }}" style="width:100%; height:100%; object-fit:cover; opacity:0.6">
