  <style>
    .page-top { padding-top: calc(var(--nav-height) + 60px); padding-bottom: 40px; }

    /* Blog asymmetric grid */
    .blog-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      grid-template-rows: auto;
      gap: 24px;
    }
    .blog-grid .article-card.featured { grid-column: 1; grid-row: 1; }
    .blog-sidebar-col { display: flex; flex-direction: column; gap: 24px; }

    /* Override article-card for vertical small cards */
    .article-card.vertical {
      grid-template-columns: 1fr;
    }
    .article-card.vertical .article-img { height: 180px; }

    /* Pull quote */
    .pull-quote {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 1.35rem;
      line-height: 1.6;
      color: var(--accent-primary);
      border-left: 4px solid var(--accent-primary);
      padding-left: 24px;
      margin: 0;
    }

    /* Author card */
    .author-card {
      display: flex; gap: 12px; align-items: center;
      padding: 14px;
      background: var(--bg-surface); border: 1px solid var(--border-color);
      border-radius: var(--border-radius-md);
    }
    .author-ava {
      width: 44px; height: 44px; border-radius: 50%;
      background: linear-gradient(135deg, var(--accent-primary), var(--accent-teal));
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; font-weight: 700; color: #fff; font-family: var(--font-body);
      flex-shrink: 0;
    }
    .author-dna canvas { width: 48px !important; height: 48px !important; }

    /* AI typewriter summary */
    .ai-summary-box {
      background: rgba(0,245,212,0.06);
      border: 1px solid rgba(0,245,212,0.2);
      border-radius: var(--border-radius-md);
      padding: 14px 18px;
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--text-secondary);
      letter-spacing: 0.03em;
      line-height: 1.7;
      margin-bottom: 14px;
    }
    .ai-summary-label {
      font-size: 9px; color: var(--accent-teal); text-transform: uppercase;
      letter-spacing: 0.12em; margin-bottom: 6px; display: block;
    }

    /* Comment */
    .comment {
      display: flex; gap: 14px; padding: 16px 0;
      border-bottom: 1px solid var(--border-color);
    }
    .comment-ava {
      width: 38px; height: 38px; border-radius: 50%;
      background: var(--bg-secondary); display: flex; align-items: center; justify-content: center;
      font-size: 16px; flex-shrink: 0;
    }
    .comment-sentiment {
      font-size: 10px; font-family: var(--font-mono);
      padding: 2px 8px; border-radius: 100px;
    }
    .sentiment-positive { background: rgba(0,200,150,0.1); color: #00C878; }
    .sentiment-neutral  { background: rgba(107,127,163,0.1); color: var(--text-muted); }
    @media (max-width: 900px) {
      .blog-grid { grid-template-columns: 1fr; }
      .article-card.featured { grid-template-columns: 1fr; }
    }
  </style>
</head>
