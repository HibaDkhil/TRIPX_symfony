{% block javascripts %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
const accommodationId = {{ accommodation.id }};
const CURRENT_USER_NAME = {{ userName|json_encode|raw }};

let map             = null;
let galleryImages   = [];
let roomsMap        = {};
let currentRoom     = null;
let currentStep     = 0;
let carouselIndex   = 0;
let guestCount      = 1;
let bookingResult   = null;
let carouselInterval= null;
let selectedNetwork = null;

// ── Toast ──────────────────────────────────────────────────
function showToast(msg, type = 'success') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.background = type === 'error' ? '#ef4444' : type === 'info' ? '#3b82f6' : '#10b981';
  t.style.transform = 'translateY(0)'; t.style.opacity = '1';
  setTimeout(() => { t.style.transform = 'translateY(70px)'; t.style.opacity = '0'; }, 3000);
}

function escapeHtml(str) {
  if (!str) return '';
  return String(str)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function openModal(url) {
  document.getElementById('modal-image').src = url;
  document.getElementById('image-modal').classList.add('open');
}
function closeModal() { document.getElementById('image-modal').classList.remove('open'); }

// ══════════════════════════════════════════════════════════
// ITINERARY
// ══════════════════════════════════════════════════════════
async function generateItinerary() {
  const btn       = document.getElementById('generate-itinerary-btn');
  const container = document.getElementById('itinerary-container');
  const days      = document.getElementById('itinerary-days').value;

  if (btn) {
    btn.disabled    = true;
    btn.textContent = '⏳ Generating...';
  }

  container.innerHTML = '<div class="skeleton" style="height:200px;border-radius:12px;"></div>';

  try {
    const res  = await fetch(`/api/itinerary/${accommodationId}`, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ days: parseInt(days) })
    });
    const data = await res.json();
    if (data.itinerary) {
      container.textContent = data.itinerary;
    } else {
      container.innerHTML = '<p style="color:#ef4444;text-align:center;">Failed to generate itinerary. Please try again.</p>';
    }
  } catch (e) {
    container.innerHTML = '<p style="color:#ef4444;text-align:center;">Network error. Please try again.</p>';
  } finally {
    if (btn) {
      btn.disabled    = false;
      btn.textContent = 'Generate';
    }
  }
}

// ══════════════════════════════════════════════════════════
// PAYMENT WALLET
// ══════════════════════════════════════════════════════════
const NETWORK_CONFIG = {
  visa: {
    id: 'pw-visa', label: 'Visa', maxLength: 19,
    format: '16 digits · XXXX XXXX XXXX XXXX', cvvLen: 3,
    placeholder: '4242 4242 4242 4242', cvvPlaceholder: '•••',
    startDigit: '4', pillColor: '#5b9bd5',
  },
  mc: {
    id: 'pw-mc', label: 'Mastercard', maxLength: 19,
    format: '16 digits · XXXX XXXX XXXX XXXX', cvvLen: 3,
    placeholder: '5500 0000 0000 0004', cvvPlaceholder: '•••',
    startDigit: '5', pillColor: '#e57373',
  },
  amex: {
    id: 'pw-amex', label: 'American Express', maxLength: 17,
    format: '15 digits · XXXX XXXXXX XXXXX', cvvLen: 4,
    placeholder: '3714 496353 98431', cvvPlaceholder: '••••',
    startDigit: '3', pillColor: '#81c784',
  },
};

function selectPayCard(network) {
  selectedNetwork = network;
  const cfg = NETWORK_CONFIG[network];
  ['visa','mc','amex'].forEach(n => document.getElementById('pw-' + n).classList.remove('selected'));
  document.getElementById('pw-' + network).classList.add('selected');
  const hint = document.getElementById('pay-wallet-hint');
  hint.textContent = cfg.label + ' selected ✓';
  hint.className = 'pay-wallet-hint selected-hint';
  const pill     = document.getElementById('pay-format-pill');
  const pillText = document.getElementById('pay-format-text');
  pill.style.display = 'inline-flex';
  pill.style.borderColor = cfg.pillColor + '44';
  pill.style.color = cfg.pillColor;
  pill.querySelector('.dot').style.background = cfg.pillColor;
  pillText.textContent = cfg.format;
  const holderEl = document.getElementById('card-holder');
  if (holderEl && (!holderEl.value || holderEl.value === holderEl._lastAutoFill)) {
    holderEl.value = CURRENT_USER_NAME;
    holderEl._lastAutoFill = CURRENT_USER_NAME;
    syncCardHolderToWallet();
  }
  const numEl = document.getElementById('card-number');
  if (numEl) {
    numEl.maxLength = cfg.maxLength;
    numEl.placeholder = cfg.placeholder;
    const currentDigit = numEl.value.replace(/\s/g,'')[0];
    if (currentDigit && currentDigit !== cfg.startDigit) numEl.value = '';
  }
  const cvvEl = document.getElementById('card-cvv');
  if (cvvEl) { cvvEl.maxLength = cfg.cvvLen; cvvEl.placeholder = cfg.cvvPlaceholder; }
}

function syncCardHolderToWallet() {
  const name = (document.getElementById('card-holder').value || '').toUpperCase() || 'YOUR NAME';
  ['visa','mc','amex'].forEach(n => {
    const el = document.getElementById('pw-' + n + '-name');
    if (el) el.textContent = name.substring(0, 18);
  });
}

function updateWalletTotal(totalStr) {
  const el = document.getElementById('pay-bal-real');
  if (el) el.textContent = totalStr;
}

function populatePaymentStep() {
  const name = CURRENT_USER_NAME || 'YOUR NAME';
  ['visa','mc','amex'].forEach(n => {
    const el = document.getElementById('pw-' + n + '-name');
    if (el) el.textContent = name.substring(0, 18);
  });
  const holderEl = document.getElementById('card-holder');
  if (holderEl) { holderEl.value = name; holderEl._lastAutoFill = name; }
  selectedNetwork = null;
  ['visa','mc','amex'].forEach(n => document.getElementById('pw-' + n).classList.remove('selected'));
  const hint = document.getElementById('pay-wallet-hint');
  hint.textContent = 'Hover to fan cards · click one to select';
  hint.className = 'pay-wallet-hint';
  const pill = document.getElementById('pay-format-pill');
  if (pill) pill.style.display = 'none';
  const numEl = document.getElementById('card-number');
  if (numEl) { numEl.value = ''; numEl.placeholder = 'Select a card type above first'; }
  const expEl = document.getElementById('card-expiry');
  if (expEl) { expEl.value = ''; expEl.style.borderColor = ''; expEl.style.borderWidth = ''; }
  const cvvEl = document.getElementById('card-cvv');
  if (cvvEl) cvvEl.value = '';
}

// ══════════════════════════════════════════════════════════
// CAROUSEL
// ══════════════════════════════════════════════════════════
function updateCarouselWithImages(images) {
  const slidesEl = document.getElementById('carousel-slides');
  const dotsEl   = document.getElementById('carousel-dots');
  if (!slidesEl) return;
  if (!images || images.length === 0) {
    slidesEl.innerHTML = '<div class="carousel-slide-placeholder">🏨</div>';
    if (dotsEl) dotsEl.innerHTML = '';
    return;
  }
  const imgSrc = (path) => {
    if (!path) return '';
    if (path.startsWith('http')) return path;
    return '/' + path.replace(/^\/+/, '');
  };
  slidesEl.innerHTML = images.map(img =>
    `<img class="carousel-slide" src="${imgSrc(img.filePath)}" alt="${currentRoom?.room_name || 'Room'}" loading="lazy" onerror="this.onerror=null;this.parentElement.innerHTML='<div class=\\'carousel-slide-placeholder\\'>🏨</div>'">`
  ).join('');
  if (dotsEl) {
    dotsEl.innerHTML = images.map((_, i) =>
      `<div class="carousel-dot ${i === 0 ? 'active' : ''}" onclick="carouselGoTo(${i})"></div>`
    ).join('');
  }
  carouselIndex = 0;
  updateCarousel();
}

function updateCarousel() {
  const slides = document.getElementById('carousel-slides');
  const dots   = document.querySelectorAll('.carousel-dot');
  const count  = slides.children.length;
  if (count === 0) return;
  slides.style.transform = `translateX(-${carouselIndex * 100}%)`;
  dots.forEach((d, i) => d.classList.toggle('active', i === carouselIndex));
}

function carouselNext() {
  const count = document.getElementById('carousel-slides').children.length;
  if (!count) return;
  carouselIndex = (carouselIndex + 1) % count;
  updateCarousel();
}
function carouselPrev() {
  const count = document.getElementById('carousel-slides').children.length;
  if (!count) return;
  carouselIndex = (carouselIndex - 1 + count) % count;
  updateCarousel();
}
function carouselGoTo(i) {
  const count = document.getElementById('carousel-slides').children.length;
  if (!count) return;
  carouselIndex = Math.min(Math.max(0, i), count - 1);
  updateCarousel();
}

function startCarouselAutoSlide() {
  if (carouselInterval) clearInterval(carouselInterval);
  carouselInterval = setInterval(() => {
    if (currentStep === 0 &&
        document.getElementById('booking-drawer').classList.contains('open') &&
        currentRoom?.images?.length > 1) {
      carouselNext();
    }
  }, 4000);
}
function stopCarouselAutoSlide() {
  if (carouselInterval) { clearInterval(carouselInterval); carouselInterval = null; }
}

async function loadRoomImages(roomId) {
  if (currentRoom?.images?.length > 0) {
    updateCarouselWithImages(currentRoom.images);
    return;
  }
  try {
    const data = await fetch(`/api/room/images/${roomId}`).then(r => r.json());
    currentRoom.images = data.images || [];
    updateCarouselWithImages(currentRoom.images);
  } catch {
    currentRoom.images = [];
    updateCarouselWithImages([]);
  }
}

// ══════════════════════════════════════════════════════════
// DRAWER CORE
// ══════════════════════════════════════════════════════════
function openBookingDrawer(roomId) {
  currentRoom = roomsMap[roomId];
  if (!currentRoom) return;
  guestCount    = 1;
  carouselIndex = 0;
  goToStep(0);
  populateStep0();
  loadRoomImages(roomId);
  setDefaultDates();
  startCarouselAutoSlide();
  document.getElementById('booking-drawer').classList.add('open');
  document.getElementById('drawer-backdrop').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeDrawer() {
  if (currentStep === 3) { _closeDrawer(); return; }
  if (currentStep > 0 && !confirm('Close booking? Your progress will be lost.')) return;
  _closeDrawer();
}
function _closeDrawer() {
  document.getElementById('booking-drawer').classList.remove('open');
  document.getElementById('drawer-backdrop').classList.remove('open');
  document.body.style.overflow = '';
  stopCarouselAutoSlide();
}

document.getElementById('drawer-backdrop').addEventListener('click', () => {
  if (currentStep === 0 || currentStep === 3) _closeDrawer();
  else showToast('Complete or cancel the booking first', 'info');
});

function goToStep(step) {
  const oldEl = document.getElementById('step-' + currentStep);
  if (oldEl) {
    oldEl.classList.remove('active');
    oldEl.classList.add('exiting');
    setTimeout(() => oldEl.classList.remove('exiting'), 450);
  }
  currentStep = step;
  const newEl = document.getElementById('step-' + step);
  if (newEl) { newEl.classList.add('active'); newEl.scrollTop = 0; }
  updateProgress();
  updateCTA();
  if (step === 2) {
    populatePaymentStep();
    const recapTotal = document.getElementById('recap-total');
    if (recapTotal) updateWalletTotal(recapTotal.textContent);
  }
}

function updateProgress() {
  for (let i = 0; i <= 3; i++) {
    const dot  = document.getElementById('dot-'  + i);
    const prog = document.getElementById('prog-' + i);
    if (dot)  dot.classList.remove('active','done');
    if (prog) prog.classList.remove('active','done');
    if (i < currentStep) {
      if (dot)  dot.classList.add('done');
      if (prog) prog.classList.add('done');
    } else if (i === currentStep) {
      if (dot)  dot.classList.add('active');
      if (prog) prog.classList.add('active');
    }
  }
  for (let i = 0; i <= 2; i++) {
    const line = document.getElementById('line-' + i);
    if (line) line.style.width = i < currentStep ? '100%' : '0%';
  }
}

function updateCTA() {
  const btn    = document.getElementById('drawer-cta-btn');
  const label  = document.getElementById('cta-label');
  const footer = document.getElementById('drawer-footer');
  if (btn) { btn.disabled = false; btn.classList.remove('loading'); btn.onclick = drawerCTAClick; }
  if (footer) footer.style.display = '';
  const labels = ['Reserve This Room →', 'Continue to Payment →', '🔐 Complete Booking', '✓ Close — All Done!'];
  if (label) label.textContent = labels[currentStep] || '';
  if (currentStep === 3 && btn) btn.onclick = _closeDrawer;
}

function drawerCTAClick() {
  if      (currentStep === 0) { goToStep(1); }
  else if (currentStep === 1) { if (!validateStay()) return; populatePaymentRecap(); goToStep(2); }
  else if (currentStep === 2) { submitBooking(); }
  else if (currentStep === 3) { _closeDrawer(); }
}

// ══════════════════════════════════════════════════════════
// STEP 0 — Room Preview
// ══════════════════════════════════════════════════════════
function populateStep0() {
  const r = currentRoom;
  if (!r) return;
  document.getElementById('preview-name').textContent     = r.room_name || 'Standard Room';
  document.getElementById('preview-type').textContent     = r.room_type || 'Standard';
  document.getElementById('preview-capacity').textContent = r.capacity  || '—';
  document.getElementById('preview-size').textContent     = r.size      || '—';
  document.getElementById('preview-beds').textContent     = Math.ceil((r.capacity || 2) / 2);
  document.getElementById('preview-price').textContent    = '€' + r.price_per_night;
  document.getElementById('guest-capacity-hint').textContent = 'Max ' + (r.capacity || 4) + ' guests';
  const amenWrap = document.getElementById('preview-amenities');
  const icons = { wifi:'📶','air conditioning':'❄️',breakfast:'🍳',gym:'💪',spa:'🧖',pool:'🏊',parking:'🅿️',tv:'📺',minibar:'🍸',safe:'🔒',balcony:'🌅',sea:'🌊' };
  amenWrap.innerHTML = (r.amenities || 'WiFi, Air Conditioning').split(',').map(a => {
    const key  = a.trim().toLowerCase();
    const icon = Object.keys(icons).find(k => key.includes(k));
    return `<div class="drawer-amenity">${icon ? icons[icon] + ' ' : ''}${escapeHtml(a.trim())}</div>`;
  }).join('');
}

// ══════════════════════════════════════════════════════════
// STEP 1 — Stay Details
// ══════════════════════════════════════════════════════════
function setDefaultDates() {
  const today    = new Date();
  const checkin  = new Date(today); checkin.setDate(today.getDate() + 1);
  const checkout = new Date(today); checkout.setDate(today.getDate() + 4);
  const ci = document.getElementById('d-checkin');
  const co = document.getElementById('d-checkout');
  if (ci) { ci.value = checkin.toISOString().split('T')[0]; ci.min = today.toISOString().split('T')[0]; }
  if (co)   co.value = checkout.toISOString().split('T')[0];
  guestCount = 1;
  const gd = document.getElementById('guest-count-display');
  if (gd) gd.textContent = 1;
  updateGuestButtons();
  recalcPrice();
}

function adjustGuests(delta) {
  const max = currentRoom ? (currentRoom.capacity || 4) : 4;
  guestCount = Math.min(Math.max(1, guestCount + delta), max);
  const gd = document.getElementById('guest-count-display');
  if (gd) gd.textContent = guestCount;
  updateGuestButtons();
}
function updateGuestButtons() {
  const max   = currentRoom ? (currentRoom.capacity || 4) : 4;
  const minus = document.getElementById('guest-minus');
  const plus  = document.getElementById('guest-plus');
  if (minus) minus.disabled = (guestCount <= 1);
  if (plus)  plus.disabled  = (guestCount >= max);
}

function getNights() {
  const ci = document.getElementById('d-checkin');
  const co = document.getElementById('d-checkout');
  if (!ci || !co) return 0;
  const a = new Date(ci.value), b = new Date(co.value);
  if (isNaN(a) || isNaN(b)) return 0;
  const diff = Math.round((b - a) / 86400000);
  return diff > 0 ? diff : 0;
}

function recalcPrice() {
  const nights = getNights();
  const price  = currentRoom ? currentRoom.price_per_night : 0;
  const ci     = document.getElementById('d-checkin');
  const co     = document.getElementById('d-checkout');
  if (ci && co && ci.value) co.min = ci.value;
  const pill   = document.getElementById('nights-pill');
  const setRow = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
  if (nights <= 0) {
    if (pill) pill.textContent = 'Select valid dates';
    setRow('price-row-label','—'); setRow('price-row-sub','€—'); setRow('price-row-tax','€—'); setRow('price-row-total','€—');
    return;
  }
  const sub   = price * nights;
  const tax   = Math.round(sub * 0.10 * 100) / 100;
  const total = Math.round((sub + tax) * 100) / 100;
  if (pill) pill.textContent = `🌙 ${nights} night${nights !== 1 ? 's' : ''}`;
  setRow('price-row-label', `€${price} × ${nights} night${nights !== 1 ? 's' : ''}`);
  setRow('price-row-sub',   `€${sub.toFixed(2)}`);
  setRow('price-row-tax',   `€${tax.toFixed(2)}`);
  setRow('price-row-total', `€${total.toFixed(2)}`);
}

function validateStay() {
  const nights = getNights();
  if (nights <= 0) { showToast('Please select valid check-in and check-out dates', 'error'); return false; }
  if (nights > 90) { showToast('Maximum stay is 90 nights', 'error'); return false; }
  const phone = document.getElementById('d-phone').value.trim();
  if (!phone) { showToast('Please enter a phone number', 'error'); return false; }
  const cleanPhone = phone.replace(/[\s\-\(\)\+]/g, '');
  if (!/^[0-9]{8,15}$/.test(cleanPhone)) { showToast('Phone number must contain 8–15 digits', 'error'); markError('d-phone'); return false; }
  return true;
}

// ══════════════════════════════════════════════════════════
// STEP 2 — Payment recap
// ══════════════════════════════════════════════════════════
function populatePaymentRecap() {
  const nights = getNights();
  const price  = currentRoom ? currentRoom.price_per_night : 0;
  const sub    = price * nights;
  const tax    = Math.round(sub * 0.10 * 100) / 100;
  const total  = Math.round((sub + tax) * 100) / 100;
  const set    = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
  set('recap-room',   currentRoom.room_name || 'Room');
  set('recap-nights', nights + 'n');
  set('recap-total',  '€' + total.toFixed(2));
}

// ── Phone sanitizer ────────────────────────────────────────
function sanitizePhone(input) {
  let val = input.value.replace(/[^\d\s\+\-\(\)]/g, '');
  const digits = val.replace(/\D/g, '');
  if (digits.length > 15) val = val.slice(0, -1);
  input.value = val;
}

// ── Card number formatter ──────────────────────────────────
function formatCardNumber(input) {
  const isAmex = selectedNetwork === 'amex';
  let raw = input.value.replace(/\D/g, '');
  if (isAmex) {
    raw = raw.substring(0, 15);
    let parts = [];
    if (raw.length > 0)  parts.push(raw.substring(0, 4));
    if (raw.length > 4)  parts.push(raw.substring(4, 10));
    if (raw.length > 10) parts.push(raw.substring(10, 15));
    input.value = parts.join(' ');
  } else {
    raw = raw.substring(0, 16);
    input.value = raw.replace(/(.{4})/g, '$1 ').trim();
  }
}

// ── Expiry formatter + live validator ─────────────────────
function formatExpiry(input) {
  let val = input.value.replace(/\D/g, '').substring(0, 4);
  if (val.length >= 2) {
    let month = parseInt(val.substring(0, 2), 10);
    if (month < 1)  month = 1;
    if (month > 12) month = 12;
    val = String(month).padStart(2, '0') + '/' + val.substring(2);
  }
  input.value = val;

  if (val.length === 5) {
    const month = parseInt(val.substring(0, 2), 10);
    const year  = parseInt('20' + val.substring(3), 10);
    const now   = new Date();
    const el    = document.getElementById('card-expiry');
    if (year < now.getFullYear() || (year === now.getFullYear() && month < now.getMonth() + 1)) {
      el.style.borderColor = '#ef4444';
      el.style.borderWidth = '2px';
      el.title = 'This card has expired';
    } else {
      el.style.borderColor = '';
      el.style.borderWidth = '';
      el.title = '';
    }
  }
}

// ══════════════════════════════════════════════════════════
// BOOKING SUBMISSION
// ══════════════════════════════════════════════════════════
async function submitBooking() {
  const btn = document.getElementById('drawer-cta-btn');
  document.querySelectorAll('.drawer-input').forEach(el => { el.style.borderColor = ''; el.style.borderWidth = ''; });

  if (!selectedNetwork) { showToast('❌ Please select a card type from your wallet', 'error'); return; }

  const cfg    = NETWORK_CONFIG[selectedNetwork];
  const rawNum = document.getElementById('card-number').value.replace(/\s/g,'');
  const minLen = selectedNetwork === 'amex' ? 15 : 13;
  if (rawNum.length < minLen) { showToast(`❌ Enter a valid ${cfg.label} card number`, 'error'); markError('card-number'); return; }

  const expiry = document.getElementById('card-expiry').value;
  if (!expiry || expiry.length < 5) {
    showToast('❌ Enter a valid expiry date (MM/YY)', 'error');
    markError('card-expiry');
    return;
  }
  const expMonth = parseInt(expiry.substring(0, 2), 10);
  const expYear  = parseInt('20' + expiry.substring(3), 10);
  const now      = new Date();
  if (expMonth < 1 || expMonth > 12) {
    showToast('❌ Expiry month must be between 01 and 12', 'error');
    markError('card-expiry');
    return;
  }
  if (expYear < now.getFullYear() || (expYear === now.getFullYear() && expMonth < now.getMonth() + 1)) {
    showToast('❌ This card has expired', 'error');
    markError('card-expiry');
    return;
  }

  const cvv = document.getElementById('card-cvv').value;
  if (!cvv || cvv.length < cfg.cvvLen) { showToast(`❌ Enter your ${cfg.cvvLen}-digit CVV`, 'error'); markError('card-cvv'); return; }

  const holder = document.getElementById('card-holder').value.trim();
  if (!holder) { showToast('❌ Enter the cardholder name', 'error'); markError('card-holder'); return; }

  if (btn) { btn.classList.add('loading'); btn.disabled = true; }

  try {
    const payload = {
      room_id:           currentRoom.id,
      check_in:          document.getElementById('d-checkin').value,
      check_out:         document.getElementById('d-checkout').value,
      guests:            guestCount,
      phone:             document.getElementById('d-phone').value.trim(),
      special_requests:  document.getElementById('d-requests').value.trim(),
      estimated_arrival: document.getElementById('d-arrival').value
    };
    const res  = await fetch('/api/book', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!res.ok || data.error) {
      if (data.field) {
        const el = getFieldElement(data.field);
        if (el) { markError(el.id); el.scrollIntoView({ behavior:'smooth', block:'center' }); }
        showToast('❌ ' + data.error, 'error');
      } else if (data.errors) {
        Object.entries(data.errors).forEach(([field]) => {
          const el = getFieldElement(field);
          if (el) { markError(el.id); setTimeout(() => clearError(el.id), 3000); }
        });
        showToast('❌ Validation failed. Please check your details.', 'error');
      } else {
        showToast('❌ ' + (data.error || 'Booking failed. Please try again.'), 'error');
      }
      return;
    }
    bookingResult = data;
    populateConfirmation(data);
    goToStep(3);
    launchConfetti();
  } catch (err) {
    showToast('❌ Network error. Please try again.', 'error');
  } finally {
    if (btn) { btn.classList.remove('loading'); btn.disabled = false; }
  }
}

function markError(id) {
  const el = document.getElementById(id);
  if (el) { el.style.borderColor = '#ef4444'; el.style.borderWidth = '2px'; }
}
function clearError(id) {
  const el = document.getElementById(id);
  if (el) { el.style.borderColor = ''; el.style.borderWidth = ''; }
}

function getFieldElement(fieldName) {
  const mapping = {
    'check_in': 'd-checkin', 'check_out': 'd-checkout',
    'phone': 'd-phone', 'phone_number': 'd-phone',
    'estimated_arrival': 'd-arrival', 'special_requests': 'd-requests',
    'dates': 'd-checkin', 'nights': 'd-checkin',
  };
  const id = mapping[fieldName];
  return id ? document.getElementById(id) : null;
}

function populateConfirmation(data) {
  const set = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
  set('booking-ref',   data.reference || 'TRX-' + Date.now());
  set('conf-room',     currentRoom.room_name || 'Room');
  set('conf-checkin',  formatDate(document.getElementById('d-checkin').value));
  set('conf-checkout', formatDate(document.getElementById('d-checkout').value));
  set('conf-guests',   guestCount + (guestCount === 1 ? ' Guest' : ' Guests'));
  set('conf-total',    '€' + (data.total || 0).toFixed(2));
  setTimeout(() => {
    const chk = document.getElementById('confirm-checkmark');
    if (chk) chk.classList.add('animate');
  }, 100);
}

function formatDate(str) {
  if (!str) return '—';
  return new Date(str).toLocaleDateString('en-US', { weekday:'short', month:'short', day:'numeric', year:'numeric' });
}

// ══════════════════════════════════════════════════════════
// CONFETTI
// ══════════════════════════════════════════════════════════
function launchConfetti() {
  const canvas = document.getElementById('confetti-canvas');
  if (!canvas) return;
  canvas.width = window.innerWidth; canvas.height = window.innerHeight;
  canvas.classList.add('active');
  const ctx = canvas.getContext('2d');
  const particles = Array.from({length: 120}, () => ({
    x: Math.random() * canvas.width, y: -20,
    w: Math.random() * 10 + 5, h: Math.random() * 6 + 3,
    r: Math.random() * Math.PI * 2, dr: (Math.random() - 0.5) * 0.2,
    vx: (Math.random() - 0.5) * 4, vy: Math.random() * 3 + 2,
    color: ['#a78bfa','#38bdf8','#fbbf24','#10b981','#f472b6','#fb923c'][Math.floor(Math.random()*6)],
    alpha: 1
  }));
  let frame = 0;
  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    let alive = false;
    for (const p of particles) {
      p.x += p.vx; p.y += p.vy; p.r += p.dr; p.vy += 0.05; p.alpha -= 0.008;
      if (p.alpha > 0 && p.y < canvas.height) alive = true;
      ctx.save();
      ctx.globalAlpha = Math.max(0, p.alpha);
      ctx.translate(p.x, p.y); ctx.rotate(p.r);
      ctx.fillStyle = p.color;
      ctx.fillRect(-p.w/2, -p.h/2, p.w, p.h);
      ctx.restore();
    }
    frame++;
    if (alive && frame < 300) requestAnimationFrame(draw);
    else { canvas.classList.remove('active'); ctx.clearRect(0,0,canvas.width,canvas.height); }
  }
  requestAnimationFrame(draw);
}

// ══════════════════════════════════════════════════════════
// ROOMS LOADER
// ══════════════════════════════════════════════════════════
async function loadRooms() {
  try {
    const data = await fetch(`/api/accommodation/rooms/${accommodationId}`).then(r => r.json());
    const container = document.getElementById('rooms-container');
    if (data.rooms && data.rooms.length > 0) {
      let minPrice = Infinity;
      data.rooms.forEach(r => { roomsMap[r.id] = r; if (r.price_per_night < minPrice) minPrice = r.price_per_night; });
      container.innerHTML = data.rooms.map(room => `
        <div class="room-card">
          <div class="room-header">
            <span class="room-name">${escapeHtml(room.room_name || 'Standard Room')}</span>
            <span class="room-price">€${room.price_per_night}<small>/night</small></span>
          </div>
          <div class="room-details">
            <span>👥 Capacity: ${room.capacity || 2} guests</span>
            <span>📏 Size: ${room.size || 'N/A'} m²</span>
          </div>
          <div class="room-amenities">
            ${(room.amenities || 'WiFi, Air Conditioning').split(',').map(a => `<span class="room-amenity">${escapeHtml(a.trim())}</span>`).join('')}
          </div>
          <button class="book-btn" style="padding:10px;" onclick="openBookingDrawer(${room.id})">
            🛏️ Book This Room
          </button>
        </div>`).join('');
      document.getElementById('min-price').textContent = `€${minPrice}`;
    } else {
      container.innerHTML = '<div class="empty-state"><div class="icon">🛏️</div><p>No rooms available.</p></div>';
    }
  } catch(e) {
    document.getElementById('rooms-container').innerHTML = '<div class="empty-state"><div class="icon">⚠️</div><p>Unable to load rooms.</p></div>';
  }
}

// ══════════════════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {
  loadRooms();
  loadWeather();
  loadNearby();
  loadGallery();
  loadReviews();
  initMiniMap();

  const nearbyCategory = document.getElementById('nearby-category');
  if (nearbyCategory) nearbyCategory.addEventListener('change', loadNearby);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && document.getElementById('booking-drawer').classList.contains('open')) {
      closeDrawer();
    }
  });
});

