{% extends 'front/base_auth.html.twig' %}
{% block title %}Forgot Password{% endblock %}

{% block body %}
<div id="app">
  <div class="auth-card" style="max-width: 500px; margin: 40px auto;">
    <div class="auth-forms" style="width: 100%;">
      <div class="form-panel" style="position:relative; z-index:2; padding:40px;">
        <div class="form-title">Reset Password <span class="sparkle">🔒</span></div>
        <div class="form-sub">Enter your email address and we'll send you a link to reset your password.</div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div style="background: {{ label == 'success' ? '#10b981' : '#ef4444' }}; color: white; padding: 12px; border-radius: 8px; margin-bottom: 20px; font-size: 14px;">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <form method="POST" action="{{ path('app_forgot_password') }}">
          <div class="form-control">
            <input type="email" id="reset_email" name="email" required autocomplete="email" placeholder=" " oninput="this.classList.toggle('has-value', this.value!='')" />
            <label for="reset_email">
              <span style="transition-delay:0ms">E</span><span style="transition-delay:50ms">m</span><span style="transition-delay:100ms">a</span><span style="transition-delay:150ms">i</span><span style="transition-delay:200ms">l</span>
            </label>
            <span class="field-icon"><i class="far fa-envelope"></i></span>
          </div>

          <div class="btn-row" style="margin-top: 30px;">
            <a href="{{ path('app_login') }}" class="btn-secondary" style="text-decoration:none; text-align:center;">Back to Login</a>
            <button type="submit" class="btn-primary">Send Email</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{% endblock %}
