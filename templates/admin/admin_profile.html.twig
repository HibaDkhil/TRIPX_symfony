{% extends 'admin/admin_base.html.twig' %}
{% block title %}My Profile — TripX Admin{% endblock %}

{% block breadcrumbs %}
  <a href="{{ path('admin_dashboard') }}" class="crumb">Dashboard</a>
  <span class="sep">›</span>
  <span class="crumb active">My Profile</span>
{% endblock %}

{% block content %}
<style>
/* Animated Wavy Input Styles from Auth UI */
.wavy-control {
  position: relative;
  margin: 20px auto 35px;
  width: 100%;
}
.wavy-control input {
  background-color: transparent !important;
  border: 0 !important;
  border-bottom: 2px #d1d5db solid !important;
  display: block;
  width: 100%;
  padding: 12px 0 !important;
  font-size: 16px;
  color: var(--text-primary);
  border-radius: 0 !important;
  transition: 0.3s ease;
}
.wavy-control input:focus,
.wavy-control input:valid,
.wavy-control input.has-value {
  outline: 0;
  border-bottom-color: #3b82f6 !important;
}
.wavy-control label {
  position: absolute;
  top: 12px;
  left: 0;
  pointer-events: none;
}
.wavy-control label span {
  display: inline-block;
  font-size: 16px;
  min-width: 5px;
  color: #8a94a8;
  transition: 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}
.wavy-control input:focus+label span,
.wavy-control input:valid+label span,
.wavy-control input.has-value+label span {
  color: #3b82f6;
  transform: translateY(-28px);
  font-weight: 700;
  font-size: 13px;
}
.wavy-icon {
  position: absolute;
  right: 0;
  bottom: 12px;
  color: #8a94a8;
  font-size: 1rem;
  pointer-events: all;
  cursor: pointer;
}
.wavy-icon:hover {
  color: #3b82f6;
}
</style>

<div class="reveal">
  {% for message in app.flashes('error') %}
    <div style="margin-bottom:14px;padding:10px 12px;border-radius:8px;border:1px solid #ef4444;background:rgba(239,68,68,0.12);color:#ef4444">{{ message }}</div>
  {% endfor %}
  {% for message in app.flashes('success') %}
    <div style="margin-bottom:14px;padding:10px 12px;border-radius:8px;border:1px solid #22c55e;background:rgba(34,197,94,0.12);color:#22c55e">{{ message }}</div>
  {% endfor %}
  <div style="margin-bottom:32px;">
    <h1 class="display-sm" style="margin-bottom:4px">Admin Profile</h1>
    <p class="text-muted" style="font-size:14px">Manage your account settings and credentials.</p>
  </div>

  <div class="grid-2" style="gap:24px;">
    <div class="card reveal" style="max-width: 600px;">
      <div class="card-body">
        <h3 style="margin-bottom:20px; font-family:var(--font-display);">Personal Information</h3>
        <form method="post" action="{{ path('admin_profile_update') }}" novalidate>
          
          <div class="wavy-control">
            <input type="text" id="admin_firstname" name="firstName" value="{{ app.user.firstName }}" class="has-value" required>
            <label for="admin_firstname">
              <span style="transition-delay:0ms">F</span><span style="transition-delay:50ms">i</span><span style="transition-delay:100ms">r</span><span style="transition-delay:150ms">s</span><span style="transition-delay:200ms">t</span><span style="transition-delay:250ms">&nbsp;</span><span style="transition-delay:300ms">N</span><span style="transition-delay:350ms">a</span><span style="transition-delay:400ms">m</span><span style="transition-delay:450ms">e</span>
            </label>
          </div>

          <div class="wavy-control">
            <input type="text" id="admin_lastname" name="lastName" value="{{ app.user.lastName }}" class="has-value" required>
            <label for="admin_lastname">
              <span style="transition-delay:0ms">L</span><span style="transition-delay:50ms">a</span><span style="transition-delay:100ms">s</span><span style="transition-delay:150ms">t</span><span style="transition-delay:200ms">&nbsp;</span><span style="transition-delay:250ms">N</span><span style="transition-delay:300ms">a</span><span style="transition-delay:350ms">m</span><span style="transition-delay:400ms">e</span>
            </label>
          </div>

          <div class="wavy-control">
            <input type="email" id="admin_email" name="email" value="{{ app.user.email }}" class="has-value" required>
            <label for="admin_email">
              <span style="transition-delay:0ms">E</span><span style="transition-delay:50ms">m</span><span style="transition-delay:100ms">a</span><span style="transition-delay:150ms">i</span><span style="transition-delay:200ms">l</span>
            </label>
          </div>

          <button type="submit" class="btn btn-primary" style="margin-top:12px;">Update Info</button>
        </form>
      </div>
    </div>

    <div class="card reveal" style="max-width: 600px;">
      <div class="card-body">
        <h3 style="margin-bottom:20px; font-family:var(--font-display); color:var(--accent-coral);">Change Password</h3>
        <form method="post" action="{{ path('admin_profile_password') }}" novalidate>
          
          <div class="wavy-control">
            <input type="password" id="admin_newpwd" name="new_password" required>
            <label for="admin_newpwd">
              <span style="transition-delay:0ms">N</span><span style="transition-delay:50ms">e</span><span style="transition-delay:100ms">w</span><span style="transition-delay:150ms">&nbsp;</span><span style="transition-delay:200ms">P</span><span style="transition-delay:250ms">a</span><span style="transition-delay:300ms">s</span><span style="transition-delay:350ms">s</span><span style="transition-delay:400ms">w</span><span style="transition-delay:450ms">o</span><span style="transition-delay:500ms">r</span><span style="transition-delay:550ms">d</span>
            </label>
            <span class="wavy-icon toggle-pw" data-target="admin_newpwd"><i class="far fa-eye"></i></span>
          </div>

          <div class="wavy-control">
            <input type="password" id="admin_confirmpwd" name="confirm_password" required>
            <label for="admin_confirmpwd">
              <span style="transition-delay:0ms">C</span><span style="transition-delay:40ms">o</span><span style="transition-delay:80ms">n</span><span style="transition-delay:120ms">f</span><span style="transition-delay:160ms">i</span><span style="transition-delay:200ms">r</span><span style="transition-delay:240ms">m</span><span style="transition-delay:280ms">&nbsp;</span><span style="transition-delay:320ms">P</span><span style="transition-delay:360ms">a</span><span style="transition-delay:400ms">s</span><span style="transition-delay:440ms">s</span><span style="transition-delay:480ms">w</span><span style="transition-delay:520ms">o</span><span style="transition-delay:560ms">r</span><span style="transition-delay:600ms">d</span>
            </label>
            <span class="wavy-icon toggle-pw" data-target="admin_confirmpwd"><i class="far fa-eye"></i></span>
          </div>

          <button type="submit" class="btn btn-primary" style="margin-top:12px;">Update Password</button>
        </form>
      </div>
    </div>
  </div>
</div>
<script>
document.addEventListener('DOMContentLoaded', function () {
  /* Vanilla browser validation overrides */
  document.querySelectorAll('input[required], select[required], textarea[required]').forEach(function (el) {
    el.addEventListener('invalid', function () {
      if (el.validity.valueMissing) el.setCustomValidity('Please fill out this field.');
      else if (el.validity.typeMismatch) el.setCustomValidity('Please enter a valid value.');
    });
    el.addEventListener('input', function () { el.setCustomValidity(''); });
  });

  /* Lift Wavy Labels on input value presence */
  document.querySelectorAll('.wavy-control input').forEach(function (input) {
    function checkFilled() {
      if (input.value && input.value.trim() !== '') {
        input.classList.add('has-value');
      } else {
        input.classList.remove('has-value');
      }
    }
    checkFilled();
    input.addEventListener('input', checkFilled);
    input.addEventListener('change', checkFilled);
  });

  /* Password Toggle */
  document.querySelectorAll('.toggle-pw').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.dataset.target;
      const input = document.getElementById(targetId);
      if (!input) return;
      const isText = input.type === 'text';
      input.type = isText ? 'password' : 'text';
      const icon = btn.querySelector('i');
      icon.className = isText ? 'far fa-eye' : 'far fa-eye-slash';
    });
  });
});
</script>
{% endblock %}
