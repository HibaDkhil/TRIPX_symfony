{% extends 'admin/admin_base.html.twig' %}
{% block title %}Loyalty Points — TripX Admin{% endblock %}

{% block breadcrumbs %}
  <a href="{{ path('admin_dashboard') }}" class="crumb">Dashboard</a>
  <span class="sep">›</span>
  <span class="crumb active">Loyalty Points</span>
{% endblock %}

{% block content %}
<div class="reveal">
  <div style="margin-bottom:32px;">
    <h1 class="display-sm" style="margin-bottom:4px">Loyalty Points</h1>
    <p class="text-muted" style="font-size:14px">Overview of all users' loyalty tiers and points.</p>
  </div>

  <div class="stats-tab-bar reveal" style="display:flex; gap:16px; margin-bottom:24px; padding:12px; background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--border-radius-lg);">
    <div style="flex:1; padding:12px 20px; border-right:1px solid var(--border-color);">
      <div class="text-muted" style="font-size:12px; text-transform:uppercase; margin-bottom:4px;">Total Members</div>
      <div style="font-family:var(--font-display); font-size:28px; font-weight:700; color:var(--accent-primary);">{{ stats.total }}</div>
    </div>
    <div style="flex:1; padding:12px 20px; border-right:1px solid var(--border-color);">
      <div class="text-muted" style="font-size:12px; text-transform:uppercase; margin-bottom:4px;">🥇 Gold</div>
      <div style="font-family:var(--font-display); font-size:28px; font-weight:700; color:#f59e0b;">{{ stats.gold }}</div>
    </div>
    <div style="flex:1; padding:12px 20px; border-right:1px solid var(--border-color);">
      <div class="text-muted" style="font-size:12px; text-transform:uppercase; margin-bottom:4px;">🥈 Silver</div>
      <div style="font-family:var(--font-display); font-size:28px; font-weight:700; color:#9ca3af;">{{ stats.silver }}</div>
    </div>
    <div style="flex:1; padding:12px 20px;">
      <div class="text-muted" style="font-size:12px; text-transform:uppercase; margin-bottom:4px;">🥉 Bronze</div>
      <div style="font-family:var(--font-display); font-size:28px; font-weight:700; color:#b45309;">{{ stats.bronze }}</div>
    </div>
  </div>

  <div class="card reveal" style="padding:0; overflow:hidden;">
    <table style="width:100%; border-collapse:collapse;">
      <thead>
        <tr style="background:rgba(0,166,237,0.05);">
          <th style="text-align:left; padding:16px 20px; font-family:var(--font-display); font-size:14px;">User ID</th>
          <th style="text-align:left; padding:16px 20px; font-family:var(--font-display); font-size:14px;">Total Points</th>
          <th style="text-align:left; padding:16px 20px; font-family:var(--font-display); font-size:14px;">Level</th>
          <th style="text-align:left; padding:16px 20px; font-family:var(--font-display); font-size:14px;">Discount</th>
          <th style="text-align:left; padding:16px 20px; font-family:var(--font-display); font-size:14px;">Progress</th>
        </tr>
      </thead>
      <tbody>
        {% for item in items %}
        {% set level = item.computeLevel() %}
        <tr style="border-top:1px solid var(--border-color);">
          <td style="padding:16px 20px; font-family:var(--font-mono); font-size:12px;">#{{ item.userId }}</td>
          <td style="padding:16px 20px; font-weight:700; color:var(--accent-primary);">{{ item.totalPoints }} pts</td>
          <td style="padding:16px 20px;">
            {% if level == 'GOLD' %}
              <span class="badge badge-gold">🥇 Gold</span>
            {% elseif level == 'SILVER' %}
              <span class="badge" style="background:rgba(156,163,175,0.2); color:#9ca3af;">🥈 Silver</span>
            {% else %}
              <span class="badge" style="background:rgba(180,83,9,0.15); color:#b45309;">🥉 Bronze</span>
            {% endif %}
          </td>
          <td style="padding:16px 20px; color:#10b981; font-weight:600;">{{ item.loyaltyDiscountPercent }}%</td>
          <td style="padding:16px 20px; width:180px;">
            {% if level != 'GOLD' %}
              {% set pct = level == 'BRONZE' ? (item.totalPoints / 200 * 100) : ((item.totalPoints - 200) / 200 * 100) %}
              <div style="background:var(--border-color); border-radius:999px; height:6px; overflow:hidden;">
                <div style="height:100%; width:{{ pct > 100 ? 100 : pct }}%; background:var(--accent-primary); border-radius:999px;"></div>
              </div>
              <div style="font-size:11px; color:var(--text-muted); margin-top:4px;">{{ item.pointsToNextLevel }} pts to next</div>
            {% else %}
              <span style="font-size:12px; color:#f59e0b;">✦ Max level reached</span>
            {% endif %}
          </td>
        </tr>
        {% else %}
        <tr>
          <td colspan="5" style="text-align:center; padding:40px; color:var(--text-muted)">No loyalty records yet.</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endblock %}
