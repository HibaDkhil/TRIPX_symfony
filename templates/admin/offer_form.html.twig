{% extends 'admin/admin_base.html.twig' %}
{% block title %}{{ target_offer ? 'Edit' : 'Add' }} Offer — TripX Admin{% endblock %}

{% block breadcrumbs %}
  <a href="{{ path('admin_dashboard') }}" class="crumb">Dashboard</a>
  <span class="sep">›</span>
  <a href="{{ path('admin_offers') }}" class="crumb">Offers</a>
  <span class="sep">›</span>
  <span class="crumb active">{{ target_offer ? 'Edit ' ~ target_offer.title : 'Add Offer' }}</span>
{% endblock %}

{% block content %}
<div class="reveal">
  <div style="margin-bottom:32px;">
    <h1 class="display-sm" style="margin-bottom:4px">{{ target_offer ? 'Edit' : 'Add' }} Offer</h1>
    <p class="text-muted" style="font-size:14px">Configure a promotional offer or discount.</p>
  </div>

  <div class="card reveal" style="max-width:860px;">
    <div class="card-body">
      <form method="post" action="{{ target_offer ? path('admin_offer_edit', {id: target_offer.idOffer}) : path('admin_offer_add') }}">

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">

          <div class="form-group" style="grid-column:1/-1; margin-bottom:20px;">
            <label style="display:block; margin-bottom:8px; font-weight:600;">Title *</label>
            <input type="text" name="title" value="{{ target_offer ? target_offer.title : '' }}"
              class="form-control" style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);" required>
          </div>

          <div class="form-group" style="margin-bottom:20px;">
            <label style="display:block; margin-bottom:8px; font-weight:600;">Discount Type *</label>
            <select name="discountType" class="form-control" style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);" required>
              <option value="PERCENTAGE" {% if target_offer and target_offer.discountType == 'PERCENTAGE' %}selected{% endif %}>Percentage (%)</option>
              <option value="FIXED"      {% if target_offer and target_offer.discountType == 'FIXED'      %}selected{% endif %}>Fixed Amount (€)</option>
            </select>
          </div>

          <div class="form-group" style="margin-bottom:20px;">
            <label style="display:block; margin-bottom:8px; font-weight:600;">Discount Value *</label>
            <input type="number" step="0.01" name="discountValue" value="{{ target_offer ? target_offer.discountValue : '' }}"
              class="form-control" style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);" required>
          </div>

          <div class="form-group" style="margin-bottom:20px;">
            <label style="display:block; margin-bottom:8px; font-weight:600;">Apply to Pack</label>
            <select name="packId" class="form-control" style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);">
              <option value="">— No specific pack —</option>
              {% for pack in packs %}
                <option value="{{ pack.idPack }}" {% if target_offer and target_offer.packId == pack.idPack %}selected{% endif %}>
                   {{ pack.title }}
                </option>
              {% endfor %}
            </select>
          </div>

          <div class="form-group" style="margin-bottom:20px;">
            <label style="display:block; margin-bottom:8px; font-weight:600;">Start Date *</label>
            <input type="date" name="startDate" value="{{ target_offer ? target_offer.startDate|date('Y-m-d') : '' }}"
              class="form-control" style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);" required>
          </div>

          <div class="form-group" style="margin-bottom:20px;">
            <label style="display:block; margin-bottom:8px; font-weight:600;">End Date *</label>
            <input type="date" name="endDate" value="{{ target_offer ? target_offer.endDate|date('Y-m-d') : '' }}"
              class="form-control" style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);" required>
          </div>

          <div class="form-group" style="margin-bottom:20px;">
            <label style="display:block; margin-bottom:8px; font-weight:600;">Active</label>
            <select name="isActive" class="form-control" style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);">
              <option value="1" {% if not target_offer or target_offer.isActive %}selected{% endif %}>Yes</option>
              <option value="0" {% if target_offer and not target_offer.isActive %}selected{% endif %}>No</option>
            </select>
          </div>

        </div>

        <div class="form-group" style="margin-bottom:20px;">
          <label style="display:block; margin-bottom:8px; font-weight:600;">Description</label>
          <textarea name="description" rows="3" class="form-control"
            style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);">{{ target_offer ? target_offer.description : '' }}</textarea>
        </div>

        <div style="display:flex; gap:12px; margin-top:32px;">
          <button type="submit" class="btn btn-primary" style="flex:1;">Save Offer</button>
          <a href="{{ path('admin_offers') }}" class="btn btn-secondary" style="flex:1; text-align:center;">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
{% endblock %}
