{% extends 'admin/admin_base.html.twig' %}
{% block title %}Edit Booking — TripX Admin{% endblock %}

{% block breadcrumbs %}
  <a href="{{ path('admin_dashboard') }}" class="crumb">Dashboard</a>
  <span class="sep">›</span>
  <a href="{{ path('admin_bookings') }}" class="crumb">Bookings</a>
  <span class="sep">›</span>
  <span class="crumb active">Edit #{{ target_booking.bookingReference }}</span>
{% endblock %}

{% block content %}
<div class="reveal">
  <div style="margin-bottom:32px;">
    <h1 class="display-sm" style="margin-bottom:4px">Edit Booking</h1>
    <p class="text-muted" style="font-size:14px">Reference: <strong>{{ target_booking.bookingReference }}</strong> · Destination: <strong>{{ destName }}</strong></p>
  </div>

  <div class="card reveal" style="max-width: 800px;">
    <div class="card-body">
      {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
          <div class="form-group" style="margin-bottom: 20px;">
            <label style="display:block; margin-bottom:8px; font-weight:600;">User Email</label>
            <input type="text" value="{{ target_booking.userEmail|default('—') }}" class="form-control" style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);" disabled>
          </div>

          <div class="form-group" style="margin-bottom: 20px;">
            <label style="display:block; margin-bottom:8px; font-weight:600;">Destination</label>
            <input type="text" value="{{ destName }}" class="form-control" style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);" disabled>
          </div>

          <div class="form-group" style="margin-bottom: 20px;">
            {{ form_label(form.status, 'Status *', {'label_attr': {'style': 'display:block; margin-bottom:8px; font-weight:600;'}}) }}
            {{ form_widget(form.status, {'attr': {'class': 'form-control', 'style': 'width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);'}}) }}
            <div style="color: red; font-size: 13px; margin-top: 4px;">{{ form_errors(form.status) }}</div>
          </div>

          <div class="form-group" style="margin-bottom: 20px;">
            {{ form_label(form.paymentStatus, 'Payment Status *', {'label_attr': {'style': 'display:block; margin-bottom:8px; font-weight:600;'}}) }}
            {{ form_widget(form.paymentStatus, {'attr': {'class': 'form-control', 'style': 'width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);'}}) }}
            <div style="color: red; font-size: 13px; margin-top: 4px;">{{ form_errors(form.paymentStatus) }}</div>
          </div>

          <div class="form-group" style="margin-bottom: 20px;">
            {{ form_label(form.numGuests, 'Number of Guests', {'label_attr': {'style': 'display:block; margin-bottom:8px; font-weight:600;'}}) }}
            {{ form_widget(form.numGuests, {'attr': {'class': 'form-control', 'style': 'width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);'}}) }}
            <div style="color: red; font-size: 13px; margin-top: 4px;">{{ form_errors(form.numGuests) }}</div>
          </div>

          <div class="form-group" style="margin-bottom: 20px;">
            {{ form_label(form.totalAmount, 'Total Amount (€)', {'label_attr': {'style': 'display:block; margin-bottom:8px; font-weight:600;'}}) }}
            {{ form_widget(form.totalAmount, {'attr': {'class': 'form-control', 'style': 'width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);'}}) }}
            <div style="color: red; font-size: 13px; margin-top: 4px;">{{ form_errors(form.totalAmount) }}</div>
          </div>
        </div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:20px;">
          <div>
            <label style="display:block; margin-bottom:8px; font-weight:600;">Start Date</label>
            <input type="text" value="{{ target_booking.startAt|date('M d, Y') }}" class="form-control" style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);" disabled>
          </div>
          <div>
            <label style="display:block; margin-bottom:8px; font-weight:600;">End Date</label>
            <input type="text" value="{{ target_booking.endAt ? target_booking.endAt|date('M d, Y') : '—' }}" class="form-control" style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);" disabled>
          </div>
        </div>

        <div class="form-group" style="margin-bottom: 20px;">
          {{ form_label(form.notes, 'Notes', {'label_attr': {'style': 'display:block; margin-bottom:8px; font-weight:600;'}}) }}
          {{ form_widget(form.notes, {'attr': {'rows': '4', 'class': 'form-control', 'style': 'width:100%; padding:10px; border-radius:8px; border:1px solid var(--border-color); background:var(--bg-card); color:var(--text-primary);'}}) }}
          <div style="color: red; font-size: 13px; margin-top: 4px;">{{ form_errors(form.notes) }}</div>
        </div>

        <div style="display:flex; gap:12px; margin-top:32px;">
          <button type="submit" class="btn btn-primary" style="flex:1;">Save Changes</button>
          <a href="{{ path('admin_bookings') }}" class="btn btn-secondary" style="flex:1; text-align:center;">Cancel</a>
        </div>
      {{ form_end(form) }}
    </div>
  </div>
</div>
{% endblock %}
