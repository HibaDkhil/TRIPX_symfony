{% block page_scripts %}
<script>
const AJAX_H  = { 'X-Requested-With': 'XMLHttpRequest' };
const ACC_ID  = {{ acc.id }};
const BASE    = `/admin/accommodations/${ACC_ID}/rooms`;
const NEW_URL = `${BASE}/new`;
const VIEW_URL  = (id) => `${BASE}/${id}`;
const EDIT_URL  = (id) => `${BASE}/${id}/edit`;
const DEL_URL   = (id) => `${BASE}/${id}/delete`;
const IMG_UP    = (id) => `${BASE}/${id}/images/upload`;
const IMG_PRI   = (id, imgId) => `${BASE}/${id}/images/${imgId}/primary`;
const IMG_DEL   = (id, imgId) => `${BASE}/${id}/images/${imgId}/delete`;
const IMG_REORD = (id) => `${BASE}/${id}/images/reorder`;

// ── Carousel ──────────────────────────────────────────────
const carouselState = {};
const carouselTimers = {};

function carouselInit(roomId, total, primaryIndex) {
  carouselState[roomId] = { current: primaryIndex || 0, total };
  const track = document.getElementById(`track-${roomId}`);
  if (track && primaryIndex > 0) {
    track.style.transition = 'none';
    track.style.transform = `translateX(-${primaryIndex * 100}%)`;
    setTimeout(() => { if(track) track.style.transition = ''; }, 50);
    document.querySelectorAll(`#dots-${roomId} .carousel-dot`).forEach((d, i) => {
      d.classList.toggle('active', i === primaryIndex);
    });
  }
  if (total > 1) {
    if (carouselTimers[roomId]) clearInterval(carouselTimers[roomId]);
    carouselTimers[roomId] = setInterval(() => carouselNext(roomId), 4000);
  }
}

function carouselGoTo(roomId, idx) {
  const state = carouselState[roomId];
  if (!state) return;
  state.current = ((idx % state.total) + state.total) % state.total;
  const track = document.getElementById(`track-${roomId}`);
  if (track) track.style.transform = `translateX(-${state.current * 100}%)`;
  document.querySelectorAll(`#dots-${roomId} .carousel-dot`).forEach((d, i) => {
    d.classList.toggle('active', i === state.current);
  });
  if (carouselTimers[roomId]) {
    clearInterval(carouselTimers[roomId]);
    if (state.total > 1) carouselTimers[roomId] = setInterval(() => carouselNext(roomId), 4000);
  }
}
function carouselNext(roomId) { const s = carouselState[roomId]; if(s) carouselGoTo(roomId, s.current + 1); }
function carouselPrev(roomId) { const s = carouselState[roomId]; if(s) carouselGoTo(roomId, s.current - 1); }

async function refreshRoomCard(roomId) {
  try {
    const res = await fetch(VIEW_URL(roomId), { headers: AJAX_H });
    const data = await res.json();
    
    const card = document.getElementById(`room-card-${roomId}`);
    if (!card) return;
    
    // Update availability badge
    const availBadge = card.querySelector('.avail-badge');
    if (availBadge) {
      availBadge.className = `avail-badge ${data.isAvailable ? 'avail-yes' : 'avail-no'}`;
      availBadge.textContent = data.isAvailable ? 'Available' : 'Unavailable';
    }
    
    // Update room name
    const nameEl = card.querySelector('.room-name');
    if (nameEl) nameEl.textContent = data.roomName;
    
    // Update room type
    const typeEl = card.querySelector('.room-type-pill');
    if (typeEl) {
      if (data.roomType) {
        typeEl.textContent = data.roomType;
        typeEl.style.display = 'inline-block';
      } else {
        typeEl.style.display = 'none';
      }
    }
    
    // Update info row
    const infoRow = card.querySelector('.room-info-row');
    if (infoRow) {
      let infoHtml = '';
      if (data.capacity) infoHtml += `<span class="room-info-item">👥 ${data.capacity} person(s)</span>`;
      if (data.size) infoHtml += `<span class="room-info-item">📐 ${data.size} m²</span>`;
      infoRow.innerHTML = infoHtml;
    }
    
    // Update price
    const priceEl = card.querySelector('.room-price');
    if (priceEl) {
      if (data.pricePerNight) {
        priceEl.innerHTML = `€${parseFloat(data.pricePerNight).toFixed(2)} <span style="font-size:13px;font-weight:400;color:var(--text-muted)">/ night</span>`;
      } else {
        priceEl.innerHTML = '';
      }
    }
    
    // Update amenities
    const amenitiesEl = card.querySelector('.room-amenities');
    if (amenitiesEl && data.amenities) {
      const amenities = data.amenities.split(',').map(a => a.trim());
      let amenitiesHtml = '';
      amenities.slice(0, 4).forEach(am => {
        amenitiesHtml += `<span class="room-amenity-tag">${am}</span>`;
      });
      if (amenities.length > 4) {
        amenitiesHtml += `<span class="room-amenity-tag" style="color:var(--text-muted)">+${amenities.length - 4} more</span>`;
      }
      amenitiesEl.innerHTML = amenitiesHtml;
    }
    
    // Update images
    const images = data.images || [];
    const trackDiv = card.querySelector('.carousel-track');
    const dotsContainer = card.querySelector('.carousel-dots');
    const countDiv = card.querySelector('.carousel-count');
    
    if (trackDiv) {
      if (images.length > 0) {
        const imgSrc = (path) => {
          if (!path) return '';
          if (path.startsWith('http')) return path;
          return '/' + path.replace(/^\/+/, '');
        };
        
        trackDiv.innerHTML = images.map(img => `
          <div class="carousel-slide">
            <img src="${imgSrc(img.filePath)}" alt="${data.roomName}" loading="lazy">
          </div>
        `).join('');
        
        if (dotsContainer && images.length > 1) {
          dotsContainer.innerHTML = images.map((_, i) => `
            <div class="carousel-dot ${i === 0 ? 'active' : ''}" onclick="carouselGoTo('${roomId}', ${i})"></div>
          `).join('');
        } else if (dotsContainer && images.length <= 1) {
          dotsContainer.innerHTML = '';
        }
        
        if (countDiv) {
          countDiv.textContent = `${images.length} 📷`;
        }
        
        const primaryIndex = images.findIndex(img => img.isPrimary);
        const newTotal = images.length;
        
        if (carouselTimers[roomId]) {
          clearInterval(carouselTimers[roomId]);
          delete carouselTimers[roomId];
        }
        
        carouselState[roomId] = { current: primaryIndex >= 0 ? primaryIndex : 0, total: newTotal };
        
        trackDiv.style.transition = 'none';
        trackDiv.style.transform = `translateX(-${carouselState[roomId].current * 100}%)`;
        setTimeout(() => { trackDiv.style.transition = ''; }, 50);
        
        document.querySelectorAll(`#dots-${roomId} .carousel-dot`).forEach((d, i) => {
          d.classList.toggle('active', i === carouselState[roomId].current);
        });
        
        if (newTotal > 1) {
          carouselTimers[roomId] = setInterval(() => carouselNext(roomId), 4000);
        }
      } else {
        trackDiv.innerHTML = `<div class="carousel-slide"><div class="no-img">🛏️</div></div>`;
        if (dotsContainer) dotsContainer.innerHTML = '';
        if (countDiv) countDiv.innerHTML = '';
        carouselState[roomId] = { current: 0, total: 0 };
        if (carouselTimers[roomId]) {
          clearInterval(carouselTimers[roomId]);
          delete carouselTimers[roomId];
        }
      }
    }
    
    // Update stats after card refresh
    updateStats();
    
  } catch(e) {
    console.error('Failed to refresh room card:', e);
  }
}

// Init all carousels
{% for rd in roomsData %}
  {% set primaryIndex = 0 %}
  {% for img in rd.allImages %}{% if img.isPrimary %}{% set primaryIndex = loop.index0 %}{% endif %}{% endfor %}
  {% if rd.allImages|length > 0 %}
  carouselInit('{{ rd.room.id }}', {{ rd.allImages|length }}, {{ primaryIndex }});
  {% endif %}
{% endfor %}

// ── Drawer ────────────────────────────────────────────────
let editingId   = null;
let pendingFiles = [];

function openDrawer(id = null) {
  editingId = id;
  document.getElementById('drawer-title').textContent = id ? 'Edit Room' : 'Add Room';
  if (!id) resetForm();
  document.getElementById('drawer-overlay').classList.add('open');
  document.getElementById('drawer').classList.add('open');
}
function closeDrawer() {
  document.getElementById('drawer-overlay').classList.remove('open');
  document.getElementById('drawer').classList.remove('open');
  pendingFiles = [];
}
function resetForm() {
  ['roomName','roomType','pricePerNight','capacity','size','f-custom-amenities'].forEach(id => {
    const el = document.getElementById(id.startsWith('f-') ? id : 'f-' + id);
    if (el) el.value = '';
  });
  document.getElementById('f-isAvailable').value = '1';
  document.querySelectorAll('.room-amenity-cb').forEach(cb => cb.checked = false);
  document.getElementById('img-thumbs-preview').innerHTML = '';
  document.getElementById('f-images').value = '';
  pendingFiles = [];
  
  document.querySelectorAll('.form-input, .form-select').forEach(el => {
    el.style.borderColor = '';
    el.style.borderWidth = '';
  });
}

// ── Image preview in drawer ───────────────────────────────
function previewImages(files) {
  pendingFiles = [...pendingFiles, ...files];
  renderPreviews();
}
function handleDrop(e) {
  e.preventDefault();
  document.getElementById('drop-zone').classList.remove('dragover');
  const files = Array.from(e.dataTransfer.files).filter(f => f.type.startsWith('image/'));
  pendingFiles = [...pendingFiles, ...files];
  renderPreviews();
}
function renderPreviews() {
  const container = document.getElementById('img-thumbs-preview');
  container.innerHTML = '';
  pendingFiles.forEach((f, i) => {
    const url  = URL.createObjectURL(f);
    const wrap = document.createElement('div');
    wrap.className = 'img-thumb-wrap' + (i === 0 ? ' primary' : '');
    wrap.innerHTML = `<img src="${url}" alt=""><button class="img-thumb-del" onclick="removePendingFile(${i})">✕</button>`;
    container.appendChild(wrap);
  });
  if (pendingFiles.length > 0) {
    const info = document.createElement('div');
    info.style.cssText = 'width:100%;font-size:12px;color:var(--text-muted);margin-top:6px;';
    info.textContent = `${pendingFiles.length} image(s) selected. First one will be set as primary.`;
    container.appendChild(info);
  }
}
function removePendingFile(i) {
  pendingFiles.splice(i, 1);
  renderPreviews();
}

// ── Validation helper functions ───────────────────────────
function validateRoomName(name) {
  if (!name || name.trim().length === 0) {
    return { valid: false, message: 'Room name is required' };
  }
  if (name.trim().length < 2) {
    return { valid: false, message: 'Room name must be at least 2 characters' };
  }
  if (name.trim().length > 100) {
    return { valid: false, message: 'Room name cannot exceed 100 characters' };
  }
  return { valid: true, message: '' };
}

function validateRoomType(type) {
  if (!type || type.trim().length === 0) {
    return { valid: false, message: 'Room type is required' };
  }
  const validTypes = ['Single Room', 'Double Room', 'Twin Room', 'Suite', 'Family Room', 'Deluxe Room', 'Penthouse', 'Studio'];
  if (!validTypes.includes(type)) {
    return { valid: false, message: 'Please select a valid room type' };
  }
  return { valid: true, message: '' };
}

function validatePrice(price) {
  if (!price || price.toString().trim().length === 0) {
    return { valid: false, message: 'Price per night is required' };
  }
  const priceNum = parseFloat(price);
  if (isNaN(priceNum)) {
    return { valid: false, message: 'Price per night must be a valid number' };
  }
  if (priceNum <= 0) {
    return { valid: false, message: 'Price per night must be a positive number' };
  }
  if (priceNum > 100000) {
    return { valid: false, message: 'Price per night cannot exceed 100,000' };
  }
  return { valid: true, message: '' };
}

function validateCapacity(capacity) {
  if (!capacity || capacity.toString().trim().length === 0) {
    return { valid: false, message: 'Capacity is required' };
  }
  const capacityNum = parseInt(capacity);
  if (isNaN(capacityNum)) {
    return { valid: false, message: 'Capacity must be a valid number' };
  }
  if (capacityNum < 1) {
    return { valid: false, message: 'Capacity must be at least 1 person' };
  }
  if (capacityNum > 50) {
    return { valid: false, message: 'Capacity cannot exceed 50 persons' };
  }
  return { valid: true, message: '' };
}

function validateSize(size) {
  if (!size || size.toString().trim().length === 0) {
    return { valid: false, message: 'Room size is required' };
  }
  const sizeNum = parseFloat(size);
  if (isNaN(sizeNum)) {
    return { valid: false, message: 'Size must be a valid number' };
  }
  if (sizeNum <= 0) {
    return { valid: false, message: 'Size must be greater than 0' };
  }
  if (sizeNum > 1000) {
    return { valid: false, message: 'Size cannot exceed 1000 m²' };
  }
  return { valid: true, message: '' };
}

// ── Save room ─────────────────────────────────────────────
async function saveRoom() {
  const name = document.getElementById('f-roomName').value.trim();
  const type = document.getElementById('f-roomType').value;
  const price = document.getElementById('f-pricePerNight').value.trim();
  const capacity = document.getElementById('f-capacity').value.trim();
  const size = document.getElementById('f-size').value.trim();
  
  document.querySelectorAll('.form-input, .form-select').forEach(el => {
    el.style.borderColor = '';
    el.style.borderWidth = '';
  });
  
  const nameValidation = validateRoomName(name);
  if (!nameValidation.valid) {
    showToast('❌ ' + nameValidation.message, 'error');
    const nameField = document.getElementById('f-roomName');
    nameField.style.borderColor = '#ef4444';
    nameField.style.borderWidth = '2px';
    nameField.focus();
    return;
  }
  
  const typeValidation = validateRoomType(type);
  if (!typeValidation.valid) {
    showToast('❌ ' + typeValidation.message, 'error');
    const typeField = document.getElementById('f-roomType');
    typeField.style.borderColor = '#ef4444';
    typeField.style.borderWidth = '2px';
    typeField.focus();
    return;
  }
  
  const priceValidation = validatePrice(price);
  if (!priceValidation.valid) {
    showToast('❌ ' + priceValidation.message, 'error');
    const priceField = document.getElementById('f-pricePerNight');
    priceField.style.borderColor = '#ef4444';
    priceField.style.borderWidth = '2px';
    priceField.focus();
    return;
  }
  
  const capacityValidation = validateCapacity(capacity);
  if (!capacityValidation.valid) {
    showToast('❌ ' + capacityValidation.message, 'error');
    const capacityField = document.getElementById('f-capacity');
    capacityField.style.borderColor = '#ef4444';
    capacityField.style.borderWidth = '2px';
    capacityField.focus();
    return;
  }
  
  const sizeValidation = validateSize(size);
  if (!sizeValidation.valid) {
    showToast('❌ ' + sizeValidation.message, 'error');
    const sizeField = document.getElementById('f-size');
    sizeField.style.borderColor = '#ef4444';
    sizeField.style.borderWidth = '2px';
    sizeField.focus();
    return;
  }

  const btn = document.getElementById('save-btn');
  const originalText = btn.textContent;
  btn.textContent = '⏳ Saving…'; 
  btn.disabled = true;

  const checked = [...document.querySelectorAll('.room-amenity-cb:checked')].map(c => c.value);
  const custom  = document.getElementById('f-custom-amenities').value.split(',').map(s => s.trim()).filter(Boolean);
  const amenities = [...checked, ...custom].join(',');

  const fd = new FormData();
  fd.append('roomName',      name);
  fd.append('roomType',      type);
  fd.append('isAvailable',   document.getElementById('f-isAvailable').value);
  fd.append('pricePerNight', parseFloat(price));
  fd.append('capacity',      parseInt(capacity));
  fd.append('size',          size);
  fd.append('amenities',     amenities);
  
  pendingFiles.forEach(f => fd.append('images[]', f));

  const url = editingId ? EDIT_URL(editingId) : NEW_URL;
  try {
    const res  = await fetch(url, { method: 'POST', body: fd, headers: AJAX_H });
    const data = await res.json();
    
    if (data.success) {
      showToast('✅ ' + data.message, 'success');
      closeDrawer();
      
      if (editingId) {
        await refreshRoomCard(editingId);
        await loadAiInsights();
      } else {
        // Add new room without page refresh
        await addNewRoomCard(data.id);
        await loadAiInsights();
      }
    } else {
      if (data.errors) {
        let errorMsg = "❌ Validation failed:\n\n";
        for (const [field, msg] of Object.entries(data.errors)) {
          let fieldLabel = field;
          const labels = {
            'roomName': 'Room Name',
            'roomType': 'Room Type',
            'pricePerNight': 'Price per Night',
            'capacity': 'Capacity',
            'size': 'Size',
            'amenities': 'Amenities',
            'isAvailable': 'Availability'
          };
          fieldLabel = labels[field] || field;
          errorMsg += `• ${fieldLabel}: ${msg}\n`;
          
          let fieldId = field;
          if (field === 'pricePerNight') fieldId = 'pricePerNight';
          else if (field === 'roomName') fieldId = 'roomName';
          else if (field === 'capacity') fieldId = 'capacity';
          else if (field === 'size') fieldId = 'size';
          else if (field === 'roomType') fieldId = 'roomType';
          else if (field === 'isAvailable') fieldId = 'isAvailable';
          
          const fieldElement = document.getElementById(`f-${fieldId}`);
          if (fieldElement) {
            fieldElement.style.borderColor = '#ef4444';
            fieldElement.style.borderWidth = '2px';
            setTimeout(() => {
              fieldElement.style.borderColor = '';
              fieldElement.style.borderWidth = '';
            }, 3000);
          }
        }
        showToast(errorMsg, 'error');
      } else {
        showToast('❌ ' + (data.error || 'Error saving room'), 'error');
      }
    }
  } catch(e) { 
    showToast('❌ Network error: ' + e.message, 'error'); 
  }
  btn.textContent = originalText; 
  btn.disabled = false;
}

// ── Add new room card without page refresh ─────────────────
async function addNewRoomCard(roomId) {
  try {
    const res = await fetch(VIEW_URL(roomId), { headers: AJAX_H });
    const data = await res.json();
    
    const grid = document.getElementById('rooms-grid');
    
    // Remove empty state if present
    const emptyState = grid.querySelector('.empty-rooms');
    if (emptyState) emptyState.remove();
    
    // Create new card
    const card = document.createElement('div');
    card.className = 'room-card';
    card.id = `room-card-${roomId}`;
    
    // Build carousel HTML
    let carouselHtml = '';
    if (!data.images || data.images.length === 0) {
      carouselHtml = `
        <div class="carousel" id="carousel-${roomId}">
          <div class="carousel-track">
            <div class="carousel-slide"><div class="no-img">🛏️</div></div>
          </div>
          <span class="avail-badge ${data.isAvailable ? 'avail-yes' : 'avail-no'}">
            ${data.isAvailable ? 'Available' : 'Unavailable'}
          </span>
        </div>
      `;
    } else {
      const imgSrc = (path) => {
        if (!path) return '';
        if (path.startsWith('http')) return path;
        return '/' + path.replace(/^\/+/, '');
      };
      
      const slidesHtml = data.images.map(img => `
        <div class="carousel-slide">
          <img src="${imgSrc(img.filePath)}" alt="${data.roomName}" loading="lazy">
        </div>
      `).join('');
      
      const dotsHtml = data.images.length > 1 ? `
        <div class="carousel-dots" id="dots-${roomId}">
          ${data.images.map((_, i) => `
            <div class="carousel-dot ${i === 0 ? 'active' : ''}" onclick="carouselGoTo('${roomId}', ${i})"></div>
          `).join('')}
        </div>
        <button class="carousel-btn prev" onclick="carouselPrev('${roomId}')">‹</button>
        <button class="carousel-btn next" onclick="carouselNext('${roomId}')">›</button>
        <div class="carousel-count">${data.images.length} 📷</div>
      ` : '';
      
      carouselHtml = `
        <div class="carousel" id="carousel-${roomId}">
          <div class="carousel-track" id="track-${roomId}">
            ${slidesHtml}
          </div>
          ${dotsHtml}
          <span class="avail-badge ${data.isAvailable ? 'avail-yes' : 'avail-no'}">
            ${data.isAvailable ? 'Available' : 'Unavailable'}
          </span>
        </div>
      `;
    }
    
    // Build amenities HTML
    let amenitiesHtml = '';
    if (data.amenities) {
      const amenities = data.amenities.split(',').map(a => a.trim());
      amenities.slice(0, 4).forEach(am => {
        amenitiesHtml += `<span class="room-amenity-tag">${am}</span>`;
      });
      if (amenities.length > 4) {
        amenitiesHtml += `<span class="room-amenity-tag" style="color:var(--text-muted)">+${amenities.length - 4} more</span>`;
      }
    }
    
    // Build info row
    let infoRowHtml = '';
    if (data.capacity) infoRowHtml += `<span class="room-info-item">👥 ${data.capacity} person(s)</span>`;
    if (data.size) infoRowHtml += `<span class="room-info-item">📐 ${data.size} m²</span>`;
    
    card.innerHTML = `
      ${carouselHtml}
      <div class="room-body">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:6px;">
          <div class="room-name">${data.roomName}</div>
          <div style="display: flex; gap: 6px;">
            ${data.roomType ? `<span class="room-type-pill">${data.roomType}</span>` : ''}
            <span class="room-quality-badge" id="quality-badge-${roomId}" style="display: none;"></span>
          </div>
        </div>
        <div class="room-info-row">
          ${infoRowHtml}
        </div>
        ${data.pricePerNight ? `
        <div class="room-price">€${parseFloat(data.pricePerNight).toFixed(2)} <span style="font-size:13px;font-weight:400;color:var(--text-muted)">/ night</span></div>
        ` : ''}
        ${amenitiesHtml ? `<div class="room-amenities">${amenitiesHtml}</div>` : ''}
        <div class="room-actions">
          <button class="room-btn rb-images" onclick="openImgMgr(${roomId}, '${data.roomName.replace(/'/g, "\\'")}')">🖼 Images (${data.images ? data.images.length : 0})</button>
          <button class="room-btn rb-edit" onclick="editRoom(${roomId})">✏️ Edit</button>
          <button class="room-btn rb-del" onclick="confirmDel(${roomId}, '${data.roomName.replace(/'/g, "\\'")}')">🗑</button>
        </div>
      </div>
    `;
    
    grid.appendChild(card);
    
    // Initialize carousel if there are images
    if (data.images && data.images.length > 0) {
      const primaryIndex = data.images.findIndex(img => img.isPrimary);
      carouselInit(roomId.toString(), data.images.length, primaryIndex >= 0 ? primaryIndex : 0);
    }
    
    // Update stats
    updateStats();
    
  } catch(e) {
    console.error('Failed to add new room card:', e);
    // Fallback to page reload if something goes wrong
    location.reload();
  }
}

// ── Edit room ─────────────────────────────────────────────
async function editRoom(id) {
  try {
    const res = await fetch(VIEW_URL(id), { headers: AJAX_H });
    const d   = await res.json();
    openDrawer(id);
    setTimeout(() => {
      document.getElementById('f-roomName').value      = d.roomName || '';
      document.getElementById('f-roomType').value      = d.roomType || '';
      document.getElementById('f-isAvailable').value   = d.isAvailable ? '1' : '0';
      document.getElementById('f-pricePerNight').value = d.pricePerNight || '';
      document.getElementById('f-capacity').value      = d.capacity || '';
      document.getElementById('f-size').value          = d.size || '';
      if (d.amenities) {
        const list = d.amenities.split(',').map(s => s.trim());
        document.querySelectorAll('.room-amenity-cb').forEach(cb => { cb.checked = list.includes(cb.value); });
      }
      document.querySelectorAll('.form-input, .form-select').forEach(el => {
        el.style.borderColor = '';
        el.style.borderWidth = '';
      });
    }, 80);
  } catch(e) { showToast('❌ Failed to load room', 'error'); }
}

// ── Delete ────────────────────────────────────────────────
let deleteId = null;
function confirmDel(id, name) {
  deleteId = id;
  document.getElementById('del-name').textContent = name;
  document.getElementById('del-overlay').classList.add('open');
}
function closeDel() { document.getElementById('del-overlay').classList.remove('open'); deleteId = null; }
async function doDelete() {
  if (!deleteId) return;
  try {
    const res  = await fetch(DEL_URL(deleteId), { method: 'POST', headers: AJAX_H });
    const data = await res.json();
    if (data.success) {
      showToast('✅ ' + data.message, 'success');
      closeDel();
      
      // Remove the card from DOM
      const card = document.getElementById(`room-card-${deleteId}`);
      if (card) {
        card.remove();
      }
      
      // Update stats
      updateStats();
      
      // Refresh AI insights
      await loadAiInsights();
      
      // Check if grid is empty
      const grid = document.getElementById('rooms-grid');
      const remainingCards = grid.querySelectorAll('.room-card');
      if (remainingCards.length === 0) {
        grid.innerHTML = `
          <div class="empty-rooms" style="grid-column:1/-1">
            <div class="ei">🛏️</div>
            <h3 style="font-family:var(--font-display);margin-bottom:8px">No rooms yet</h3>
            <p>Click "Add Room" to create the first room for this accommodation.</p>
          </div>
        `;
      }
    } else { 
      showToast('❌ ' + (data.error || 'Delete failed'), 'error'); 
    }
  } catch(e) { 
    showToast('❌ Network error: ' + e.message, 'error'); 
  }
}

function updateStats() {
  const cards = document.querySelectorAll('.room-card');
  const total = cards.length;
  const available = document.querySelectorAll('.avail-yes').length;
  const unavailable = total - available;
  
  const totalEl = document.getElementById('stat-total');
  const availEl = document.getElementById('stat-avail');
  const unavailEl = document.getElementById('stat-unavail');
  
  if (totalEl) totalEl.textContent = total;
  if (availEl) availEl.textContent = available;
  if (unavailEl) unavailEl.textContent = unavailable;
}

// ── Image Manager ─────────────────────────────────────────
let imgMgrRoomId  = null;
let imgMgrCurrent = 0;
let imgMgrImages  = [];

async function openImgMgr(roomId, roomName) {
  imgMgrRoomId = roomId;
  document.getElementById('imgmgr-room-name').textContent = roomName;
  document.getElementById('imgmgr-overlay').classList.add('open');
  await loadImgMgr();
}
function closeImgMgr() {
  document.getElementById('imgmgr-overlay').classList.remove('open');
  imgMgrRoomId = null; imgMgrImages = []; imgMgrCurrent = 0;
}

async function loadImgMgr() {
  try {
    const res  = await fetch(VIEW_URL(imgMgrRoomId), { headers: AJAX_H });
    const data = await res.json();
    imgMgrImages  = data.images || [];
    imgMgrCurrent = 0;
    renderImgMgr();
  } catch(e) { showToast('❌ Failed to load images', 'error'); }
}

function renderImgMgr() {
  const track = document.getElementById('imgmgr-track');
  const thumbs = document.getElementById('imgmgr-thumbs');
  const count  = document.getElementById('imgmgr-count');

  if (imgMgrImages.length === 0) {
    track.innerHTML = `<div class="carousel-slide"><div style="height:300px;display:flex;align-items:center;justify-content:center;font-size:64px;color:var(--text-muted)">📷</div></div>`;
    thumbs.innerHTML = `<div style="color:var(--text-muted);font-size:13px;padding:8px">No images yet. Upload some!</div>`;
    count.textContent = '0 / 0';
    return;
  }

  const imgSrc = (path) => {
    if (!path) return '';
    if (path.startsWith('http')) return path;
    return '/' + path.replace(/^\/+/, '');
  };

  track.innerHTML = imgMgrImages.map(img =>
    `<div class="carousel-slide"><img src="${imgSrc(img.filePath)}" alt="" style="width:100%;height:300px;object-fit:cover;"></div>`
  ).join('');
  track.style.transform = `translateX(-${imgMgrCurrent * 100}%)`;
  count.textContent = `${imgMgrCurrent + 1} / ${imgMgrImages.length}`;

  thumbs.innerHTML = imgMgrImages.map((img, i) => `
    <div class="imgmgr-thumb ${i === imgMgrCurrent ? 'active' : ''} ${img.isPrimary ? 'primary-thumb' : ''}" onclick="imgMgrGoTo(${i})">
      <img src="${imgSrc(img.filePath)}" alt="">
      <div class="imgmgr-thumb-actions">
        <button class="imgmgr-thumb-btn" onclick="event.stopPropagation();setPrimary(${img.id})" title="Set as primary">★</button>
        <button class="imgmgr-thumb-btn" style="background:rgba(239,68,68,.9);color:#fff;" onclick="event.stopPropagation();deleteImage(${img.id})" title="Delete">🗑</button>
      </div>
    </div>`).join('');
}

function imgMgrGoTo(i) {
  imgMgrCurrent = (i + imgMgrImages.length) % imgMgrImages.length;
  const track = document.getElementById('imgmgr-track');
  track.style.transform = `translateX(-${imgMgrCurrent * 100}%)`;
  document.getElementById('imgmgr-count').textContent = `${imgMgrCurrent + 1} / ${imgMgrImages.length}`;
  document.querySelectorAll('.imgmgr-thumb').forEach((t, idx) => t.classList.toggle('active', idx === imgMgrCurrent));
}
function imgMgrNext() { imgMgrGoTo(imgMgrCurrent + 1); }
function imgMgrPrev() { imgMgrGoTo(imgMgrCurrent - 1); }

async function setPrimary(imgId) {
  try {
    const res  = await fetch(IMG_PRI(imgMgrRoomId, imgId), { method: 'POST', headers: AJAX_H });
    const data = await res.json();
    if (data.success) {
      showToast('✅ Primary image updated', 'success');
      imgMgrImages.forEach(img => img.isPrimary = (img.id === imgId));
      renderImgMgr();
      await refreshRoomCard(imgMgrRoomId);
      await loadAiInsights();
    } else showToast('❌ ' + (data.error || 'Error'), 'error');
  } catch(e) { showToast('❌ Error setting primary image', 'error'); }
}

async function deleteImage(imgId) {
  if (!confirm('Delete this image?')) return;
  try {
    const res  = await fetch(IMG_DEL(imgMgrRoomId, imgId), { method: 'POST', headers: AJAX_H });
    const data = await res.json();
    if (data.success) { 
      showToast('✅ Image deleted', 'success'); 
      await loadImgMgr();
      await refreshRoomCard(imgMgrRoomId);
      await loadAiInsights();
    }
    else showToast('❌ ' + (data.error || 'Delete failed'), 'error');
  } catch(e) { showToast('❌ Error deleting image', 'error'); }
}

async function uploadMoreImages(files) {
  if (!files || !files.length) return;
  showToast(`📤 Uploading ${files.length} image(s)…`, 'success');
  const fd = new FormData();
  files.forEach(f => fd.append('images[]', f));
  try {
    const res  = await fetch(IMG_UP(imgMgrRoomId), { method: 'POST', body: fd, headers: AJAX_H });
    const data = await res.json();
    if (data.success) { 
      showToast('✅ ' + data.message, 'success'); 
      await loadImgMgr();
      await refreshRoomCard(imgMgrRoomId);
      await loadAiInsights();
    }
    else showToast('❌ ' + (data.error || 'Upload failed'), 'error');
  } catch(e) { showToast('❌ Upload failed: ' + e.message, 'error'); }
}

// ── Toast ─────────────────────────────────────────────────
function showToast(msg, type = 'success') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = `toast ${type} show`;
  setTimeout(() => t.classList.remove('show'), 4000);
}

// ── Keyboard shortcuts ────────────────────────────────────
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') { closeDrawer(); closeImgMgr(); closeDel(); }
  if (e.key === 'ArrowRight' && imgMgrImages.length) imgMgrNext();
  if (e.key === 'ArrowLeft'  && imgMgrImages.length) imgMgrPrev();
});

// ── Drop zone event listeners ────────────────────────────
const dropZone = document.getElementById('drop-zone');
if (dropZone) {
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('dragover');
  });
  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('dragover');
  });
  dropZone.addEventListener('drop', handleDrop);
}

// ── AI Insights Functions ─────────────────────────────────
async function loadAiInsights() {
    const panel = document.getElementById('ai-panel');
    const content = document.getElementById('ai-content');
    const refreshBtn = document.getElementById('ai-refresh-btn');
    
    panel.style.display = 'block';
    content.innerHTML = '<div style="text-align: center; padding: 40px; color: var(--text-muted);">Analyzing rooms...</div>';
    
    if (refreshBtn) {
        refreshBtn.disabled = true;
        refreshBtn.textContent = 'Loading...';
    }
    
    try {
        const response = await fetch(`/admin/accommodations/${ACC_ID}/rooms/insights`, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });
        const data = await response.json();
        
        if (data.summary) {
            renderAiInsights(data);
        } else {
            content.innerHTML = '<div style="text-align: center; padding: 40px; color: var(--text-muted);">No insights available. Add rooms to see analysis.</div>';
        }
    } catch (error) {
        console.error('AI insights error:', error);
        content.innerHTML = '<div style="text-align: center; padding: 40px; color: #ef4444;">Failed to load insights. Please try again.</div>';
    } finally {
        if (refreshBtn) {
            refreshBtn.disabled = false;
            refreshBtn.textContent = 'Refresh Analysis';
        }
    }
}

function renderAiInsights(data) {
    const summary = data.summary;
    const content = document.getElementById('ai-content');
    const modelBadge = document.getElementById('ai-model-badge');
    
    if (modelBadge && summary.aiInsights) {
        modelBadge.textContent = summary.aiInsights.model || 'AI Model';
    }
    
    let criticalHtml = '';
    let warningHtml = '';
    
    if (data.criticalIssues && data.criticalIssues.length > 0) {
        criticalHtml = `
            <div style="margin-bottom: 16px;">
                <div style="font-weight: 700; margin-bottom: 10px; color: #ef4444; font-size: 13px;">Critical Issues - Need Immediate Attention</div>
                <div class="ai-issues-list">
                    ${data.criticalIssues.map(issue => `
                        <div class="ai-issue-item ai-critical">
                            <div class="ai-issue-icon">⚠️</div>
                            <div class="ai-issue-content">
                                <div class="ai-issue-title">${escapeHtml(issue.roomName)}</div>
                                <div class="ai-issue-desc">${escapeHtml(issue.issues[0]?.message || 'Price anomaly detected')}</div>
                                <div class="ai-issue-suggestion">${escapeHtml(issue.issues[0]?.suggestion || 'Review pricing')}</div>
                            </div>
                        </div>
                    `).join('')}
                </div>
            </div>
        `;
    }
    
    if (data.warnings && data.warnings.length > 0) {
        warningHtml = `
            <div style="margin-bottom: 16px;">
                <div style="font-weight: 700; margin-bottom: 10px; color: #f59e0b; font-size: 13px;">Warnings - Recommended Actions</div>
                <div class="ai-issues-list">
                    ${data.warnings.slice(0, 5).map(warning => `
                        <div class="ai-issue-item ai-warning">
                            <div class="ai-issue-icon">ℹ️</div>
                            <div class="ai-issue-content">
                                <div class="ai-issue-title">${escapeHtml(warning.roomName)}</div>
                                <div class="ai-issue-desc">${escapeHtml(warning.issues[0]?.message || 'Quality improvement needed')}</div>
                                <div class="ai-issue-suggestion">${escapeHtml(warning.issues[0]?.suggestion || 'Take action to improve')}</div>
                            </div>
                        </div>
                    `).join('')}
                </div>
            </div>
        `;
    }
    
    let tipsHtml = '';
    if (data.tips && data.tips.length > 0) {
        tipsHtml = `
            <div style="margin-bottom: 16px;">
                <div style="font-weight: 700; margin-bottom: 10px; color: #10b981; font-size: 13px;">Quick Tips to Improve</div>
                <div class="ai-issues-list">
                    ${data.tips.map(tip => `
                        <div class="ai-issue-item">
                            <div class="ai-issue-icon">💡</div>
                            <div class="ai-issue-content">
                                <div class="ai-issue-desc" style="margin-bottom: 0;">${escapeHtml(tip)}</div>
                            </div>
                        </div>
                    `).join('')}
                </div>
            </div>
        `;
    }
    
   let insightHtml = '';
if (summary.aiInsights && summary.aiInsights.insights) {
    const formatted = summary.aiInsights.insights
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/\n\n/g, '</p><p>')
        .replace(/\n/g, '<br>');

    insightHtml = `
        <div class="ai-insight-text">
            <p>${formatted}</p>
            ${summary.aiInsights.generated === false ? '<div style="font-size: 10px; margin-top: 8px; opacity: 0.6;">Rule-based analysis (Gemini not configured)</div>' : ''}
        </div>
    `;
}
    
    content.innerHTML = `
        <div class="ai-stats-grid">
            <div class="ai-stat-card">
                <div class="ai-stat-value">${summary.totalRooms}</div>
                <div class="ai-stat-label">Total Rooms</div>
            </div>
            <div class="ai-stat-card">
                <div class="ai-stat-value">€${summary.avgPrice}</div>
                <div class="ai-stat-label">Avg Price / Night</div>
            </div>
            <div class="ai-stat-card ai-stat-critical">
                <div class="ai-stat-value">${summary.criticalCount}</div>
                <div class="ai-stat-label">Critical Issues</div>
            </div>
            <div class="ai-stat-card ai-stat-warning">
                <div class="ai-stat-value">${summary.warningCount}</div>
                <div class="ai-stat-label">Warnings</div>
            </div>
        </div>
        ${criticalHtml}
        ${warningHtml}
        ${tipsHtml}
        ${insightHtml}
    `;
    
    if (data.rooms) {
        updateRoomQualityBadges(data.rooms);
    }
}

function updateRoomQualityBadges(roomsData) {
    for (const roomId in roomsData) {
        const analysis = roomsData[roomId];
        const badge = document.getElementById(`quality-badge-${roomId}`);
        if (badge) {
            const score = analysis.qualityScore;
            badge.style.display = 'inline-block';
            badge.textContent = `${score}`;
            if (score >= 70) {
                badge.className = 'room-quality-badge high';
                badge.title = 'Good quality room';
            } else if (score >= 40) {
                badge.className = 'room-quality-badge medium';
                badge.title = 'Average quality - room for improvement';
            } else {
                badge.className = 'room-quality-badge low';
                badge.title = 'Needs attention - check pricing and amenities';
            }
        }
    }
}

function escapeHtml(str) {
    if (!str) return '';
    return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
}

// Load AI insights when page loads
document.addEventListener('DOMContentLoaded', function() {
    setTimeout(loadAiInsights, 500);
});
</script>
