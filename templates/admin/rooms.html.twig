{% extends 'admin/admin_base.html.twig' %}

{% block title %}Rooms — {{ acc.name }} — TripX Admin{% endblock %}

{% block breadcrumbs %}
  <a href="{{ path('admin_accommodations_index') }}" class="crumb">Accommodations</a>
  <span class="sep">›</span>
  <a href="{{ path('admin_accommodations_index') }}" class="crumb" onclick="history.back();return false;">{{ acc.name }}</a>
  <span class="sep">›</span>
  <span class="crumb active">Rooms</span>
{% endblock %}

{% block page_styles %}
  /* ── Header bar ── */
  .rooms-header {
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom:28px; flex-wrap:wrap; gap:16px;
  }
  .rooms-header-left h1 { font-family:var(--font-display); font-size:26px; font-weight:700; margin-bottom:4px; }
  .rooms-header-left p  { font-size:13px; color:var(--text-muted); }
  .rooms-stats { display:flex; gap:16px; flex-wrap:wrap; margin-bottom:28px; }
  .rstat {
    background:var(--bg-card); border:1px solid var(--border-color);
    border-radius:12px; padding:16px 22px; display:flex; align-items:center; gap:14px;
  }
  .rstat-icon { font-size:24px; }
  .rstat-val  { font-family:var(--font-display); font-size:24px; font-weight:700; color:var(--accent-primary); line-height:1; }
  .rstat-lbl  { font-size:11px; color:var(--text-muted); text-transform:uppercase; letter-spacing:.06em; }

  /* ── Rooms grid ── */
  .rooms-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(340px,1fr)); gap:24px; }

  /* ── Room card ── */
  .room-card {
    background:var(--bg-card); border:1px solid var(--border-color);
    border-radius:18px; overflow:hidden;
    transition:transform .25s,box-shadow .25s,border-color .25s;
  }
  .room-card:hover { transform:translateY(-5px); box-shadow:0 16px 40px rgba(0,0,0,.18); border-color:var(--accent-primary); }

  /* ── Carousel ── */
  .carousel { position:relative; height:220px; background:linear-gradient(135deg,#1e3a5f,#0a6587); overflow:hidden; }
  .carousel-track { display:flex; height:100%; transition:transform .4s cubic-bezier(.4,0,.2,1); }
  .carousel-slide { min-width:100%; height:100%; position:relative; flex-shrink:0; }
  .carousel-slide img { width:100%; height:100%; object-fit:cover; }
  .carousel-slide .no-img { width:100%; height:100%; display:flex; align-items:center; justify-content:center; font-size:64px; }
  .carousel-btn {
    position:absolute; top:50%; transform:translateY(-50%);
    width:34px; height:34px; background:rgba(0,0,0,.55); border:none;
    border-radius:50%; color:#fff; font-size:16px; cursor:pointer;
    display:flex; align-items:center; justify-content:center;
    opacity:0; transition:opacity .2s; z-index:5;
  }
  .carousel:hover .carousel-btn { opacity:1; }
  .carousel-btn.prev { left:10px; }
  .carousel-btn.next { right:10px; }
  .carousel-dots { position:absolute; bottom:10px; left:50%; transform:translateX(-50%); display:flex; gap:5px; z-index:5; }
  .carousel-dot { width:6px; height:6px; border-radius:50%; background:rgba(255,255,255,.5); cursor:pointer; transition:background .2s,transform .2s; }
  .carousel-dot.active { background:#fff; transform:scale(1.3); }
  .carousel-count { position:absolute; top:10px; right:10px; background:rgba(0,0,0,.55); color:#fff; font-size:11px; padding:3px 8px; border-radius:10px; z-index:5; }
  .avail-badge {
    position:absolute; top:10px; left:10px;
    padding:4px 10px; border-radius:20px; font-size:11px; font-weight:600; z-index:5;
  }
  .avail-yes { background:rgba(16,185,129,.85); color:#fff; }
  .avail-no  { background:rgba(239,68,68,.85); color:#fff; }

  /* ── Room card body ── */
  .room-body { padding:18px; }
  .room-name { font-family:var(--font-display); font-size:17px; font-weight:700; margin-bottom:6px; }
  .room-type-pill { display:inline-block; padding:3px 10px; background:rgba(0,166,237,.1); color:var(--accent-primary); border-radius:20px; font-size:11px; font-weight:600; margin-bottom:10px; }
  .room-info-row { display:flex; gap:16px; margin-bottom:12px; flex-wrap:wrap; }
  .room-info-item { display:flex; align-items:center; gap:5px; font-size:12px; color:var(--text-muted); }
  .room-price { font-family:var(--font-display); font-size:20px; font-weight:700; color:var(--accent-primary); margin-bottom:12px; }
  .room-amenities { display:flex; flex-wrap:wrap; gap:5px; margin-bottom:14px; }
  .room-amenity-tag { font-size:11px; padding:2px 8px; background:var(--bg-surface); border:1px solid var(--border-color); border-radius:8px; }
  .room-actions { display:flex; gap:8px; padding-top:14px; border-top:1px solid var(--border-color); }
  .room-btn { flex:1; padding:8px 6px; border-radius:9px; border:none; cursor:pointer; font-size:12px; font-weight:600; transition:opacity .2s,transform .2s; display:flex; align-items:center; justify-content:center; gap:5px; }
  .room-btn:hover { opacity:.82; transform:translateY(-1px); }
  .rb-images { background:rgba(139,92,246,.12); color:#8b5cf6; }
  .rb-edit   { background:rgba(245,158,11,.12); color:#f59e0b; }
  .rb-del    { background:rgba(239,68,68,.12); color:#ef4444; }

  /* ── Add room btn ── */
  .btn-add-room {
    display:flex; align-items:center; gap:8px; padding:11px 22px;
    background:var(--accent-primary); color:#fff; border:none;
    border-radius:11px; font-size:14px; font-weight:600; cursor:pointer;
    transition:opacity .2s; white-space:nowrap;
  }
  .btn-add-room:hover { opacity:.88; }
  .btn-back {
    display:flex; align-items:center; gap:7px; padding:10px 18px;
    background:var(--bg-card); color:var(--text-muted); border:1px solid var(--border-color);
    border-radius:11px; font-size:13px; font-weight:500; cursor:pointer;
    text-decoration:none; transition:border-color .2s,color .2s;
  }
  .btn-back:hover { border-color:var(--accent-primary); color:var(--accent-primary); }

  /* ── Drawer ── */
  .drawer-overlay { position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:1000; opacity:0; pointer-events:none; transition:opacity .3s; }
  .drawer-overlay.open { opacity:1; pointer-events:all; }
  .drawer {
    position:fixed; top:0; right:0; bottom:0; width:500px; max-width:95vw;
    background:var(--bg-card); border-left:1px solid var(--border-color);
    z-index:1001; display:flex; flex-direction:column;
    transform:translateX(100%); transition:transform .35s cubic-bezier(.4,0,.2,1);
  }
  .drawer.open { transform:translateX(0); }
  .drawer-header { padding:22px 26px; border-bottom:1px solid var(--border-color); display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
  .drawer-title { font-family:var(--font-display); font-size:19px; font-weight:700; }
  .drawer-close { width:34px; height:34px; border-radius:8px; background:var(--bg-surface); border:1px solid var(--border-color); cursor:pointer; font-size:17px; display:flex; align-items:center; justify-content:center; }
  .drawer-close:hover { background:rgba(239,68,68,.1); color:#ef4444; border-color:#ef4444; }
  .drawer-body { flex:1; overflow-y:auto; padding:26px; scroll-behavior:smooth; }
  .drawer-body::-webkit-scrollbar { width:4px; }
  .drawer-body::-webkit-scrollbar-thumb { background:var(--border-color); border-radius:4px; }
  .drawer-footer { padding:18px 26px; border-top:1px solid var(--border-color); display:flex; gap:12px; flex-shrink:0; }

  .form-group { margin-bottom:18px; }
  .form-label { display:block; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:var(--text-muted); margin-bottom:7px; }
  .form-input, .form-select, .form-textarea { width:100%; padding:10px 13px; background:var(--bg-surface); border:1px solid var(--border-color); border-radius:9px; color:inherit; font-size:14px; transition:border-color .2s; }
  .form-input:focus, .form-select:focus, .form-textarea:focus { outline:none; border-color:var(--accent-primary); }
  .form-textarea { resize:vertical; min-height:80px; }
  .form-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
  .form-section-title { font-size:12px; font-weight:700; color:var(--accent-primary); margin:18px 0 12px; text-transform:uppercase; letter-spacing:.07em; }

  /* Image upload in drawer */
  .img-drop-zone {
    border:2px dashed var(--border-color); border-radius:12px; padding:24px;
    text-align:center; cursor:pointer; transition:border-color .2s,background .2s;
  }
  .img-drop-zone:hover, .img-drop-zone.dragover { border-color:var(--accent-primary); background:rgba(0,166,237,.05); }
  .img-thumbs { display:flex; flex-wrap:wrap; gap:8px; margin-top:12px; }
  .img-thumb-wrap { position:relative; width:70px; height:70px; border-radius:8px; overflow:hidden; border:2px solid transparent; transition:border-color .2s; }
  .img-thumb-wrap.primary { border-color:var(--accent-primary); }
  .img-thumb-wrap img { width:100%; height:100%; object-fit:cover; }
  .img-thumb-del { position:absolute; top:2px; right:2px; background:rgba(239,68,68,.85); color:#fff; border:none; border-radius:50%; width:18px; height:18px; font-size:10px; cursor:pointer; display:flex; align-items:center; justify-content:center; }

  /* ── Image manager modal ── */
  .imgmgr-overlay { position:fixed; inset:0; background:rgba(0,0,0,.7); z-index:2000; opacity:0; pointer-events:none; transition:opacity .3s; display:flex; align-items:center; justify-content:center; padding:20px; }
  .imgmgr-overlay.open { opacity:1; pointer-events:all; }
  .imgmgr {
    background:var(--bg-card); border-radius:20px; width:720px; max-width:100%; max-height:90vh;
    display:flex; flex-direction:column; border:1px solid var(--border-color);
    transform:scale(.95); transition:transform .3s;
  }
  .imgmgr-overlay.open .imgmgr { transform:scale(1); }
  .imgmgr-header { padding:20px 24px; border-bottom:1px solid var(--border-color); display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
  .imgmgr-body { flex:1; overflow-y:auto; padding:24px; }
  .imgmgr-body::-webkit-scrollbar { width:4px; }
  .imgmgr-body::-webkit-scrollbar-thumb { background:var(--border-color); border-radius:4px; }

  /* Big carousel in image manager */
  .imgmgr-carousel {
    border-radius:14px; overflow:hidden; height:300px;
    background:linear-gradient(135deg,#1e3a5f,#0a6587);
    position:relative; margin-bottom:20px;
  }
  .imgmgr-carousel .carousel-track {
    display:flex; height:100%; width:100%;
    transition:transform .4s cubic-bezier(.4,0,.2,1);
  }
  .imgmgr-carousel .carousel-slide {
    min-width:100%; height:100%; flex-shrink:0;
    display:flex; align-items:center; justify-content:center;
  }
  .imgmgr-carousel .carousel-slide img { width:100%; height:100%; object-fit:cover; display:block; }
  .imgmgr-carousel .carousel-btn { opacity:1; width:40px; height:40px; font-size:18px; }

  .imgmgr-thumbs { display:flex; gap:10px; flex-wrap:wrap; }
  .imgmgr-thumb {
    width:90px; height:70px; border-radius:10px; overflow:hidden;
    border:2px solid var(--border-color); cursor:pointer; position:relative;
    transition:border-color .2s;
  }
  .imgmgr-thumb:hover { border-color:var(--accent-primary); }
  .imgmgr-thumb.active { border-color:var(--accent-primary); }
  .imgmgr-thumb.primary-thumb::after { content:'★'; position:absolute; top:3px; left:3px; background:var(--accent-primary); color:#fff; font-size:10px; padding:1px 5px; border-radius:5px; }
  .imgmgr-thumb img { width:100%; height:100%; object-fit:cover; }
  .imgmgr-thumb-actions { position:absolute; inset:0; background:rgba(0,0,0,.5); opacity:0; transition:opacity .2s; display:flex; align-items:center; justify-content:center; gap:4px; }
  .imgmgr-thumb:hover .imgmgr-thumb-actions { opacity:1; }
  .imgmgr-thumb-btn { background:rgba(255,255,255,.9); border:none; border-radius:5px; padding:3px 6px; font-size:10px; cursor:pointer; font-weight:600; }

  .imgmgr-upload-bar { display:flex; gap:10px; align-items:center; margin-top:16px; padding-top:16px; border-top:1px solid var(--border-color); }
  .imgmgr-footer { padding:16px 24px; border-top:1px solid var(--border-color); display:flex; justify-content:flex-end; flex-shrink:0; }

  /* ── Delete confirm ── */
  .del-overlay { position:fixed; inset:0; background:rgba(0,0,0,.6); z-index:3000; opacity:0; pointer-events:none; transition:opacity .25s; display:flex; align-items:center; justify-content:center; }
  .del-overlay.open { opacity:1; pointer-events:all; }
  .del-box { background:var(--bg-card); border-radius:16px; padding:30px; width:380px; max-width:90vw; text-align:center; transform:scale(.9); transition:transform .25s; border:1px solid var(--border-color); }
  .del-overlay.open .del-box { transform:scale(1); }

  /* ── Toast ── */
  .toast { position:fixed; bottom:24px; right:24px; z-index:9999; padding:13px 18px; border-radius:11px; font-size:14px; font-weight:500; display:flex; align-items:center; gap:8px; transform:translateY(70px); opacity:0; transition:transform .3s,opacity .3s; box-shadow:0 8px 24px rgba(0,0,0,.2); }
  .toast.show { transform:translateY(0); opacity:1; }
  .toast.success { background:#10b981; color:#fff; }
  .toast.error   { background:#ef4444; color:#fff; }

  .empty-rooms { text-align:center; padding:80px 40px; color:var(--text-muted); }
  .empty-rooms .ei { font-size:64px; opacity:.3; margin-bottom:16px; }

  /* AI Insights Panel */
  .ai-panel {
    background: linear-gradient(135deg, rgba(127,119,221,0.08) 0%, rgba(127,119,221,0.02) 100%);
    border: 1px solid rgba(127,119,221,0.2);
    border-radius: 20px;
    padding: 24px;
    margin-bottom: 28px;
    transition: all 0.3s ease;
  }
  .ai-panel:hover {
    border-color: rgba(127,119,221,0.4);
    box-shadow: 0 8px 24px -12px rgba(0,0,0,0.2);
  }
  .ai-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .ai-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .ai-badge {
    background: rgba(127,119,221,0.15);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    color: #7F77DD;
  }
  .ai-refresh {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 9px;
    padding: 7px 14px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .ai-refresh:hover {
    border-color: #7F77DD;
    transform: translateY(-1px);
  }
  .ai-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }
  .ai-stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 14px;
    padding: 16px;
    text-align: center;
  }
  .ai-stat-value {
    font-size: 28px;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 6px;
  }
  .ai-stat-label {
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .ai-stat-critical .ai-stat-value { color: #ef4444; }
  .ai-stat-warning .ai-stat-value { color: #f59e0b; }
  .ai-stat-score .ai-stat-value { color: #10b981; }
  .ai-issues-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .ai-issue-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 14px;
    transition: all 0.2s ease;
  }
  .ai-issue-item:hover {
    border-color: rgba(127,119,221,0.4);
    transform: translateX(4px);
  }
  .ai-issue-icon {
    font-size: 20px;
    flex-shrink: 0;
  }
  .ai-issue-content {
    flex: 1;
  }
  .ai-issue-title {
    font-weight: 700;
    font-size: 14px;
    margin-bottom: 4px;
  }
  .ai-issue-desc {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 8px;
  }
  .ai-issue-suggestion {
    font-size: 11px;
    color: #7F77DD;
    background: rgba(127,119,221,0.08);
    display: inline-block;
    padding: 4px 10px;
    border-radius: 20px;
  }
  .ai-critical .ai-issue-icon { color: #ef4444; }
  .ai-warning .ai-issue-icon { color: #f59e0b; }
  .ai-insight-text {
    background: rgba(127,119,221,0.05);
    border-left: 3px solid #7F77DD;
    padding: 14px 18px;
    border-radius: 12px;
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-muted);
    margin-top: 20px;
  }
  .room-quality-badge {
    padding: 3px 8px;
    border-radius: 20px;
    font-size: 10px;
    font-weight: 600;
  }
  .room-quality-badge.high { background: rgba(16,185,129,0.15); color: #10b981; }
  .room-quality-badge.medium { background: rgba(245,158,11,0.15); color: #f59e0b; }
  .room-quality-badge.low { background: rgba(239,68,68,0.15); color: #ef4444; }
  .ai-model-tag {
    font-size: 10px;
    color: var(--text-muted);
    margin-top: 8px;
    text-align: right;
  }
  @media (max-width: 768px) {
    .ai-stats-grid {
        grid-template-columns: repeat(2, 1fr);
    }
  }
{% endblock %}

{% block content %}

{# ── Header ── #}
<div class="rooms-header">
  <div class="rooms-header-left">
    <h1>🛏️ Rooms — <span style="color:var(--accent-primary)">{{ acc.name }}</span></h1>
    <p>{{ acc.city }}{% if acc.country %}, {{ acc.country }}{% endif %} • {{ acc.type }} • {{ acc.stars }}★</p>
  </div>
  <div style="display:flex;gap:10px;align-items:center;">
    <a href="{{ path('admin_accommodations_index') }}" class="btn-back">← Back</a>
    <button class="btn-add-room" onclick="openDrawer()">＋ Add Room</button>
  </div>
</div>

{# ── Stats ── #}
<div class="rooms-stats">
  <div class="rstat">
    <span class="rstat-icon">🛏️</span>
    <div><div class="rstat-val" id="stat-total">{{ total }}</div><div class="rstat-lbl">Total Rooms</div></div>
  </div>
  <div class="rstat">
    <span class="rstat-icon">✅</span>
    <div><div class="rstat-val" id="stat-avail" style="color:#10b981">{{ available }}</div><div class="rstat-lbl">Available</div></div>
  </div>
  <div class="rstat">
    <span class="rstat-icon">⏸️</span>
    <div><div class="rstat-val" id="stat-unavail" style="color:#ef4444">{{ total - available }}</div><div class="rstat-lbl">Unavailable</div></div>
  </div>
</div>

{# AI Insights Panel #}
<div class="ai-panel" id="ai-panel" style="display: none;">
    <div class="ai-header">
        <div class="ai-title">
            <span>AI Room Intelligence</span>
            <span class="ai-badge" id="ai-model-badge">Loading...</span>
        </div>
        <button class="ai-refresh" onclick="loadAiInsights()" id="ai-refresh-btn">
            Refresh Analysis
        </button>
    </div>
    
    <div id="ai-content">
        <div style="text-align: center; padding: 40px; color: var(--text-muted);">
            Loading insights...
        </div>
    </div>
</div>

{# ── Rooms Grid ── #}
<div class="rooms-grid" id="rooms-grid">
  {% if roomsData is empty %}
  <div class="empty-rooms" style="grid-column:1/-1">
    <div class="ei">🛏️</div>
    <h3 style="font-family:var(--font-display);margin-bottom:8px">No rooms yet</h3>
    <p>Click "Add Room" to create the first room for this accommodation.</p>
  </div>
  {% else %}
    {% for rd in roomsData %}
    {% set r = rd.room %}
    <div class="room-card" id="room-card-{{ r.id }}">
      {# Carousel #}
      <div class="carousel" id="carousel-{{ r.id }}">
        {% if rd.allImages is empty %}
        <div class="carousel-track">
          <div class="carousel-slide"><div class="no-img">🛏️</div></div>
        </div>
        {% else %}
        <div class="carousel-track" id="track-{{ r.id }}">
          {% for img in rd.allImages %}
          <div class="carousel-slide">
            <img src="{{ img.filePath starts with '/' ? img.filePath : '/' ~ img.filePath }}" alt="{{ r.roomName }}" loading="lazy">
          </div>
          {% endfor %}
        </div>
        {% if rd.allImages|length > 1 %}
        <button class="carousel-btn prev" onclick="carouselPrev('{{ r.id }}')">‹</button>
        <button class="carousel-btn next" onclick="carouselNext('{{ r.id }}')">›</button>
        <div class="carousel-dots" id="dots-{{ r.id }}">
          {% for img in rd.allImages %}
          <div class="carousel-dot {% if loop.first %}active{% endif %}" onclick="carouselGoTo('{{ r.id }}', {{ loop.index0 }})"></div>
          {% endfor %}
        </div>
        <div class="carousel-count">{{ rd.imageCount }} 📷</div>
        {% endif %}
        {% endif %}
        <span class="avail-badge {{ r.isAvailable ? 'avail-yes' : 'avail-no' }}">
          {{ r.isAvailable ? 'Available' : 'Unavailable' }}
        </span>
      </div>

      {# Body #}
      <div class="room-body">
