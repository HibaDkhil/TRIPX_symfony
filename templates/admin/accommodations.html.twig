// Enhanced setStar function with validation styling
function setStar(n) {
  document.getElementById('f-stars').value = n;
  document.querySelectorAll('.star-btn').forEach((b, i) => {
    b.classList.toggle('lit', i < n);
  });
  
  // Remove error styling if stars are selected
  if (n > 0) {
    const starsContainer = document.querySelector('.star-picker');
    if (starsContainer) starsContainer.style.border = '';
  }
}

// Phone number validation helper
function validatePhoneNumber(phone) {
  // Remove spaces, dashes, parentheses for validation
  const cleanPhone = phone.replace(/[\s\-\(\)]/g, '');
  
  // Check if it contains only digits (optionally starting with +)
  const digitsOnly = cleanPhone.replace(/^\+/, '');
  
  if (!/^\d+$/.test(digitsOnly)) {
    return { valid: false, message: 'Phone number must contain only numbers, spaces, dashes, or parentheses' };
  }
  
  if (digitsOnly.length < 8 || digitsOnly.length > 15) {
    return { valid: false, message: 'Phone number must be between 8 and 15 digits' };
  }
  
  return { valid: true, message: '' };
}

function previewImg(input) {
  const file = input.files[0];
  if (!file) return;
  const r = new FileReader();
  r.onload = e => { const img = document.getElementById('img-preview'); img.src = e.target.result; img.style.display = 'block'; };
  r.readAsDataURL(file);
}

// ── Save (UPDATED with full validation) ──────────────────────────────────
async function saveAcc() {
  // Validate required fields
  const name = document.getElementById('f-name').value.trim();
  if (!name) { 
    showToast('❌ Name is required', 'error'); 
    switchTab('basic'); 
    document.getElementById('f-name').focus();
    return; 
  }
  
  const city = document.getElementById('f-city').value.trim();
  if (!city) { 
    showToast('❌ City is required', 'error'); 
    switchTab('location'); 
    document.getElementById('f-city').focus();
    return; 
  }
  
  const country = document.getElementById('f-country').value.trim();
  if (!country) { 
    showToast('❌ Country is required', 'error'); 
    switchTab('location'); 
    document.getElementById('f-country').focus();
    return; 
  }
  
  // Validate stars (required)
  const stars = parseInt(document.getElementById('f-stars').value);
  if (!stars || stars < 1 || stars > 5) { 
    showToast('❌ Star rating is required (1-5 stars)', 'error'); 
    switchTab('basic'); 
    // Highlight stars picker
    const starsContainer = document.querySelector('.star-picker');
    starsContainer.style.border = '2px solid #ef4444';
    starsContainer.style.borderRadius = '8px';
    starsContainer.style.padding = '8px';
    setTimeout(() => {
      starsContainer.style.border = '';
      starsContainer.style.padding = '';
    }, 3000);
    return; 
  }
  
  // Validate phone number
  const phone = document.getElementById('f-phone').value.trim();
  if (!phone) { 
    showToast('❌ Phone number is required', 'error'); 
    switchTab('contact'); 
    document.getElementById('f-phone').focus();
    return; 
  }
  
  const phoneValidation = validatePhoneNumber(phone);
  if (!phoneValidation.valid) {
    showToast('❌ ' + phoneValidation.message, 'error');
    const phoneField = document.getElementById('f-phone');
    phoneField.style.borderColor = '#ef4444';
    phoneField.style.borderWidth = '2px';
    setTimeout(() => {
      phoneField.style.borderColor = '';
      phoneField.style.borderWidth = '';
    }, 3000);
    switchTab('contact');
    return;
  }

  const btn = document.getElementById('save-btn');
  const originalText = btn.textContent;
  btn.textContent = '⏳ Saving…'; 
  btn.disabled = true;

  const checked = [...document.querySelectorAll('.amenity-cb:checked')].map(c => c.value);
  const custom  = document.getElementById('f-custom-amenities').value.split(',').map(s => s.trim()).filter(Boolean);
  const amenities = [...checked, ...custom].join(',');

  const fd = new FormData();
  fd.append('name',        name);
  fd.append('type',        document.getElementById('f-type').value);
  fd.append('status',      document.getElementById('f-status').value);
  fd.append('description', document.getElementById('f-description').value);
  fd.append('address',     document.getElementById('f-address').value);
  fd.append('city',        city);
  fd.append('country',     country);
  fd.append('postalCode',  document.getElementById('f-postalCode').value);
  fd.append('latitude',    document.getElementById('f-latitude').value);
  fd.append('longitude',   document.getElementById('f-longitude').value);
  fd.append('phone',       phone);
  fd.append('email',       document.getElementById('f-email').value);
  fd.append('website',     document.getElementById('f-website').value);
  fd.append('stars',       stars);
  fd.append('amenities',   amenities);

  const imgFile = document.getElementById('f-image').files[0];
  if (imgFile) fd.append('image', imgFile);

  const url = editingId ? EDIT_URL(editingId) : NEW_URL;
  try {
    const res  = await fetch(url, { method: 'POST', body: fd, headers: AJAX_HEADERS });
    const data = await res.json();
    
    if (data.success) {
      showToast('✅ ' + data.message, 'success');
      closeDrawer();
      doSearch();
      refreshStats();
    } else {
      // Handle validation errors from server
      if (data.errors) {
        let errorMsg = "❌ Validation failed:\n\n";
        for (const [field, msg] of Object.entries(data.errors)) {
          let fieldLabel = field;
          const labels = {
            'name': 'Name',
            'city': 'City',
            'country': 'Country',
            'email': 'Email',
            'website': 'Website',
            'phone': 'Phone',
            'stars': 'Stars',
            'rating': 'Rating',
            'latitude': 'Latitude',
            'longitude': 'Longitude',
            'type': 'Accommodation Type',
            'status': 'Status',
            'address': 'Address',
            'postalCode': 'Postal Code',
            'description': 'Description'
          };
          fieldLabel = labels[field] || field;
          errorMsg += `• ${fieldLabel}: ${msg}\n`;
          
          // Highlight the field in red
          const fieldElement = document.getElementById(`f-${field}`);
          if (fieldElement) {
            fieldElement.style.borderColor = '#ef4444';
            fieldElement.style.borderWidth = '2px';
            setTimeout(() => {
              fieldElement.style.borderColor = '';
              fieldElement.style.borderWidth = '';
            }, 3000);
          }
        }
        showToast(errorMsg, 'error');
      } else {
        showToast('❌ ' + (data.error || 'Something went wrong'), 'error');
      }
    }
  } catch(e) {
    showToast('❌ Network error: ' + e.message, 'error');
  }
  btn.textContent = originalText;
  btn.disabled = false;
}

