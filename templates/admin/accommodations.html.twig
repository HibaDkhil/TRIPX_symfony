{% extends 'admin/admin_base.html.twig' %}

{% block title %}Accommodations — TripX Admin{% endblock %}

{% block breadcrumbs %}
  <a href="{{ path('admin_accommodations_index') }}" class="crumb">Accommodations</a>
  <span class="sep">›</span>
  <span class="crumb active">Management</span>
{% endblock %}

{% block page_styles %}
  .kpi-bar { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin-bottom:28px; }

.kpi-card {
  --radius: 24px;
  font-family: system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
  height: 170px;
  border-radius: var(--radius);
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  padding: 1.5rem;
  padding-top: 1.5rem;
  position: relative;
  overflow: hidden;
  transition: all 0.4s cubic-bezier(0.23, 1, 0.320, 1);
  transform-style: preserve-3d;
  perspective: 1000px;
  backdrop-filter: blur(10px);
}

/* Luminous 3D Hover Effect */
.kpi-card:hover {
  transform: translateY(-6px) rotateX(3deg) rotateY(2deg) scale(1.02);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.25), 0 0 30px rgba(255, 255, 255, 0.1);
}

/* Glow Effect on Hover */
.kpi-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: var(--radius);
  opacity: 0;
  transition: opacity 0.5s ease;
  pointer-events: none;
  z-index: 1;
}

.kpi-card:hover::after {
  opacity: 1;
}

/* Shimmer Animation */
.kpi-card::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -60%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
  z-index: 2;
}

.kpi-card:hover::before {
  opacity: 0.6;
  animation: shimmer 1.2s ease-out;
}

@keyframes shimmer {
  0% {
    transform: translate(-30%, -30%) scale(0.5);
    opacity: 0;
  }
  20% {
    opacity: 0.6;
  }
  100% {
    transform: translate(30%, 30%) scale(1.5);
    opacity: 0;
  }
}

.kpi-card {
  --radius: 20px;
  font-family: system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
  height: 140px;
  border-radius: var(--radius);
  display: flex;
