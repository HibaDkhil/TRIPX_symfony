  .map-search-input { flex:1; padding:10px 14px; background:var(--bg-card); border:1px solid var(--border-color); border-radius:10px; font-size:13px; color:inherit; box-shadow:0 4px 12px rgba(0,0,0,.3); }
  .map-search-input:focus { outline:none; border-color:var(--accent-primary); }
  .map-search-btn { padding:10px 16px; background:var(--accent-primary); color:#fff; border:none; border-radius:10px; cursor:pointer; font-size:13px; font-weight:600; white-space:nowrap; box-shadow:0 4px 12px rgba(0,0,0,.3); }
  #map-container { height:420px; width:100%; }
  .map-crosshair { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); font-size:28px; color:var(--accent-primary); pointer-events:none; z-index:999; text-shadow:0 0 4px rgba(0,0,0,.5); line-height:1; }
  .map-modal-footer { padding:14px 22px; border-top:1px solid var(--border-color); display:flex; align-items:center; gap:12px; flex-shrink:0; }
  .map-confirm-btn { padding:10px 20px; background:var(--accent-primary); color:#fff; border:none; border-radius:10px; cursor:pointer; font-size:13px; font-weight:600; transition:opacity .2s; }
  .map-confirm-btn:disabled { opacity:.4; cursor:not-allowed; }
  .map-confirm-btn:not(:disabled):hover { opacity:.88; }
  .map-pin-pulse { animation: pulse 1.5s infinite; }
  @keyframes pulse { 0%,100% { transform: scale(1); } 50% { transform: scale(1.3); } }

  .results-count { font-size:13px; color:var(--text-muted); margin-bottom:16px; }

