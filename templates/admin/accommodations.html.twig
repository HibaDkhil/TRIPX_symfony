    transition:opacity .3s; display:flex; align-items:center; justify-content:center; padding:20px;
  }
  .map-overlay.open { opacity:1; pointer-events:all; }
  .map-modal {
    background:var(--bg-card); border-radius:18px; width:820px; max-width:100%;
    max-height:90vh; display:flex; flex-direction:column;
    border:1px solid var(--border-color); overflow:hidden;
    transform:scale(.95); transition:transform .3s;
  }
