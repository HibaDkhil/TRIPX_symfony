// ── Real-time search ──────────────────────────────────────
let searchTimer = null;
document.getElementById('search-box').addEventListener('input', function() {
  clearTimeout(searchTimer);
  searchTimer = setTimeout(doSearch, 300);
});
document.getElementById('filter-type').addEventListener('change', doSearch);
document.getElementById('filter-status').addEventListener('change', doSearch);

async function doSearch() {
  const q      = document.getElementById('search-box').value;
  const type   = document.getElementById('filter-type').value;
  const status = document.getElementById('filter-status').value;

  const url = `${SEARCH_URL}?q=${encodeURIComponent(q)}&type=${encodeURIComponent(type)}&status=${encodeURIComponent(status)}`;
  try {
    const res  = await fetch(url, { headers: AJAX_HEADERS });
    const data = await res.json();
    document.getElementById('results-count').textContent = `${data.count} accommodation${data.count !== 1 ? 's' : ''}`;
    renderGrid(data.results);
    renderTable(data.results);
  } catch(e) { console.error('Search error', e); }
}

function renderGrid(items) {
  const c = document.getElementById('grid-container');
  if (!items.length) {
    c.innerHTML = `<div class="empty-state" style="grid-column:1/-1"><div class="es-icon">🏨</div><h3 style="font-family:var(--font-display)">No results</h3></div>`;
    return;
  }
  c.innerHTML = items.map(a => `
    <div class="acc-card" data-id="${a.id}">
      <div class="acc-card-img">
        ${a.imagePath ? `<img src="/${a.imagePath}" alt="${esc(a.name)}">` : '🏨'}
        <span class="acc-status-badge ${a.status === 'Active' ? 'badge-active' : 'badge-inactive'}">${a.status}</span>
      </div>
      <div class="acc-card-body">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:4px">
          <div class="acc-card-name">${esc(a.name)}</div>
          ${a.type ? `<span class="acc-type-pill">${esc(a.type)}</span>` : ''}
        </div>
        <div class="acc-card-meta">📍 ${esc(a.city || '')}${a.country ? ', ' + esc(a.country) : ''}</div>
        <div style="display:flex;justify-content:space-between;align-items:center">
          <span class="stars">${starsHtml(a.stars)}</span>
          ${a.rating ? `<span style="font-size:12px;color:var(--text-muted)">⭐ ${parseFloat(a.rating).toFixed(1)}</span>` : ''}
        </div>
        <div class="acc-card-actions">
          <button class="acc-btn btn-view" onclick="viewAcc(${a.id})">👁 View</button>
          <button class="acc-btn btn-edit" onclick="editAcc(${a.id})">✏️ Edit</button>
          <button class="acc-btn btn-del"  onclick="confirmDel(${a.id}, '${esc(a.name)}')">🗑 Del</button>
        </div>
      </div>
    </div>`).join('');
}

function renderTable(items) {
  const tb = document.getElementById('table-body');
  if (!items.length) {
    tb.innerHTML = `<tr><td colspan="6" style="text-align:center;padding:40px;color:var(--text-muted)">No results</td></tr>`;
    return;
  }
  tb.innerHTML = items.map(a => `
    <tr data-id="${a.id}">
      <td>
        <div style="display:flex;align-items:center;gap:11px">
          <div class="tbl-thumb">${a.imagePath ? `<img src="/${a.imagePath}" alt="">` : '🏨'}</div>
          <div><div style="font-weight:600;font-size:14px">${esc(a.name)}</div>${a.email ? `<div style="font-size:11px;color:var(--text-muted)">${esc(a.email)}</div>` : ''}</div>
        </div>
      </td>
      <td>${a.type ? `<span class="acc-type-pill">${esc(a.type)}</span>` : '—'}</td>
      <td><div style="font-weight:500">${esc(a.city||'')}</div><div style="font-size:11px;color:var(--text-muted)">${esc(a.country||'')}</div></td>
      <td><span class="stars">${starsHtml(a.stars)}</span></td>
      <td><span class="acc-status-badge ${a.status === 'Active' ? 'badge-active' : 'badge-inactive'}">${a.status}</span></td>
      <td>
        <div class="tbl-actions">
          <button class="tbl-btn btn-view" onclick="viewAcc(${a.id})">👁 View</button>
          <button class="tbl-btn btn-edit" onclick="editAcc(${a.id})">✏️ Edit</button>
          <button class="tbl-btn btn-del"  onclick="confirmDel(${a.id}, '${esc(a.name)}')">🗑</button>
        </div>
      </td>
    </tr>`).join('');
}

function starsHtml(n) {
  n = n || 0;
  return '★'.repeat(n) + '☆'.repeat(Math.max(0, 5 - n));
}
function esc(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

// ── Drawer ────────────────────────────────────────────────
let editingId = null;

function openDrawer(id = null) {
