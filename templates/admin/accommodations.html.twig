}

/* Luminous 3D Hover Effect */
.kpi-card:hover {
  transform: translateY(-4px) rotateX(2deg) rotateY(1deg) scale(1.01);
  box-shadow: 0 20px 35px rgba(0, 0, 0, 0.2), 0 0 25px rgba(255, 255, 255, 0.15);
}

/* Glow Effect on Hover */
.kpi-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: var(--radius);
  opacity: 0;
  transition: opacity 0.5s ease;
  pointer-events: none;
  z-index: 1;
}

.kpi-card:hover::after {
  opacity: 1;
}

/* Shimmer Animation */
.kpi-card::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -60%;
  width: 200%;
