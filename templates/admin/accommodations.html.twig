      document.getElementById('f-status').value      = d.status || 'Active';
      document.getElementById('f-description').value = d.description || '';
      document.getElementById('f-address').value     = d.address || '';
      document.getElementById('f-city').value        = d.city || '';
      document.getElementById('f-country').value     = d.country || '';
      document.getElementById('f-postalCode').value  = d.postalCode || '';
      document.getElementById('f-latitude').value    = d.latitude || '';
      document.getElementById('f-longitude').value   = d.longitude || '';
      document.getElementById('f-phone').value       = d.phone || '';
      document.getElementById('f-email').value       = d.email || '';
