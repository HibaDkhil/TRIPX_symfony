// ── Map Picker ────────────────────────────────────────────
let map = null;
let mapMarker = null;
let mapPickedData = null;

const mapIcon = () => L.divIcon({
  html: '<div style="width:24px;height:24px;background:#00a6ed;border:3px solid #fff;border-radius:50%;box-shadow:0 2px 8px rgba(0,0,0,.5);"></div>',
  iconSize: [24, 24], iconAnchor: [12, 12], className: ''
});

function openMapPicker() {
  document.getElementById('map-overlay').classList.add('open');
  mapPickedData = null;
  document.getElementById('map-confirm-btn').disabled = true;
  document.getElementById('map-selected-info').textContent = 'Click on the map to select a location…';

  if (!map) {
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        map = L.map('map-container', { zoomControl: true });
        map.setView([20, 0], 2);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '© OpenStreetMap contributors',
          maxZoom: 19,
        }).addTo(map);

        map.on('click', function(e) {
          handleMapClick(e.latlng.lat, e.latlng.lng);
        });

        const lat = parseFloat(document.getElementById('f-latitude').value);
        const lng = parseFloat(document.getElementById('f-longitude').value);
        if (lat && lng) {
          map.setView([lat, lng], 14);
          mapMarker = L.marker([lat, lng], { icon: mapIcon(), draggable: true }).addTo(map);
          mapMarker.on('dragend', function(ev) {
            const pos = ev.target.getLatLng();
            handleMapClick(pos.lat, pos.lng);
          });
        }
      });
    });
  } else {
    map.invalidateSize();
    const lat = parseFloat(document.getElementById('f-latitude').value);
    const lng = parseFloat(document.getElementById('f-longitude').value);
    if (lat && lng && !mapMarker) {
      map.setView([lat, lng], 14);
      mapMarker = L.marker([lat, lng], { icon: mapIcon(), draggable: true }).addTo(map);
    }
  }
}

function closeMapPicker() {
  document.getElementById('map-overlay').classList.remove('open');
}

async function handleMapClick(lat, lng) {
  if (mapMarker) {
    mapMarker.setLatLng([lat, lng]);
  } else {
    mapMarker = L.marker([lat, lng], { icon: mapIcon(), draggable: true }).addTo(map);
    mapMarker.on('dragend', function(ev) {
      const pos = ev.target.getLatLng();
      handleMapClick(pos.lat, pos.lng);
    });
  }

  document.getElementById('map-selected-info').textContent = '⏳ Loading address…';
  document.getElementById('map-confirm-btn').disabled = true;

  try {
    const res = await fetch(
      `https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json&addressdetails=1`,
      { headers: { 'Accept-Language': 'en', 'User-Agent': 'TripX-Admin/1.0' } }
    );
    const data = await res.json();
    const addr = data.address || {};

    mapPickedData = {
      lat:        lat.toFixed(8),
      lng:        lng.toFixed(8),
      address:    [addr.road, addr.house_number].filter(Boolean).join(' ') || '',
      city:       addr.city || addr.town || addr.village || addr.county || '',
      country:    addr.country || '',
      postalCode: addr.postcode || '',
    };

  } catch(e) {
    mapPickedData = {
      lat: lat.toFixed(8), lng: lng.toFixed(8),
      address: '', city: '', country: '', postalCode: ''
    };
  }

  fillAndClose();
}

function fillAndClose() {
  if (!mapPickedData) return;

  document.getElementById('f-latitude').value  = mapPickedData.lat;
  document.getElementById('f-longitude').value = mapPickedData.lng;
  if (mapPickedData.address)    document.getElementById('f-address').value    = mapPickedData.address;
  if (mapPickedData.city)       document.getElementById('f-city').value       = mapPickedData.city;
  if (mapPickedData.country)    document.getElementById('f-country').value    = mapPickedData.country;
  if (mapPickedData.postalCode) document.getElementById('f-postalCode').value = mapPickedData.postalCode;

  const label = [mapPickedData.address, mapPickedData.city, mapPickedData.country].filter(Boolean).join(', ');
  document.getElementById('map-picked-text').textContent = `${label} (${mapPickedData.lat}, ${mapPickedData.lng})`;
  document.getElementById('map-picked-preview').style.display = 'block';

  closeMapPicker();
  showToast('✅ Location filled: ' + (mapPickedData.city || mapPickedData.address || 'coordinates set'), 'success');
}

function confirmMapPick() { fillAndClose(); }

async function searchMap() {
  const q = document.getElementById('map-search-input').value.trim();
  if (!q || !map) return;

  try {
    const res = await fetch(
      `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(q)}&format=json&limit=1`,
      { headers: { 'Accept-Language': 'en', 'User-Agent': 'TripX-Admin/1.0' } }
    );
    const results = await res.json();
    if (!results.length) { showToast('❌ Location not found', 'error'); return; }

    const lat = parseFloat(results[0].lat);
    const lon = parseFloat(results[0].lon);
    map.setView([lat, lon], 14);

    if (mapMarker) mapMarker.setLatLng([lat, lon]);
    else {
      mapMarker = L.marker([lat, lon], { icon: mapIcon(), draggable: true }).addTo(map);
      mapMarker.on('dragend', function(ev) {
        const pos = ev.target.getLatLng();
        handleMapClick(pos.lat, pos.lng);
      });
    }

    await handleMapClick(lat, lon);
  } catch(e) { showToast('❌ Search failed', 'error'); }
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    closeDrawer(); closeView(); closeDel();
    closeMapPicker();
  }
});
</script>
