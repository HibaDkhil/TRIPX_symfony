  .drawer-tab { padding:13px 16px; background:transparent; border:none; cursor:pointer; font-size:13px; font-weight:500; color:var(--text-muted); border-bottom:2px solid transparent; transition:color .2s,border-color .2s; white-space:nowrap; }
  .drawer-tab.active { color:var(--accent-primary); border-bottom-color:var(--accent-primary); font-weight:600; }
  .drawer-body { flex:1; overflow-y:auto; padding:26px; }
  .drawer-body::-webkit-scrollbar { width:4px; }
  .drawer-body::-webkit-scrollbar-thumb { background:var(--border-color); border-radius:4px; }
  .drawer-footer { padding:18px 26px; border-top:1px solid var(--border-color); display:flex; gap:12px; flex-shrink:0; }
  .tab-panel { display:none; }
  .tab-panel.active { display:block; }

  .form-group { margin-bottom:18px; }
  .form-label { display:block; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:var(--text-muted); margin-bottom:7px; }
  .form-input, .form-select, .form-textarea {
    width:100%; padding:10px 13px;
    background:var(--bg-surface); border:1px solid var(--border-color);
    border-radius:9px; color:inherit; font-size:14px; transition:border-color .2s;
  }
  .form-input:focus, .form-select:focus, .form-textarea:focus { outline:none; border-color:var(--accent-primary); }
  .form-textarea { resize:vertical; min-height:88px; }
  .form-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
  .star-picker { display:flex; gap:4px; }
  .star-btn { background:none; border:none; cursor:pointer; font-size:26px; color:#d1d5db; transition:color .1s; padding:0; line-height:1; }
  .star-btn.lit { color:#f59e0b; }
  .img-upload-area { border:2px dashed var(--border-color); border-radius:10px; padding:24px; text-align:center; cursor:pointer; transition:border-color .2s,background .2s; }
  .img-upload-area:hover { border-color:var(--accent-primary); background:rgba(0,166,237,.04); }
  .img-preview { width:100%; height:150px; object-fit:cover; border-radius:9px; margin-top:10px; display:none; }

  /* View Modal */
  .vmodal-overlay { position:fixed; inset:0; background:rgba(0,0,0,.6); z-index:2000; opacity:0; pointer-events:none; transition:opacity .3s; display:flex; align-items:center; justify-content:center; padding:20px; }
  .vmodal-overlay.open { opacity:1; pointer-events:all; }
  .vmodal { background:var(--bg-card); border-radius:20px; width:660px; max-width:100%; max-height:90vh; overflow:hidden; display:flex; flex-direction:column; transform:scale(.95); transition:transform .3s; border:1px solid var(--border-color); }
  .vmodal-overlay.open .vmodal { transform:scale(1); }
  .vmodal-img { height:200px; background:linear-gradient(135deg,#1e3a5f,#0a6587); position:relative; overflow:hidden; display:flex; align-items:center; justify-content:center; font-size:72px; flex-shrink:0; }
  .vmodal-img img { width:100%; height:100%; object-fit:cover; position:absolute; inset:0; }
  .vmodal-img-overlay { position:absolute; inset:0; background:linear-gradient(to top,rgba(0,0,0,.65) 0%,transparent 55%); }
  .vmodal-img-title { position:absolute; bottom:14px; left:20px; color:#fff; font-family:var(--font-display); font-size:22px; font-weight:700; z-index:1; }
  .vmodal-body { padding:22px; overflow-y:auto; flex:1; }
  .vmodal-body::-webkit-scrollbar { width:4px; }
  .vmodal-body::-webkit-scrollbar-thumb { background:var(--border-color); border-radius:4px; }
  .vm-meta { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:18px; }
  .vm-chip { padding:4px 12px; border-radius:20px; font-size:12px; font-weight:500; background:var(--bg-surface); border:1px solid var(--border-color); }
  .vm-section { margin-bottom:18px; }
  .vm-section h4 { font-size:11px; text-transform:uppercase; letter-spacing:.08em; color:var(--text-muted); margin-bottom:10px; font-weight:700; }
  .vm-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
  .vm-item { background:var(--bg-surface); border-radius:9px; padding:11px 13px; }
  .vm-item-label { font-size:11px; color:var(--text-muted); margin-bottom:2px; }
  .vm-item-val { font-size:13px; font-weight:600; }
  .vmodal-footer { padding:14px 22px; border-top:1px solid var(--border-color); display:flex; gap:10px; flex-shrink:0; }

  /* Delete confirm */
  .del-overlay { position:fixed; inset:0; background:rgba(0,0,0,.6); z-index:3000; opacity:0; pointer-events:none; transition:opacity .25s; display:flex; align-items:center; justify-content:center; }
  .del-overlay.open { opacity:1; pointer-events:all; }
  .del-box { background:var(--bg-card); border-radius:16px; padding:30px; width:380px; max-width:90vw; text-align:center; transform:scale(.9); transition:transform .25s; border:1px solid var(--border-color); }
  .del-overlay.open .del-box { transform:scale(1); }

  /* Toast */
  .toast { position:fixed; bottom:24px; right:24px; z-index:9999; padding:13px 18px; border-radius:11px; font-size:14px; font-weight:500; display:flex; align-items:center; gap:8px; transform:translateY(70px); opacity:0; transition:transform .3s,opacity .3s; box-shadow:0 8px 24px rgba(0,0,0,.2); }
  .toast.show { transform:translateY(0); opacity:1; }
  .toast.success { background:#10b981; color:#fff; }
  .toast.error   { background:#ef4444; color:#fff; }
{% endblock %}

{% block content %}

{# KPI #}
<div class="kpi-bar">
  <div class="kpi-card kpi-card-total">
    <div class="kpi-top">
      <div class="kpi-icon" style="background:rgba(126,200,247,.15)">🏨</div>
      <span class="kpi-val" style="color:#7ec8f7">{{ total }}</span>
    </div>
    <span class="kpi-label">Total</span>
  </div>

  <div class="kpi-card kpi-card-active">
    <div class="kpi-top">
      <div class="kpi-icon" style="background:rgba(110,231,183,.15)">✅</div>
      <span class="kpi-val" style="color:#6ee7b7">{{ active }}</span>
    </div>
    <span class="kpi-label">Active</span>
  </div>

  <div class="kpi-card kpi-card-inactive">
    <div class="kpi-top">
      <div class="kpi-icon" style="background:rgba(196,181,253,.15)">⏸️</div>
      <span class="kpi-val" style="color:#c4b5fd">{{ inactive }}</span>
    </div>
    <span class="kpi-label">Inactive</span>
  </div>
</div>

{# Toolbar #}
<div class="toolbar">
  <div class="search-input-wrap">
    <span class="search-icon">🔍</span>
    <input type="text" id="search-box" placeholder="Search name, city, country…" value="{{ filters.search }}" autocomplete="off">
  </div>
  <select id="filter-type" class="filter-select">
    <option value="">All Types</option>
    {% for t in types %}<option value="{{ t }}" {% if filters.type == t %}selected{% endif %}>{{ t }}</option>{% endfor %}
  </select>
  <select id="filter-status" class="filter-select">
    <option value="">All Status</option>
    <option value="Active" {% if filters.status == 'Active' %}selected{% endif %}>Active</option>
    <option value="Inactive" {% if filters.status == 'Inactive' %}selected{% endif %}>Inactive</option>
  </select>
  <div class="view-toggle">
    <button type="button" class="view-btn active" id="btn-grid" onclick="setView('grid')" title="Grid">⊞</button>
    <button type="button" class="view-btn" id="btn-table" onclick="setView('table')" title="Table">☰</button>
  </div>
  <button type="button" class="btn-add" onclick="openDrawer()">＋ Add Accommodation</button>
</div>

<div class="results-count" id="results-count">{{ accommodations|length }} accommodation{{ accommodations|length != 1 ? 's' : '' }}</div>

{# Grid #}
<div id="view-grid">
  <div class="acc-grid" id="grid-container">
    {% for a in accommodations %}
    <div class="acc-card" data-id="{{ a.id }}">
      <div class="acc-card-img">
        {% if a.imagePath %}<img src="{{ asset(a.imagePath) }}" alt="{{ a.name }}">{% else %}🏨{% endif %}
        <span class="acc-status-badge {% if a.status == 'Active' %}badge-active{% else %}badge-inactive{% endif %}">{{ a.status }}</span>
      </div>
      <div class="acc-card-body">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:4px;">
          <div class="acc-card-name">{{ a.name }}</div>
          {% if a.type %}<span class="acc-type-pill">{{ a.type }}</span>{% endif %}
        </div>
        <div class="acc-card-meta">📍 {{ a.city }}{% if a.country %}, {{ a.country }}{% endif %}</div>
        <div style="display:flex;justify-content:space-between;align-items:center;">
          <span class="stars">{% for i in 1..5 %}{{ i <= a.stars ? '★' : '☆' }}{% endfor %}</span>
          {% if a.rating %}<span style="font-size:12px;color:var(--text-muted)">⭐ {{ a.rating|number_format(1) }}</span>{% endif %}
        </div>
        <div class="acc-card-actions">
          <button class="acc-btn btn-view" onclick="viewAcc({{ a.id }})">👁 View</button>
          <button class="acc-btn btn-edit" onclick="editAcc({{ a.id }})">✏️ Edit</button>
          <button class="acc-btn btn-del"  onclick="confirmDel({{ a.id }}, '{{ a.name|e('js') }}')">🗑 Del</button>
        </div>
      </div>
    </div>
    {% else %}
    <div class="empty-state" style="grid-column:1/-1">
      <div class="es-icon">🏨</div>
      <h3 style="font-family:var(--font-display);margin-bottom:8px">No accommodations found</h3>
      <p>Try adjusting your filters or add a new one.</p>
    </div>
    {% endfor %}
  </div>
</div>

{# Table #}
<div id="view-table" style="display:none">
  <div class="acc-table-wrap">
    <table class="acc-table">
      <thead><tr>
        <th>Accommodation</th><th>Type</th><th>Location</th><th>Stars</th><th>Status</th><th>Actions</th>
      </tr></thead>
      <tbody id="table-body">
        {% for a in accommodations %}
        <tr data-id="{{ a.id }}">
          <td>
            <div style="display:flex;align-items:center;gap:11px;">
              <div class="tbl-thumb">{% if a.imagePath %}<img src="{{ asset(a.imagePath) }}" alt="">{% else %}🏨{% endif %}</div>
              <div><div style="font-weight:600;font-size:14px">{{ a.name }}</div>{% if a.email %}<div style="font-size:11px;color:var(--text-muted)">{{ a.email }}</div>{% endif %}</div>
            </div>
          </td>
          <td>{% if a.type %}<span class="acc-type-pill">{{ a.type }}</span>{% endif %}</td>
          <td><div style="font-weight:500">{{ a.city }}</div><div style="font-size:11px;color:var(--text-muted)">{{ a.country }}</div></td>
          <td><span class="stars">{% for i in 1..5 %}{{ i <= a.stars ? '★' : '☆' }}{% endfor %}</span></td>
          <td><span class="acc-status-badge {% if a.status == 'Active' %}badge-active{% else %}badge-inactive{% endif %}">{{ a.status }}</span></td>
          <td>
            <div class="tbl-actions">
              <button class="tbl-btn btn-view" onclick="viewAcc({{ a.id }})">👁 View</button>
              <button class="tbl-btn btn-edit" onclick="editAcc({{ a.id }})">✏️ Edit</button>
              <button class="tbl-btn btn-del"  onclick="confirmDel({{ a.id }}, '{{ a.name|e('js') }}')">🗑</button>
            </div>
          </td>
        </tr>
        {% else %}
        <tr><td colspan="6" style="text-align:center;padding:40px;color:var(--text-muted)">No accommodations found</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

{# ── DRAWER ── #}
<div class="drawer-overlay" id="drawer-overlay" onclick="closeDrawer()"></div>
<div class="drawer" id="drawer">
  <div class="drawer-header">
    <div class="drawer-title" id="drawer-title">Add Accommodation</div>
    <button class="drawer-close" onclick="closeDrawer()">✕</button>
  </div>
  <div class="drawer-tabs">
    <button class="drawer-tab active" onclick="switchTab('basic')">📋 Basic Info</button>
    <button class="drawer-tab" onclick="switchTab('location')">📍 Location</button>
    <button class="drawer-tab" onclick="switchTab('contact')">📞 Contact</button>
    <button class="drawer-tab" onclick="switchTab('amenities')">✨ Amenities</button>
  </div>
  <div class="drawer-body">

    <div class="tab-panel active" id="tab-basic">
      <div class="form-group">
        <label class="form-label">Name *</label>
        <input type="text" class="form-input" id="f-name" placeholder="Grand Palace Hotel">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Type</label>
          <select class="form-select" id="f-type">
            <option value="">Select type</option>
            <option>Hotel</option><option>Resort</option><option>Villa</option>
            <option>Hostel</option><option>Apartment</option><option>Guest House</option>
            <option>Boutique</option><option>Motel</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Status</label>
          <select class="form-select" id="f-status">
            <option value="Active">Active</option>
            <option value="Inactive">Inactive</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Stars</label>
        <div class="star-picker">
          {% for i in 1..5 %}
          <button type="button" class="star-btn" data-val="{{ i }}" onclick="setStar({{ i }})">★</button>
          {% endfor %}
        </div>
        <input type="hidden" id="f-stars" value="0">
      </div>
      <div class="form-group">
        <label class="form-label">Description</label>
        <textarea class="form-textarea" id="f-description" placeholder="Describe the accommodation…"></textarea>
      </div>
      <div class="form-group">
        <label class="form-label">Cover Image</label>
        <div class="img-upload-area" onclick="document.getElementById('f-image').click()">
          <div style="font-size:28px;margin-bottom:6px">📷</div>
          <div style="font-size:13px;color:var(--text-muted)">Click to upload</div>
          <div style="font-size:11px;color:var(--text-muted);margin-top:3px">JPG, PNG — max 5MB</div>
        </div>
        <input type="file" id="f-image" accept="image/*" style="display:none" onchange="previewImg(this)">
        <img id="img-preview" class="img-preview" alt="">
      </div>
    </div>

    <div class="tab-panel" id="tab-location">

      {# Pick from Map button #}
      <div style="margin-bottom:18px;">
        <button type="button" class="pick-map-btn" onclick="openMapPicker()">
          🗺️ Pick Location from Map
        </button>
        <div id="map-picked-preview" style="display:none;margin-top:10px;padding:10px 14px;background:rgba(0,166,237,.08);border:1px solid rgba(0,166,237,.25);border-radius:10px;font-size:12px;color:var(--accent-primary);">
          📍 <span id="map-picked-text"></span>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Address</label>
        <input type="text" class="form-input" id="f-address" placeholder="123 Beach Road">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">City</label>
          <input type="text" class="form-input" id="f-city" placeholder="Dubai">
        </div>
        <div class="form-group">
          <label class="form-label">Country</label>
          <input type="text" class="form-input" id="f-country" placeholder="UAE">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Postal Code</label>
        <input type="text" class="form-input" id="f-postalCode" placeholder="12345">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Latitude</label>
          <input type="number" class="form-input" id="f-latitude" step="0.00000001" placeholder="25.2048" readonly>
        </div>
        <div class="form-group">
          <label class="form-label">Longitude</label>
          <input type="number" class="form-input" id="f-longitude" step="0.00000001" placeholder="55.2708" readonly>
        </div>
      </div>
    </div>

    <div class="tab-panel" id="tab-contact">
      <div class="form-group">
        <label class="form-label">Phone</label>
        <input type="text" class="form-input" id="f-phone" placeholder="+1 234 567 890">
      </div>
      <div class="form-group">
        <label class="form-label">Email</label>
        <input type="email" class="form-input" id="f-email" placeholder="info@hotel.com">
      </div>
      <div class="form-group">
        <label class="form-label">Website</label>
        <input type="url" class="form-input" id="f-website" placeholder="https://hotel.com">
      </div>
    </div>

    <div class="tab-panel" id="tab-amenities">
      <div class="form-group">
        <label class="form-label">Select Amenities</label>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px">
          {% for am in ['Free WiFi','Pool','Parking','Gym','Spa','Restaurant','Bar','Room Service','Air Conditioning','Pet Friendly','Beach Access','Concierge'] %}
          <label style="display:flex;align-items:center;gap:8px;padding:9px 11px;background:var(--bg-surface);border-radius:8px;border:1px solid var(--border-color);cursor:pointer;font-size:13px">
            <input type="checkbox" class="amenity-cb" value="{{ am }}" style="accent-color:var(--accent-primary)"> {{ am }}
          </label>
          {% endfor %}
        </div>
        <label class="form-label">Other (comma separated)</label>
        <input type="text" class="form-input" id="f-custom-amenities" placeholder="Rooftop Terrace, Private Chef…">
      </div>
    </div>

  </div>
  <div class="drawer-footer">
    <button class="btn-add" style="flex:1;justify-content:center" id="save-btn" onclick="saveAcc()">💾 Save</button>
    <button style="padding:10px 18px;background:var(--bg-surface);border:1px solid var(--border-color);border-radius:10px;cursor:pointer;font-size:14px" onclick="closeDrawer()">Cancel</button>
  </div>
</div>

{# View Modal #}
<div class="vmodal-overlay" id="vmodal-overlay" onclick="if(event.target===this)closeView()">
  <div class="vmodal">
    <div class="vmodal-img" id="vm-img">
      <img id="vm-img-el" src="" alt="" style="display:none">
      <span id="vm-emoji">🏨</span>
      <div class="vmodal-img-overlay"></div>
      <div class="vmodal-img-title" id="vm-title">—</div>
    </div>
    <div class="vmodal-body">
      <div class="vm-meta" id="vm-meta"></div>
      <div class="vm-section"><h4>Details</h4><div class="vm-grid" id="vm-grid"></div></div>
      <div class="vm-section" id="vm-desc-sec"><h4>Description</h4><p id="vm-desc" style="font-size:14px;line-height:1.6;color:var(--text-muted)"></p></div>
      <div class="vm-section" id="vm-am-sec"><h4>Amenities</h4><div id="vm-am" style="display:flex;flex-wrap:wrap;gap:7px"></div></div>

      {# Rooms preview #}
      <div class="vm-section" id="vm-rooms-sec">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
          <h4 style="margin:0">🛏️ Available Rooms</h4>
          <a id="vm-manage-rooms-btn" href="#" style="font-size:12px;font-weight:600;color:var(--accent-primary);text-decoration:none;padding:5px 12px;border:1px solid var(--accent-primary);border-radius:8px;transition:background .2s;" onmouseover="this.style.background='rgba(0,166,237,.1)'" onmouseout="this.style.background='transparent'">Manage Rooms →</a>
        </div>
        <div id="vm-rooms-list" style="display:flex;flex-direction:column;gap:10px;">
          <div style="text-align:center;padding:20px;color:var(--text-muted);font-size:13px">Loading rooms…</div>
        </div>
      </div>
    </div>
    <div class="vmodal-footer">
      <button class="acc-btn btn-edit" style="flex:1;padding:11px" id="vm-edit-btn">✏️ Edit</button>
      <button style="padding:11px 18px;background:var(--bg-surface);border:1px solid var(--border-color);border-radius:10px;cursor:pointer" onclick="closeView()">Close</button>
    </div>
  </div>
</div>

{# ── Map Picker Modal ── #}
<div class="map-overlay" id="map-overlay">
  <div class="map-modal">
    <div class="map-modal-header">
      <div>
        <div style="font-family:var(--font-display);font-size:18px;font-weight:700;">📍 Pick Location</div>
        <div style="font-size:12px;color:var(--text-muted);margin-top:2px;">Click anywhere on the map to select a location</div>
      </div>
      <button class="drawer-close" onclick="closeMapPicker()">✕</button>
    </div>
    <div style="position:relative;">
      <div class="map-search-bar">
        <input type="text" id="map-search-input" class="map-search-input" placeholder="Search for a city or address…" onkeydown="if(event.key==='Enter')searchMap()">
        <button class="map-search-btn" onclick="searchMap()">🔍 Search</button>
      </div>
      <div id="map-container"></div>
      <div class="map-crosshair">＋</div>
    </div>
    <div class="map-modal-footer">
      <div id="map-selected-info" style="font-size:13px;color:var(--text-muted);flex:1;">
        Click on the map to select a location…
      </div>
      <button class="map-confirm-btn" id="map-confirm-btn" onclick="confirmMapPick()" disabled>✅ Confirm Location</button>
      <button style="padding:10px 16px;background:var(--bg-surface);border:1px solid var(--border-color);border-radius:10px;cursor:pointer;font-size:13px;" onclick="closeMapPicker()">Cancel</button>
    </div>
  </div>
</div>

{# Delete Confirm #}
<div class="del-overlay" id="del-overlay">
  <div class="del-box">
    <div style="font-size:44px;margin-bottom:14px">🗑️</div>
    <h3 style="font-family:var(--font-display);margin-bottom:8px">Delete Accommodation</h3>
    <p style="color:var(--text-muted);font-size:14px;margin-bottom:22px">Are you sure you want to delete <strong id="del-name"></strong>?</p>
    <div style="display:flex;gap:10px;justify-content:center">
      <button style="padding:10px 26px;background:#ef4444;color:#fff;border:none;border-radius:9px;cursor:pointer;font-weight:600" onclick="doDelete()">Delete</button>
      <button style="padding:10px 26px;background:var(--bg-surface);border:1px solid var(--border-color);border-radius:9px;cursor:pointer" onclick="closeDel()">Cancel</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

{% endblock %}

{% block page_scripts %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
// ── CSRF token for Symfony POST requests ──────────────────
const AJAX_HEADERS = { 'X-Requested-With': 'XMLHttpRequest' };

const STATS_URL  = '{{ path('admin_accommodations_stats') }}';
const SEARCH_URL = '{{ path('admin_accommodations_search') }}';
const NEW_URL    = '{{ path('admin_accommodations_new') }}';
const VIEW_URL   = (id) => `/admin/accommodations/${id}`;
const EDIT_URL   = (id) => `/admin/accommodations/${id}/edit`;
const DEL_URL    = (id) => `/admin/accommodations/${id}/delete`;

// ── Refresh KPI stats without reload ─────────────────────
async function refreshStats() {
  try {
    const res  = await fetch(STATS_URL, { headers: AJAX_HEADERS });
    const data = await res.json();
    const vals = document.querySelectorAll('.kpi-val');
    if (vals[0]) vals[0].textContent = data.total;
    if (vals[1]) vals[1].textContent = data.active;
    if (vals[2]) vals[2].textContent = data.inactive;
  } catch(e) { console.error('Stats refresh failed', e); }
}

