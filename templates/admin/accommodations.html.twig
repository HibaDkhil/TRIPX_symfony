  }
}

/* Card Variants - Pastel & Harmonious Colors */
.kpi-card-total {
  --accent-color: #7ec8f7;
  background: linear-gradient(135deg, #eef5ff 0%, #f8f0ff 100%);
  border: 1px solid rgba(126, 200, 247, 0.5);
  box-shadow: 0 6px 14px rgba(126, 200, 247, 0.12);
}

.kpi-card-active {
  --accent-color: #5ee0b5;
  background: linear-gradient(135deg, #e8fff6 0%, #e0f7ff 100%);
  border: 1px solid rgba(94, 224, 181, 0.5);
  box-shadow: 0 6px 14px rgba(94, 224, 181, 0.12);
}

.kpi-card-inactive {
  --accent-color: #c4b5fd;
  background: linear-gradient(135deg, #faf5ff 0%, #f5f0ff 100%);
  border: 1px solid rgba(196, 181, 253, 0.5);
  box-shadow: 0 6px 14px rgba(196, 181, 253, 0.12);
}

/* Hover State - Enhanced Luminous Effect */
.kpi-card-total:hover {
  border-color: rgba(126, 200, 247, 0.8);
  box-shadow: 0 16px 32px rgba(126, 200, 247, 0.22), 0 0 25px rgba(126, 200, 247, 0.18);
  background: linear-gradient(135deg, #f0f8ff 0%, #fcf5ff 100%);
}

.kpi-card-active:hover {
  border-color: rgba(94, 224, 181, 0.8);
  box-shadow: 0 16px 32px rgba(94, 224, 181, 0.22), 0 0 25px rgba(94, 224, 181, 0.18);
  background: linear-gradient(135deg, #f0fffa 0%, #eef9ff 100%);
}

.kpi-card-inactive:hover {
  border-color: rgba(196, 181, 253, 0.8);
  box-shadow: 0 16px 32px rgba(196, 181, 253, 0.22), 0 0 25px rgba(196, 181, 253, 0.18);
  background: linear-gradient(135deg, #fdfaff 0%, #faf5ff 100%);
}

.kpi-top {
  display: flex;
  align-items: center;
  gap: 12px;
  position: relative;
  z-index: 3;
}

.kpi-icon {
  width: 48px;
  height: 48px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(4px);
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.kpi-card:hover .kpi-icon {
  transform: scale(1.05) translateY(-2px);
  box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
}

.kpi-val {
  font-size: 2.2rem;
  font-weight: 800;
  line-height: 1;
  letter-spacing: -0.02em;
  position: relative;
  z-index: 3;
  transition: transform 0.3s ease;
}

.kpi-card:hover .kpi-val {
  transform: scale(1.02);
}

.kpi-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-top: auto;
  position: relative;
  z-index: 3;
  transition: all 0.3s ease;
}

/* Text Colors - Solid and Clearly Visible in Light Theme */
.kpi-card-total .kpi-val,
.kpi-card-active .kpi-val,
.kpi-card-inactive .kpi-val {
  color: #1a2c3e;
}

.kpi-card-total .kpi-label {
  color: #4a5568;
  opacity: 1;
}

.kpi-card-active .kpi-label {
  color: #2c5a4a;
  opacity: 1;
}

.kpi-card-inactive .kpi-label {
  color: #5b4c8a;
  opacity: 1;
}

/* Icon Colors with Solid Backgrounds */
.kpi-card-total .kpi-icon {
  color: #4a9eff;
  background: rgba(74, 158, 255, 0.15);
}

.kpi-card-active .kpi-icon {
  color: #2c9c7a;
  background: rgba(44, 156, 122, 0.15);
}

.kpi-card-inactive .kpi-icon {
  color: #9b87f5;
  background: rgba(155, 135, 245, 0.15);
}

/* Optional: Add a decorative element from original design */
.kpi-card::before {
  /* Keep the shimmer animation, remove the circular element if needed */
  content: '';
  position: absolute;
  top: -30px;
  right: -30px;
  width: 110px;
  height: 110px;
  border-radius: 50%;
  opacity: 0.08;
  background: var(--accent-color);
  pointer-events: none;
  z-index: 0;
}

.kpi-card:hover::before {
  opacity: 0.15;
  transform: scale(1.05);
  transition: all 0.4s ease;
}

/* Responsive Adjustments */
@media (max-width: 768px) {
  .kpi-card {
    height: auto;
    min-height: 130px;
    padding: 1rem;
  }
  
  .kpi-val {
    font-size: 1.8rem;
  }
  
  .kpi-icon {
    width: 40px;
    height: 40px;
    font-size: 18px;
  }
  
  .kpi-label {
    font-size: 10px;
  }
}

/* Dark Mode Support - Maintains Readability */
@media (prefers-color-scheme: dark) {
  .kpi-card-total {
    background: linear-gradient(135deg, rgba(100, 130, 190, 0.25) 0%, rgba(130, 110, 190, 0.25) 100%);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(126, 200, 247, 0.4);
  }
  
  .kpi-card-active {
    background: linear-gradient(135deg, rgba(70, 150, 130, 0.25) 0%, rgba(90, 150, 170, 0.25) 100%);
    border: 1px solid rgba(94, 224, 181, 0.4);
  }
  
  .kpi-card-inactive {
    background: linear-gradient(135deg, rgba(110, 90, 170, 0.25) 0%, rgba(130, 100, 190, 0.25) 100%);
    border: 1px solid rgba(196, 181, 253, 0.4);
  }
  
  .kpi-card-total .kpi-val,
  .kpi-card-active .kpi-val,
  .kpi-card-inactive .kpi-val {
    color: #f0f3fa;
  }
  
  .kpi-card-total .kpi-label {
    color: #cbd5e6;
    opacity: 0.9;
  }
  
  .kpi-card-active .kpi-label {
    color: #b8f0e0;
    opacity: 0.9;
  }
  
  .kpi-card-inactive .kpi-label {
    color: #e0d4ff;
    opacity: 0.9;
  }
  
  .kpi-card-total .kpi-icon {
    background: rgba(126, 200, 247, 0.2);
  }
  
  .kpi-card-active .kpi-icon {
    background: rgba(94, 224, 181, 0.2);
  }
  
  .kpi-card-inactive .kpi-icon {
    background: rgba(196, 181, 253, 0.2);
  }
}

  .toolbar { display:flex; align-items:center; gap:12px; margin-bottom:24px; flex-wrap:wrap; }
  .search-input-wrap { position:relative; flex:1; min-width:220px; }
  .search-input-wrap input {
    width:100%; padding:10px 16px 10px 40px;
